Init_ResetMemory(int Heap0Size)
{
	HEREIAM("");
	
   #if !DEBUG
	
	// Fixed size small heap.
   HeapDefs[0][0]=TopOfCode;
   HeapDefs[0][1]=HeapDefs[0][0]+Heap0Size;
   
	// and the big heap can have whatever is left.
   HeapDefs[1][0]=HeapDefs[0][1];
   HeapDefs[1][1]=MEMTOP-STACKSIZE;

   if (HeapDefs[1][0]>HeapDefs[1][1]-100)
   {
#		if DEBUG
      printf("\n\nDisaster! No space for a decent big heap!");
      ASSERT(0,"Not enough space for big heap");
#		endif
   }
	
   #else

   // We know here that the DDX is off, and DEBUG is on, so
   // we can assume we have 8 megs to play with
   // Note that this means a CD burn version can't have DEBUG on. However
   // even if extended RAM is not used when DEBUG is on, we probably still
   // couldn't have DEBUG on in a CD version because so much memory is used
   // by the debug code. 

   int BigHeapSize=MEMTOP-STACKSIZE-TopOfCode-Heap0Size+DEBUGCODESIZE;
   #if MICKMAP
   HeapDefs[0][0]=0x80200000;	// 1M for the small heap.
   HeapDefs[0][1]=0x80300000;
   
   HeapDefs[1][0]=0x80300000; // 3M for the big heap.
   HeapDefs[1][1]=0x80300000 + BigHeapSize + 1000000;			// extra million bytes for mickmap polybuffer
	#else
   // Calculate the size available to the big heap (heap 1) if DEBUG were
   // off, then allocate all the heaps from the extended RAM.
	// This is therefore emulating the memory that would be available if DEBUG were off.

   HeapDefs[0][0]=0x80200000;
   HeapDefs[0][1]=0x80200000+Heap0Size;
   
   HeapDefs[1][0]=0x80200000+Heap0Size;
   HeapDefs[1][1]=0x80200000+Heap0Size+BigHeapSize;
							
	// The HIGSPEEDCACHE heap is statically defined in mem.cpp.
   #endif
   #endif

   Mem_Init();    // Init memory manager

	extern int TotalCClassUsage;
	TotalCClassUsage = 0;
	extern int TotalCommandPointMemory;
	TotalCommandPointMemory = 0;
	extern int	TotalPaletteUsage;
	TotalPaletteUsage = 0;
	extern int	TotalPackUsage;
	TotalPackUsage = 0;
	extern int	TotalTextureUsage;
	TotalTextureUsage = 0;
	extern int	TotalVabUsage;
	TotalVabUsage = 0;
	extern int	TotalBitUsage;
	TotalBitUsage = 0;




}




void Init_Restart(EPackInitType Mode, int SmallHeapSize)
{
	HEREIAM("");

	
	extern char *pBMR;		// Reset the BMR, as there may ahve been one loaded
	pBMR = NULL;
	extern Uint16 *pCompressedBMR;	 // unlikely, but lets get rid of the compressed one as well
	pCompressedBMR = NULL;


// if there was anything in memory, then Init_Cleanup will tidy up, reset lists
// stop FMV, clear flags and suchlike
   Init_Cleanup(HARD_CLEANUP);	// clean up as much as possible, stop FMV, etc
	Init_ResetMemory(SmallHeapSize);
	Db_Reset();

   #if DEBUG
   Debug_InitDiagnostics();
   #endif

   Spool_Init();
	TitleTimeout=TITLETIMEOUT_REGULAR;

	Flash_Reset();		// clear any flashes, or black rectangles.

   if (Mode == PACK640x480)
      Pack_Init640x480();
   else
      Pack_Init();

   SFX_InitAtStart();
   Pal_Init();
   Font_Reset();

	Pad_LockAnalog();			// lock the pads into analog mode


/////
}


void Init_ForGame()
{
	HEREIAM("");

	pCurrentViewport = &ApocalypseViewport;
	
	Db_Init();

	Front_Init(); // Don't do any file loading before this.

   Video_InitOnce();
   CamPt_Init();
   Video_Init();

}

void Init_DebugStuff()
{
	HEREIAM("");
	
   extern Uint32 *__text_org,*memset,*memcpy;
	Uint32* pCodeStart=(Uint32*)&__text_org;
	Uint32* pCodeEnd=(Uint32*)&EndOfOurCode__Fv;

   #if DEBUG
	// Note: Maybe this should be done the same way that memset's are checked for above?
   // Install the "built in new" patch, which asserts if the default
   // C++ new operator ever gets called, which we don't want to happen
   // cos it'll trash the heaps
   Uint32* pPatch=(Uint32*)(void (*)())Mips_BuiltInNewPatch;
   extern Uint32* __builtin_new;
   Uint32* pDest=(Uint32*)&__builtin_new;
   for (int i=0; i<7; ++i) *pDest++=*pPatch++;
	
   pPatch=(Uint32*)(void (*)())Mips_BuiltInDeletePatch;
   extern Uint32* __builtin_delete;
   pDest=(Uint32*)&__builtin_delete;
   for (int i=0; i<7; ++i) *pDest++=*pPatch++;

   // TopOfCode is the address of the first thing above all code and
   // static data. It is defined in address.s
   ASSERT(TopOfCode<MEMTOP-STACKSIZE,"Blimey, code has reached the stack");

	// This is put here instead of right at the start, because ASSERT's don't seem
	// to work properly until the various GPU init functions have been called.
	// ----------------------------------------------------------------------------
	//              Search the code for any memset or memcpy calls.
	// ----------------------------------------------------------------------------
	
	// Calculate the machine code instructions to look for.
	Uint32 MemsetCall=0x0c000000|((((Uint32)&memset)&0xffffff)>>2);
	Uint32 MemcpyCall=0x0c000000|((((Uint32)&memcpy)&0xffffff)>>2);
	Uint32 NewCall=0x0c000000|((((Uint32)&__builtin_new)&0xffffff)>>2);
	Uint32 DeleteCall=0x0c000000|((((Uint32)&__builtin_delete)&0xffffff)>>2);
	
	// Choose the address range to search.
	// The dummy function EndOfOurCode() is used to limit the search to our code, because
	// if the linker generated __text_orgend were used instead it would find all the
	// memcpy's contained in the library functions. (Such as PutDrawEnv and PutDispEnv)
	// Do the search.
	for (Uint32 *pInstruction=pCodeStart; pInstruction<pCodeEnd; ++pInstruction)
	{
		if (*pInstruction==MemsetCall)
		{
			sprintf(AssertString,"\n Address = %lx",pInstruction);
			ASSERT(0,"Eeeeeeek! Memset call!!!");
		}	
		if (*pInstruction==MemcpyCall)
		{
			sprintf(AssertString,"\n Address = %lx",pInstruction);
			ASSERT(0,"Eeeeeeek! Memcpy call!!!");
		}	
		
		if (*pInstruction==NewCall)
		{
			sprintf(AssertString,"\n Address = %lx",pInstruction);
			ASSERT(0,"Eeeeeeek! BuitIn new call!!!");
		}	
		if (*pInstruction==DeleteCall)
		{
			sprintf(AssertString,"\n Address = %lx",pInstruction);
			ASSERT(0,"Eeeeeeek! BuiltIn delete call!!!");
		}
			
	}
	
	// ----------------------------------------------------------------------------
	// Check class offsets & sizes, to make sure they haven't changed from
	// what they are assumed to be in some places.

	Debug_CheckClasses();
   ProfileInit(1);
   // The wierd cast is to stop a warning
//   DrawSyncCallback((void (*)(...))Profile_DrawingDone);
   Debug_Init();
   #endif

	// Whilst we're here, maybe print our code size, which could be handy.
	#if PRINTOURCODESIZE&&(DEBUG||(MICK&&!CD))
	printf("Our code size = %ld bytes.\n",((Uint32)pCodeEnd)-((Uint32)pCodeStart));
	#endif


}


void Init_AtStart()
{
   RECORDRA;
	HEREIAM("");


#	if NEWEXCEPTIONHANDLER||(CD&&!SUBMIT)
//   Mips_InstallExceptionHandler();
#	endif
	
   ResetCallback();

#	if !DEMODISK
	Card_Init(1);
#	endif

#	if PAL
	SetVideoMode( MODE_PAL );
#	endif


	pCurrentViewport = &ApocalypseViewport;
		
   Pad_InitAtStart();
   InitGeom();
   ResetGraph(0);
   SetGraphDebug(0);
	Db_InitAtStart();
   RECT screen={0,0,1024,512};
   ClearImage(&screen,0,0,0);						// Clear all of VRAM to black
   VSyncCallback((void (*)(...))MyVSync);		// Install the Vblank interrup handler
   SetDispMask(1);									// Turn the screen on (will be black)
	Init_DebugStuff();								// <<<< needs to be here
   Camera_InitialRand(652973);
   SFX_InitAtStart();
   FileIO_Init();
	GameFMV_Init();
   M3dInit_InitAtStart();							// Just initializes some tables and stuff
   Redbook_XAInit();
}


