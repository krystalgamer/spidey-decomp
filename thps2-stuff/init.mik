// Kills all the non-protected members of the list.
static void DeleteList(CBody *pList)
{
   CBody* pNext;
   if (pList) pNext=(CBody*)(pList->mNextItem);
   while (pList)
   {
      if (!(pList->mCBodyFlags&CBODY_PROTECTED)) delete pList;
      pList=pNext;
      if (pList) pNext=(CBody*)(pList->mNextItem);
   }
}	

// Kills all CBody's and all bits.
// This assumes each object will delete anything
// it has created in its destructor 
void Init_KillAll()
{
   RECORDRA;
	HEREIAM("");
	// Kill all the non-protected members in all the CBody lists.

   DeleteList(MechList);
   DeleteList(CameraList);
   DeleteList(BaddyList);
   DeleteList(EnvironmentalObjectList);
   DeleteList(BackgroundList);
   DeleteList(PowerUpList);
   DeleteList(SuspendedList);

	// Any protected members should have been deleted by their parents, so assert if
	// anything is left.
	ASSERT(MechList==NULL,"Leftover protected members of MechList");
	ASSERT(CameraList==NULL,"Leftover protected members of CameraList");
	ASSERT(BaddyList==NULL,"Leftover protected members of BaddyList");
	ASSERT(BackgroundList==NULL,"Leftover protected members of BackgroundList");
	ASSERT(EnvironmentalObjectList==NULL,"Leftover protected members of EnvironmentalObjectList");
	ASSERT(PowerUpList==NULL,"Leftover protected members of PowerUpList");
	ASSERT(SuspendedList==NULL,"Leftover protected members of SuspendedList");

    // Delete all trickable objects
    TrickOb_DeleteAll();

    // Delete all rail objects
    Rail_DeleteAll();

   // Now the objects are gone it's safe to kill the bits
   // (The objects should have destroyed their child bits if they had any)
   Bit_DeleteAll();
	
	// Delete any leftover zooming messages.
	Mess_DeleteAll();
	
	// Better reinitialise the tints, otherwise those leftover from the last level
	// will carry on trying to tint non-existent SItem's, which would be very bad.
}

// Kills all CBodies and bits and seeds, clears all environment PSXs, and
// does general reinitialisation.
// It does not do any resetting of the triggering system.
void Init_Cleanup( int type )
{
	pCurrentViewport = &ApocalypseViewport;

	HEREIAM("");
	// Reset MIDI in case we came here from quitting the paused menu in the game.
	SFX_ResetMIDIPausedPriorToPause();		  // Does nothing if no MIDI
	// Resets various flags
	SFX_LevelStart();								  // Just clears on flag

//  	SpuSetKey( SPU_OFF, 0xFFFFFFFFUL );
	SFX_StopAll();
	FrontEnd2_MusicLoopVoice = 0;
	
	// Reset the camera zoom.
	extern SViewport ApocalypseViewport;
	ApocalypseViewport.Zoom=256;
	
	// Ensure no FMV playing.
	GameFMV_StopFMV();
	Redbook_XAStop();
	
	Init_KillAll();
	Trig_DeleteCommandPoints();

   CamPt_Cleanup(); // Always clean CamPt's up
   
	if( type == HARD_CLEANUP )
	{
		// Stop and clear out any currently playing MIDI.
		SFX_MIDIStop();
		SFX_SpoolOutMIDI();
		SFX_ReverbOff();

		// for now, disallow more than one create-a-skater
		// because it causes problems when freeing up memory
extern int SelectedSkater;
extern int SelectedSkater2;
		if (GNumberOfPlayers > 1)
			ASSERT(!(Create_UseSkater(SelectedSkater)&&Create_UseSkater(SelectedSkater2)),"Too many custom skaters");
		
		// clean up create-a-skater
		if (Create_UseSkater(SelectedSkater))
		{
			Create_FreeSkater();
		}

		if (GNumberOfPlayers > 1)
		{
			if (Create_UseSkater(SelectedSkater2))
			{
				Create_FreeSkater();
			}
		}
		
//		delete pSpecialSprite;
//		delete pScoreSprite;
//		delete pBarSprite;
//		delete pPausedSprite;

		Spool_ClearAllPSXs();
		Trig_RemoveDualBuffer();
		Trig_DeleteTrigFile();
		Pack_DefragmentFully();
		// This will make the main menu "continue" option restart at the start of the level.
		LastGameState.State.RestartName[0]=0;
	}
	else if (type == SOFT_CLEANUP)
	{
		Spool_ClearEnvironmentRegions();
	}
	
   Utils_InitialRand(RANDSEED);
   #if TWEAK
   Trig_ClearTrigMenu();
   #endif
  // Seed_Init();

	// Reset any screen flashes or fades.
	Flash_Reset();

   // Reset the zone stuff ready for the new environments
   if (type != LEVEL_EDITOR_CLEANUP)
   {
	   M3dZone_Init();
	   TrickOb_Init();

	   Rail_Init();
   }
	// Delete any background bits.
//	Backgrnd_Delete();

   // Set the gravity for the world
//   CVector grav(0,WORLD_GRAVITY,0);
//   Physics_SetGravity(grav);


   TTime=0;     
   Pad_ClearAll();
	SuspendDistance=DEFAULT_SUSPEND_DISTANCE;

	// Reset water damage.
	CurrentWaterDamage = 0;	

   // No water in level until script sets it
   CurrentWaterLevel = 0x7fffffff;
   CurrentWaterLevel2 = 0x7fffffff;
}


