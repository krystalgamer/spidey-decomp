#if DEBUG&&BITFIELD
#define PSXMEMORYSIZE (1048576*8)
#define BITFIELDSIZE ((PSXMEMORYSIZE/4)/8)
Uint8 MemBitfield[BITFIELDSIZE];
//Uint8 LeakCheckBitfield[BITFIELDSIZE];
static void FlagLocationUsed(Uint32 Loc)
{
	RECORDRA;
   Loc&=0x7fffffff;
   if (Loc>=PSXMEMORYSIZE || (Loc&3))
   {
   	printf("\nBad loc = 0x%08lx\n",Loc);
   	ASSERT(0,"Bad Loc sent to FlagLocationUsed");
   }

	int Mask=1<<((Loc>>2)&7);
	int i=Loc>>5;
   if (MemBitfield[i]&Mask)
   {
   	printf("\nBad loc = 0x%08lx\n",Loc);
   	ASSERT(0,"Location already used");
   }   
	MemBitfield[i]|=Mask;
}

static void FlagLocationUnused(Uint32 Loc)
{
	RECORDRA;
   Loc&=0x7fffffff;
   if (Loc>=PSXMEMORYSIZE || (Loc&3))
   {
   	printf("\nBad loc = 0x%08lx\n",Loc);
   	ASSERT(0,"Bad Loc sent to FlagLocationUnused");
   }

	int Mask=1<<((Loc>>2)&7);
	int i=Loc>>5;
   if ((MemBitfield[i]&Mask)==0)
   {
   	printf("\nBad loc = 0x%08lx\n",Loc);
   	ASSERT(0,"Tried to delete non-allocated memory");
   }   
	MemBitfield[i]&=~Mask;
}
#endif



Uint32 HeapDefs[MAXHEAPS][2]={{NULL,NULL},
                              {NULL,NULL}};


int LowMemory=FALSE;
static Uint32 CriticalBigHeapUsage=0;

#if RECORDSMALLHEAPPOINTERS&DEBUG
static int StartRecording=FALSE;
struct SPointer
{
	Uint32 *pWhatever;
	int ReturnAddress;
	int Flag;
	SPointer *pNext;
};

static SPointer *pFreeList;
static SPointer *pAllocatedList;
#endif

static Uint32 UniqueIndentifier=0;	

// Returns a pointer to the first byte after free block p
// p is a pointer to a block header, not a pointer returned by Mem_New
#define FREEAFTER(p) (SBlockHeader*)(((char*)((p)+1))+(p)->Size)

#define CHECKUP 0

// --------------------------------------------------------------------------
//
//           A high speed cache, separate from the above heaps, 
//           for storing small things.
//
// --------------------------------------------------------------------------


#if DEBUG
int CacheUsage=0;
int BiggestCacheRequest=0;
#endif
// --------------------------------------------------------------------------


// This keeps track of the number of searchs needed to find a free block
#define COUNTSEARCHS 1

// Make this 1 to make free blocks get filled with rubbish, so as to
// upset naughty functions that try to keep accessing freed memory
// Things will slow down if this is set, especially when deleting big things
// Note: This define is only effective if DEBUG is 1
// Another Note:  will be VERY SLOW if TONS_OF_RAM is true, as it usually scribbles over
// all 4 MB for each call to Mem_Delete()
#define SCRIBBLEOVERFREEBLOCKS 1				

// Set this to 1 to clear the allocated memory to 0
#define CLEARTOZERO 1



#if CLEARTOZERO
// Note, does not clear to zero, but to 0x33333333
#define ClearMem(p,n)                                 \
         {                                            \
            Uint32* pMem=(Uint32*)(p);                \
            for (int ii=0; ii<(n)/4; ++ii) *pMem++=0x33333333; \
         }
#else
#define ClearMem(p,n) NULL
#endif


#if DEBUG & SCRIBBLEOVERFREEBLOCKS
// Filling free blocks with rubbish only occurs if Scribble is TRUE.
// The purpose of this variable is to allow Mem_MoveBlockDown to still be 
// able to delete and reallocate a block without the source getting trashed 
// even if SCRIBBLEOVERFREEBLOCKS is set 
// Mem_MoveBlockDown will temporarily set Scribble to FALSE
static int Scribble=TRUE;
#endif



// --------------------------------------------------------------------------
// Mem_New and Mem_Delete will allocate memory from the area between HEAPBOT
// and HEAPTOP
//
// To keep fragmentation problems to a minimum, Mem_Delete will merge with
// adjacent holes
// Mem_New will allocate from the first biggest free block lowest in memory,
// which also helps to squash out holes.

// Head pointer of the free block linked list
SBlockHeader* FirstFreeBlock[MAXHEAPS];

// How much memory is being used on each heap. Includes the 8 byte headers.
int Used[MAXHEAPS];

#if DEBUG
int MemInitialised=FALSE;
int Holes[MAXHEAPS];

int FreeBlocks[MAXHEAPS];
int AllocatedBlocks[MAXHEAPS];

static int TotalSearch[MAXHEAPS];
static int NumSearchs[MAXHEAPS];
int AverageSearch[MAXHEAPS];
int MaxSearch[MAXHEAPS];

#if RECORDEVERYTHING


SMemDebug  MemDebug[MAXDEBUG];

int Mem_Debugging = 0;
int Mem_NextDebug = 0;
int Mem_When = 0;
int Mem_Snap = 0;

// Called when you want to record the state of the stack
void Mem_InitDebug()
{
	for (int i=0;i<MAXDEBUG;i++)
		MemDebug[i].pBlock = 0;
	Mem_NextDebug = 0;
	Mem_Debugging = 1;
	Mem_When = 0;
	Mem_Snap = 0;
}

// Record the allocation of a block
void Mem_Record(SBlockHeader *pBlock, int ReturnAddress)
{
	ASSERT(Mem_NextDebug < MAXDEBUG,"Mem Debug buffer full");
	MemDebug[Mem_NextDebug].pBlock = pBlock;
	MemDebug[Mem_NextDebug].ReturnAddress = ReturnAddress;

//	if (Mem_When == 932)
//		asm("break 666");

	MemDebug[Mem_NextDebug].When = Mem_When++;
	Mem_NextDebug++;
}

// Remove a block from the list
void Mem_Remove(void *p)
{
   SBlockHeader *pBlock=GETBLOCKHEADER(p);
	for (int i=0;i<Mem_NextDebug;i++)
	{
		if (MemDebug[i].pBlock == pBlock)
		{
			if (Mem_NextDebug == 1)
			{
				Mem_NextDebug = 0;
			}
			else
			{
				Mem_NextDebug--;				  // just copy the last item down over this.
				MemDebug[i] = MemDebug[Mem_NextDebug];
			}
			return;
		}
	}
	ASSERT(0,"Mem_remove did not find the block");
}

void Mem_SnapShot()
{
	Mem_Snap = Mem_When;
}


#include "pack.h"
SPack * Pack_GetSlot( void );

// Check to see if there are any memory with a time greater than this
void Mem_Check()
{
	int Errors = 0;
	int Total = 0;
	printf("\nMem_Snap is %d\n\n",Mem_Snap);
	for (int i=0;i<Mem_NextDebug;i++)
	{
		if (MemDebug[i].When >= Mem_Snap)
		{

			if (((int)MemDebug[i].ReturnAddress - (int)Pack_GetSlot) != 32)
			{
				Errors++;
				if (Errors < 100)
				{
					printf("\nStill Allocated\n");
					printf("pBlock->Size = %d  ",MemDebug[i].pBlock->Size);
					printf("ReturnAddress = %lx  ",MemDebug[i].ReturnAddress);
					printf("When = %d\n",MemDebug[i].When); 
				}
				else
					if (Errors == 100)
						printf("Too many Mem_Check Errors");
				Total += MemDebug[i].pBlock->Size;
			}
		}
	}
	printf("\nNew Blocks = %d, TOTAL new MEMORY = %d\n",Errors,Total);
//	ASSERT(Errors==0,"Mem_Check Errors");
}


#endif

