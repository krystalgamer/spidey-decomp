#if DEBUG||(MICK&&!CD)

static	const char * DumpArea  = (char*)0x80400000;
static	const	int	DumpWidth  = 600;
static	const int   DumpHeight = 180;
static	const int	DumpSize = DumpWidth * DumpHeight;
static	const char * DumpEnd = DumpArea + DumpSize;	


static int 	Off = 0;												// offset into memory
static char *pDump = DumpArea;
// only do a bit per frame
void Mem_DumpUpdate(int BytesPerFrame)
{

	if (!Pad[0].RightOne.Pressed || !Pad[0].RightTwo.Pressed)
		return;


// dodgy little thing, creates a 200x200 rectangle showing the heap, and groks it down to the screen
// where to put it in memory?   Try 0x80040000 for now

	char *Start;
	char *End;

	if (!Pad[0].Triangle.Pressed)
	{
	 	Start = (char*) HeapDefs[1][HBOT];
	 	End = (char*) HeapDefs[1][HTOP];
	}
	else										// if triangle pressed, then show the code
	{
		extern Uint32 TopOfCode;
	 	Start = (char*)0x80000000;
	 	End =   (char*)TopOfCode;							
	}

	int 	Len = (int)(End) - (int)(Start);
	int 	Step = Len * 256 / DumpSize;					// 8 bit fixed point step 

	// Find the end of this section
	// if past DumpEnd, then set to DumpEnd
	char *SectionEnd = pDump + BytesPerFrame;
	if (SectionEnd > DumpEnd)
		SectionEnd = (char*)DumpEnd;

	char *pFrom;

	// Update this section
	while (pDump < SectionEnd)
	{		
			Off += Step;
			pFrom = Start + (Off>>8);						
			*pDump++ = *pFrom;			// and copy a byte
	}	

	// If it was the last section, then back to 0
	if (SectionEnd == DumpEnd)
	{
		Off = 0;
		pDump = (char*)DumpArea;
	}


}



void Mem_DumpRect()
{
	
	RECT r;
	r.x=(512-DumpWidth/2)/2;
	r.y=pOtherBuffer->Top+(240-DumpHeight)/2;
	r.w=DumpWidth/2;
	r.h=DumpHeight;
	LoadImage( &r, (u_long *)DumpArea );
   DrawSync( 0 );

}


#define		MAXBLOCKTYPE	100
/*
struct	SDebugHeader
{
	int ParentHeap:4;
	size_t Size:28; 			// The size of the block in bytes, not including this header
   SBlockHeader* Next;
	// data after this is extra stuff
	char *pFunction;			// return address of function
	char *pFile;				// file it was in
	char *pPretty;				// Pretty function name
	int	Line;					// line number it was called from
	int	When;
};
*/

SDebugHeader  BlockType[MAXBLOCKTYPE];
int	BlockTypes;

#define MEMMAP 0x80500000

#include	"font.h"

extern void Pause(int Time);

// Display the heap, with the ability to zoom in and inspect individual areas
// and to display the names of blocks
SuperDuperMemoryInspector()
{
	int	HeapBot = HeapDefs[1][HBOT];
	int	HeapTop = HeapDefs[1][HTOP];
	int	HeapSize = HeapTop - HeapBot;
	
	printf ("heapsize = %d, Bot = %lx, Top = %lx\n",HeapSize, HeapBot,HeapTop);

	// wait for square and circle to be released
	while (Pad[0].Square.Pressed)
		Pad_Update();

	RECT r;

	printf ("Categorizing Block types\n");
	BlockTypes = 1;				// start out with type 1
	// First find out all the the block types
	SDebugHeader *pDebug = pFirstUsed;
	while (pDebug)
	{
		int i;
		char *pFunction = pDebug->pFunction;
		for (i=0;i<BlockTypes;i++)
		{
			if (BlockType[i].pFunction == pFunction)
			{
				BlockType[i].When++;
				break;
			}
		}
		if (i == BlockTypes)
		{
//			printf ("New Block %d  =  %lx\n",BlockTypes,pFunction);
			BlockType[BlockTypes] = *pDebug;
			BlockType[BlockTypes].When = 1;
			BlockTypes++;
		}

		pDebug = (SDebugHeader*)pDebug->Next;
	}


	// Now create a map of the heap, coded by block type
	// at 0x80050000 for now

	// clear it all to zero first
	char *pMap = (char*) MEMMAP;
	printf ("Zeroing Memory Map from %lx to %lx\n",pMap,(MEMMAP + HeapSize));
	while (pMap < (char*)(MEMMAP + HeapSize))
	{
		*pMap++ = 0;
	}
	int i;

	printf ("Creating Memory Map\n");
	// Now go through all the allocated blocks, and code the map based on block type
	pDebug = pFirstUsed;
	while (pDebug)
	{
		// Find the block type
		int	type;
		char *pFunction = pDebug->pFunction;
		for (i=0;i<BlockTypes;i++)
		{
			if (BlockType[i].pFunction == pFunction)
			{
				type = i;
				break;
			}
		}
		ASSERT(i!=BlockTypes,"Memory type for %lx not found",pFunction);
		pMap = MEMMAP - HeapBot + (char*)pDebug;
		int	len = pDebug->Size + sizeof(SDebugHeader);
		pMap -= sizeof(SDebugHeader);
//		printf ("%d,%d\n",type,len);
			extern int    Rnd(int n);

//		type = Rnd(255);
		for (i=0;i<len;i++)
		{
//			*pMap++ = Rnd(255);		//type;
			*pMap++ = type;
		}
		pDebug = (SDebugHeader*)pDebug->Next;
	}

	// Now we have the memory map in memory, so we can display it

	int	Start = 0;
	int	Step = 20*256;		// 256 = a step of 1
	int	Offset = 0;

	int	w = 256;
	int	h = 200;
	int	x = 100;
	int	y = 32;



   FntLoad(0, pOtherBuffer->Top);
   FntOpen(0, 0, 512, SCREENHEIGHT, 0, 1024);
DRAWENV DrawEnv;	
	SetDefDrawEnv(&DrawEnv, 0, pDoubleBuffer->Top, 512, SCREENHEIGHT);
//   SetDefDispEnv(&DispEnv, 0, 0, 512, SCREENHEIGHT);
   PutDrawEnv(&DrawEnv);
//   PutDispEnv(&DispEnv);




	printf ("Displaying Memory Map\n");
	while (!Pad[0].Start.Pressed)
	{
		Pad_Update();
		PollHost();

		int BytesPerLine = w * Step / 256;

		if (Pad[0].Up.Pressed)
		{
			Start -= BytesPerLine;
			if (Pad[0].Up.PressedTime > 1)
				Start -= 3*BytesPerLine;

//			printf ("Start = %d\n",Start);
		}

		if (Pad[0].Down.Pressed)
		{
			Start += BytesPerLine;
			if (Pad[0].Down.PressedTime > 1)
				Start += 3*BytesPerLine;
//			printf ("Start = %d\n",Start);
		}

//		if (Start > HeapSize - w*h*Step/256)
//				Start = HeapSize - w*h*Step/256;

//		if (Start < 0)
//			Start = 0;


		if (Pad[0].Right.Pressed && Step > 10)
		{
			int MidOffset = w * h/2 * Step /256;
			Start = Start + MidOffset/10;
			Step = Step * 9 / 10;
//			printf ("Step = %d\n",Step);
		}
		
		if (Pad[0].Left.Pressed && Step < 200*256)
		{
			int MidOffset = w * h/2 * Step /256;
			Start = Start - MidOffset/10;
			Step = Step * 10 / 9;
//			printf ("Step = %d\n",Step);
		}



		Offset = 0;
		Uint16* pOut = (Uint16*) DumpArea;
		char *pIn = (char*)((int)MEMMAP + (int)Start);
		char *pSample = DumpArea + (w*2) * (h/2); 
		while (pOut < (DumpArea + w * h*2) && pIn < MEMMAP + HeapSize)
		{
			Uint16 a = *pIn;
			a = a | (a<<8);
			
			if (pIn<MEMMAP)
				*pOut++ = (8<<10)+(8<<5)+8;
			else
			{
				if (a)
					*pOut++ = a;
				else
					*pOut++ = (10<<10)+(0<<5)+10;			// magenta = free
			}
			Offset += Step;
			if (Offset & 0xffffff00)
			{
		 		int Top = Offset >> 8;
				pIn += Top;
				Offset -= (Top<<8);
			}
		}


		if (pOut < (DumpArea + w * h*2))
		{
			while (pOut < (DumpArea + w * h*2))
				*pOut++ = (8<<10)+(8<<5)+8;			// nice null grey for "past the bottom"

		}
	
		r.x=x;
		r.y=pDoubleBuffer->Top+y;
		r.w=w;
		r.h=h;
		LoadImage( &r, (u_long *)DumpArea );
		DrawSync( 0 );

		r.x -= 16;
		r.y += h/2-1;
		r.w = 10;
		r.h = 3;
		ClearImage(&r,255,0,0);
		DrawSync( 0 );
		r.y += 1;
		r.w = 15;
		r.h = 1;
		ClearImage(&r,255,255,0);

		int Type = *pSample;

//		Db_FlipClear();					// Flip the buffers, start rendering and clear ot
		
		char	hmm[200];
		sprintf(hmm,"\n\n  %s (%s:%d)",BlockType[Type].pPretty,BlockType[Type].pFile,BlockType[Type].Line);


   FntPrint(hmm);
   //ClearImage(&bg, 0, 0, 0);
   FntFlush(-1);
		DrawSync(0);

//		Pause(1);
//		Db_DisplayDraw();					// Start Rendering



	}

	while (Pad[0].Start.Pressed)
		Pad_Update();
	Pad[0].Start.Triggered = 0;


}



int Mem_DumpToScreen()
{

// dodgy little thing, creates a 200x200 rectangle showing the heap, and groks it down to the screen
// where to put it in memory?   Try 0x80040000 for now
	if (!Pad[0].RightOne.Pressed || !Pad[0].RightTwo.Pressed)
		return 0 ;

	#if SUPERMEMDEBUG
	if (Pad[0].Square.Pressed)
		SuperDuperMemoryInspector();
	#endif


	Mem_DumpRect();
	return 1;
}
#endif

#if SMALLHEADER&&!(SUPERMEMDEBUG)
void* Mem_New(size_t size, int Heap, int AssertOnFailure)
{
	if (size<=4)
		size = 8;
//	printf ("N %d\n",size);
	Uint32 *p = (Uint32*)Mem_NewX(size-4,Heap,AssertOnFailure);
	p--;		// use the "Id" field, which is never used
	return (void *) p; 
}

void Mem_Delete(void *p)
{
//	printf ("D\n");
	Mem_DeleteX((void*)((int)(p) + 4));
}

void Mem_Shrink(void *p, size_t newsize)
{
	if (newsize<=4)
		newsize = 8;
//	printf ("S %d\n",newsize);
	Mem_ShrinkX((void*)((int)(p)+4),newsize-4);
}

int Mem_GetBlockSize(void *p)
{
	int n =  4+Mem_GetBlockSizeX((void*)((int)(p)+4));
	return n;
}

#endif

#if (SUPERMEMDEBUG)

#define MEMDIFF (sizeof(SDebugHeader) - sizeof(SBlockHeader))

void*   Mem_NewSuper(char* pFile, char*pPretty, int Line, size_t size, int Heap=SMALLHEAP, int AssertOnFailure=TRUE)
{
		register int _retaddr;
	__asm__ volatile ("move %0,$31" : "=r"(_retaddr) : : "%0");
	
	//	printf ("N %d\n",size);
	char *p = (char*)Mem_NewX(size+MEMDIFF,Heap,AssertOnFailure);
	
	SDebugHeader *pDebug = (SDebugHeader*)(p-sizeof(SBlockHeader));
	if (pFirstUsed == 0)
	{
		pFirstUsed = pDebug;	  		// first item in the list
		pDebug->Next = 0;				// and the last
	}
	else
	{
		pDebug->Next = (SBlockHeader*)pFirstUsed;	  // insert in head of list
		pFirstUsed = pDebug;
	}

	
	pDebug->pFunction = (char*)_retaddr;
	pDebug->Line = Line;
	pDebug->pFile = pFile;
	pDebug->pPretty = pPretty;

	p += MEMDIFF;		
	return (void *) p; 
}

void Mem_Delete(void *p)
{
//	printf ("D\n");
	SDebugHeader *pDebug = (SDebugHeader*)((int)(p)-sizeof(SDebugHeader));
	if (pFirstUsed == pDebug)
	{
		pFirstUsed = (SDebugHeader*)pDebug->Next;
	}
	else
	{
		SDebugHeader *pFind = pFirstUsed;
		while (pFind->Next != (SBlockHeader*)pDebug)
		{
			pFind = (SDebugHeader*)(pFind->Next);
			ASSERT(pFind,"Debug info not found in Mem_Delete");
		}
		pFind->Next = pDebug->Next;
	}
	Mem_DeleteX((void*)((int)(p) - MEMDIFF));
}

void Mem_Shrink(void *p, size_t newsize)
{
	if (newsize<=4)
		newsize = 8;
//	printf ("S %d\n",newsize);
	Mem_ShrinkX((void*)((int)(p)-MEMDIFF),newsize+MEMDIFF);
}

int Mem_GetBlockSize(void *p)
{
	int n =  Mem_GetBlockSizeX((void*)((int)(p)-MEMDIFF)) - MEMDIFF;
	return n;
}


#endif

int	Mem_SuperDebugUsage()
{
#if SUPERMEMDEBUG
	printf ("\nMemory Usage\n\n");
	SDebugHeader *pDebug = pFirstUsed;
	while (pDebug)
	{
//		printf ("%8lx %d\n",pDebug->pFunction,pDebug->Size);
		char *Function = pDebug->pFunction;
		SDebugHeader *pBefore = pFirstUsed;
		while (pBefore != pDebug)				// search to see if we had this before
		{
			if (pBefore->pFunction == Function)
				break;
			pBefore = (SDebugHeader*)pBefore->Next;
		}
		if (pBefore == pDebug)					// not found before
		{
			// add up this one, and all the ones after
			int	TotalSize = 0;
			int	Count = 0;
			SDebugHeader *pTally = pDebug;
			while (pTally)
			{
				if (pTally->pFunction == Function)
				{
					TotalSize += pTally->Size - MEMDIFF + 4;  // calculate the size as if no SUPERMEMDEBUG
					Count++;
				}
				pTally = (SDebugHeader*)pTally->Next;
			}
			printf("%8lx : %4d %7d  %s (%s:%d)\n",Function,Count,TotalSize,pDebug->pPretty,pDebug->pFile,pDebug->Line);
		}
  		pDebug = (SDebugHeader*)pDebug->Next;
	}
#endif
}


