void M3dColij_InitLineInfo(SLineInfo *pInfo)
{
	short		*pShort;
	SVECTOR	L,AbsL;
	Vector	*p0,*p1;

//	ASSERT(pInfo->StartCoords.vx != pInfo->EndCoords.vx ||
//			 pInfo->StartCoords.vy != pInfo->EndCoords.vy ||
//			 pInfo->StartCoords.vz != pInfo->EndCoords.vz, "Degenerate collision segment");

		//	set up the world collision	segment transform	and other stuff

		//	assume no collision

	pInfo->pItem	 =	NULL;
	pInfo->Distance =	0x7FFFFFFF;
	pInfo->Model	 =	-1;
	pInfo->RecordTriggerZoneHits=FALSE;


	pInfo->DropDown = 0;		//	assume not a drop-down test


	// calculate the world collision segment transform (cst)

	L.vx = pInfo->EndCoords.vx	- pInfo->StartCoords.vx	>>	FRACBITS;
	L.vy = pInfo->EndCoords.vy	- pInfo->StartCoords.vy	>>	FRACBITS;
	L.vz = pInfo->EndCoords.vz	- pInfo->StartCoords.vz	>>	FRACBITS;

#if 0

	AbsL.vx = L.vx>=0 ? L.vx : -L.vx;
	AbsL.vy = L.vy>=0 ? L.vy : -L.vy;
	AbsL.vz = L.vz>=0 ? L.vz : -L.vz;

	pShort =	&pInfo->WorldCst.m[0][0];

	if (AbsL.vx>AbsL.vy && AbsL.vx>AbsL.vz)
	{
		if (L.vx>0)
		{
			*pShort++ = -(L.vy<<12)/L.vx;
			*pShort++ = 0x1000;
			*pShort++ = 0;
			*pShort++ = -(L.vz<<12)/L.vx;
			*pShort++ = 0;
			*pShort++ = 0x1000;
			*pShort++ = 0x1000;
			*pShort++ = 0;
			*pShort++ = 0;
		}
		else
		{
			*pShort++ = (L.vy<<12)/L.vx;
			*pShort++ = -0x1000;
			*pShort++ = 0;
			*pShort++ = -(L.vz<<12)/L.vx;
			*pShort++ = 0;
			*pShort++ = 0x1000;
			*pShort++ = -0x1000;
			*pShort++ = 0;
			*pShort++ = 0;
		}
		pInfo->Length = AbsL.vx;
	}
	else if (AbsL.vy>AbsL.vz)
	{
		if (L.vy>0)
		{
			*pShort++ = 0;
			*pShort++ = -(L.vz<<12)/L.vy;
			*pShort++ = 0x1000;
			*pShort++ = 0x1000;
			*pShort++ = -(L.vx<<12)/L.vy;
			*pShort++ = 0;
			*pShort++ = 0;
			*pShort++ = 0x1000;
			*pShort++ = 0;
		}
		else
		{
			*pShort++ = 0;
			*pShort++ = (L.vz<<12)/L.vy;
			*pShort++ = -0x1000;
			*pShort++ = 0x1000;
			*pShort++ = -(L.vx<<12)/L.vy;
			*pShort++ = 0;
			*pShort++ = 0;
			*pShort++ = -0x1000;
			*pShort++ = 0;
		}
		pInfo->Length = AbsL.vy;
	}
	else
	{
		if (L.vz>0)
		{
			*pShort++ = 0x1000;
			*pShort++ = 0;
			*pShort++ = -(L.vx<<12)/L.vz;
			*pShort++ = 0;
			*pShort++ = 0x1000;
			*pShort++ = -(L.vy<<12)/L.vz;
			*pShort++ = 0;
			*pShort++ = 0;
			*pShort++ = 0x1000;
		}
		else
		{
			*pShort++ = -0x1000;
			*pShort++ = 0;
			*pShort++ = (L.vx<<12)/L.vz;
			*pShort++ = 0;
			*pShort++ = 0x1000;
			*pShort++ = -(L.vy<<12)/L.vz;
			*pShort++ = 0;
			*pShort++ = 0;
			*pShort++ = -0x1000;
		}
		pInfo->Length = AbsL.vz;
	}

#else

	int		lzc,Shift1,Shift2;
	Sint32	s1,s2,r1,r2,s1Norm,s2Norm,r1Norm,r2Norm;
	Sint16	Cos, Sin;

	s1	= SQ2(L.vx,L.vz);

	if	(s1)
	{
		gte_ldlzc(s1);
		gte_nop();
		gte_nop();
		gte_stlzc(&lzc);
		Shift1 = lzc-1 >> 1;

		s1Norm =	s1 << (lzc-1 & 0x1E);
		r1Norm = M3dMaths_SquareRoot0(s1Norm);

		Sin = (L.vx<<12+Shift1)/r1Norm;
		Cos = (L.vz<<12+Shift1)/r1Norm;

		pShort =	&Tfm.m[0][0];

		*pShort++ =	Cos;
		*pShort++ =	0;
		*pShort++ =	-Sin;
		*pShort++ =	0;
		*pShort++ =	0x1000;
		*pShort++ =	0;
		*pShort++ =	Sin;
		*pShort++ =	0;
		*pShort	 =	Cos;

		s2	= s1+SQ1(L.vy);

		gte_ldlzc(s2);
		gte_nop();
		gte_nop();
		gte_stlzc(&lzc);
		Shift2 = lzc-1 >> 1;

		s2Norm =	s2 << (lzc-1 & 0x1E);
		r2Norm = M3dMaths_SquareRoot0(s2Norm);
		pInfo->Length = r2Norm>>Shift2;

		Sin = (L.vy<<12+Shift2)/r2Norm;
		Cos = (r1Norm<<12)/(r2Norm << Shift1-Shift2);

		pShort =	&pInfo->WorldCst.m[0][0];

		*pShort++ =	0x1000;
		*pShort++ =	0;
		*pShort++ =	0;
		*pShort++ =	0;
		*pShort++ =	Cos;
		*pShort++ =	-Sin;
		*pShort++ =	0;
		*pShort++ =	Sin;
		*pShort	 =	Cos;

		MulMatrix(&pInfo->WorldCst, &Tfm);
	}
	else
	{
		if	(L.vy<0)
		{
			Sin =	0xF000;
			pInfo->Length = -L.vy;
		}
		else
		{
			Sin =	0x1000;
			pInfo->Length = L.vy;
			pInfo->DropDown = 1;
		}

		pShort =	&pInfo->WorldCst.m[0][0];

		//	in	the case	of	a drop-down	vector, the	world	cst will	be
		//	1	0	0      1  0  0
		//	0	0 -1  or  0  0  1
		//	0	1	0      0 -1  0

		*pShort++ =	0x1000;
		*pShort++ =	0;
		*pShort++ =	0;
		*pShort++ =	0;
		*pShort++ =	0;
		*pShort++ =	-Sin;
		*pShort++ =	0;
		*pShort++ =	Sin;
		*pShort	 =	0;

	}

#endif

	SetRotMatrix(&pInfo->WorldCst);


		//	get the bounding box	of	the collision segment

	p0	= &pInfo->StartCoords;
	p1	= &pInfo->EndCoords;

	if	(p0->vx < p1->vx)
		pInfo->MinCoords.vx = p0->vx,	pInfo->MaxCoords.vx = p1->vx;
	else
		pInfo->MinCoords.vx = p1->vx,	pInfo->MaxCoords.vx = p0->vx;

	if	(p0->vy < p1->vy)
		pInfo->MinCoords.vy = p0->vy,	pInfo->MaxCoords.vy = p1->vy;
	else
		pInfo->MinCoords.vy = p1->vy,	pInfo->MaxCoords.vy = p0->vy;

	if	(p0->vz < p1->vz)
		pInfo->MinCoords.vz = p0->vz,	pInfo->MaxCoords.vz = p1->vz;
	else
		pInfo->MinCoords.vz = p1->vz,	pInfo->MaxCoords.vz = p0->vz;


		//	set the inquiry number
		//	this will be unique over 65535 consecutive line	or	sphere tests

	NextInquiry();

	pInfo->Inquiry = Inquiry;
}





void M3dColij_LineToItem(SItem *pItem,	SLineInfo *pInfo)
{
	if	(!pItem)	return;

	if (pInfo->Length==0)
		return;

	SetRotMatrix(&pInfo->WorldCst);

	M3dAsm_LineColijPreprocessItems(pItem,0,pInfo,pInfo->Inquiry);

	for (	; pItem;	pItem=pItem->NextItem)
		if	(pItem->Inquiry != pInfo->Inquiry)
		{
			pItem->Inquiry	= pInfo->Inquiry;
			M3dColij_LineToThisItem(pItem, pInfo);
		}
}




#if 0   // 1 if old collision
