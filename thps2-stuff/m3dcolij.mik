// Globals...

MATRIX	Tfm;
CBody		*pBodyHit;
SHit		NearestHit;
Uint16	Inquiry=0xFFFF;
int		CameraCollisionCheck	 = 0,
			BaddyCollisionCheck	 = 0,
			BulletCollisionCheck	 = 0,
			TriggerCollisionCheck = 0;
int		CollidedTriggerModel;
