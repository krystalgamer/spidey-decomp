{
	if	(!ppItem) return;

	if (pInfo->Length==0)
		return;

	SetRotMatrix(&pInfo->WorldCst);

	M3dAsm_LineColijPreprocessItemsZoned(ppItem,0,pInfo,pInfo->Inquiry);

	for (	; *ppItem; ppItem++)
		if	((*ppItem)->Inquiry != pInfo->Inquiry)
		{
			(*ppItem)->Inquiry =	pInfo->Inquiry;


