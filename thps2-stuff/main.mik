			GameFMV_PlayMovie( -1 );			   // 0 = Activision Logo
		Pad_Update();
		if ( !Pad[0].Start.Pressed && ( !Pad[0].LeftOne.Pressed || !Pad[0].LeftTwo.Pressed) )
			GameFMV_PlayMovie( -2 );			// 1 = Neversoft Logo
		Pad_Update();
		if ( !Pad[0].Start.Pressed && ( !Pad[0].LeftOne.Pressed || !Pad[0].LeftTwo.Pressed) )
			GameFMV_PlayMovie( -25 );			// 24 = Intro movie

		#endif


#if DEMODISK
      Vblanks = 0;
      Xblanks = 0;
#endif

EFrontResult Result;

LABEL_MAINMENU:

      Init_Restart(PACK512x240,SMALL_HEAP_SIZE);    // Resets all of memory, and vram
		Db_Init();

// Little Problem the above should not need to be called, but Skater will not be displayed in tehf ront end
// if it is not.

		GNumberOfPlayers = 1;
      Init_Restart(PACK640x480,HIRES_SMALL_HEAP_SIZE);   // Resets all of memory, and vram
      HiRes_Init();
      HiRes_TitleScreen();

		ASSERT(0,"Never got here!");


#if 0
      // Should never get to this point ...	except for the demo disk
      Init_AtEnd();

#if LINKED_STARTUP
      printf("\nLeaving ProSkate main(), Bye!\n");
#endif
      return (0);

#endif

   }




// ================================================================================
// method added by Ryan, 3/24/99
int LaunchGame()
{
	int Result = FRONTRESULT_PLAYGAME;
	
	Pack_Init(); // To avoid strangeness with Pack_Defragment()
	Init_Restart(PACK512x240,SMALL_HEAP_SIZE);    // Resets all of memory, and vram

	SSaveGame tmp;
	tmp = StartupGameState; // Init_ForGame resets it, ouch.
	
	// RYAN: Init_ForGame() calls Video_InitOnce(), which allocates block of memory
	// for the replay video, pointed to by GVInfo1.pBlockStart
	Init_ForGame();

	StartupGameState = tmp;
	Front_SetPreferences(StartupGameState.Preferences); //@@@### Was done in Front_MainMenu

	switch (Result)
	{
		case FRONTRESULT_PLAYGAME:

			LoadingScreen_Main();	

			if (GAutoTest)
				DumpAutoTest();			// draw debuggin numbers on screen for if autotest
				
    		Front_LoadGame(&StartupGameState);
      	break;
   	default:
      	break;
    }

	// if triangle pressed on loading screen
	if (BackOut)
	{
		// if not a demo, then we go backwards from the loading screen to the level screen
		if (DemoTimer)
			StartScreen = START_LEVEL;
		// otherwise, back to the main menu
		else
			StartScreen = START_AFTER_DEMO;

		BackOut = 0;
		return(0);
	}


	if (GGame == GAME_HORSE)
	{
		extern void Horse_Reset();
		Horse_Reset();
	}

LABEL_PLAYGAME:

	// to stop X being buffered
	Pad[0].X.Pressed = 1;
	Pad[0].X.Triggered = 0;
	Pad[1].X.Pressed = 1;
	Pad[1].X.Triggered = 0;


	CloseCam = 0;
	ViewportMode = 0;				// default viewport
	if (GNumberOfPlayers == 2 && GGame != GAME_HORSE)
		ViewportMode = 1;


  	PlayAway();
	GClear1 = 0;
	GClear2 = 0;


	GHorseDoneStart = 0;				// and say again that we have not done the start text

	switch (EndCode)
	{
		case ENDCODE_TWEAKJUMP:
			printf("ENDCODE_TWEAKJUMP\n");
			// Clear everything except the triggering system.
			Init_Cleanup( SOFT_CLEANUP );

			// Reparse the trigger file.
			Trig_ParseTRGFile();

			CreateSkatersAndCameras();

			// Execute the restart node, which will set Bruce's start position and angles.
			// The tweak menus will have set the restart node.
			Trig_ExecuteRestart();

			goto LABEL_PLAYGAME;  // Play again from last checkpoint.
			break;

      default:
			printf("not .... ENDCODE_TWEAKJUMP\n");

			Init_Restart(PACK512x240,SMALL_HEAP_SIZE);    // Resets all of memory, and vram
			Db_Init();

			// Little Problem the above should not need to be called, but Skater will not be displayed in tehf ront end
			// if it is not.

			GNumberOfPlayers = 1;
			Init_Restart(PACK640x480,HIRES_SMALL_HEAP_SIZE);    // Resets all of memory, and vram
			// clears screen
			HiRes_Init();

			return(0);
         	break;
	} // end switch

DIEDIEDIE:
	#if DEBUG
	printf ("DIEDIEDIEDIEIDIOEIIIEDIIEIDI\n");
	#endif

	#if !LINKED_STARTUP
	printf("\noh shit!!!!");
	#endif

	// Should never get to this point ...	except for the demo disk
//	Init_AtEnd();

	#if LINKED_STARTUP
	printf("\nLeaving ProSkate main(), Bye!\n");
	#endif

	return (0);
} 

