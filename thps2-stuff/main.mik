FPS_Init()
{
   for (int i=0;i<FPSFRAMES;i++)
      FPS[i]=2;
   LastXblanks = Xblanks-2;	
}


FPS_Display()
{
	if (!GamePaused)
	{
	   FPS[FPSIndex] = Xblanks-LastXblanks;
	   FPSIndex++;
	   if (FPSIndex == FPSFRAMES)
	      FPSIndex=0;
	}
   LastXblanks=Xblanks;
   int Total=0;
   for (int i=0;i<FPSFRAMES;i++)
      Total+=FPS[i];
   int AverageFPS = 60 * FPSFRAMES / Total ;   // Average frames /second 


	if (Total > 5 * FPSFRAMES)
		Total = 5 * FPSFRAMES;	   // Limit logic to 5 frames (12 FPS)

	if (!GamePaused)
	{
		#if PAL
		TimeScale = 256*6/5*Total/(2*FPSFRAMES);	
		#else
		TimeScale = 256*Total/(2*FPSFRAMES);		   // shoud be 256*,  reduce this for slowmo debugging
		#endif

		if (Cheat_SlowMo)
		{
			TimeScale = TimeScale/4;
		}

/*
		if (!Cheat_PanelOn)
			TimeScale/=4;				// 1/4 speed for debuggin animations

		if (Cheat_InfiniteLives)
			TimeScale = TimeScale*3/2;		  // 150% for twitchy people
*/

		TimeScaleSquared = (TimeScale*TimeScale)>>8;	
		XFramesShifted += TimeScale*2;
		XFrames = XFramesShifted>>8;	 
	}


//#if !CD
if (Cheat_FPS)
{
	static int FPS_Pulse;

	FPS_Pulse+=10;
	FPS_Pulse &= 127;

#define FPS_X 450
#define FPS_Y 210
   static char tmp1[100];
   sprintf(tmp1," %d FPS",AverageFPS);
	if (!GameFrozen)
	{
	   if (AverageFPS >= 25)
		   Font_String(FPS_X,FPS_Y,tmp1,50,100,50,1);
	   else if (AverageFPS >= 22)
		   Font_String(FPS_X,FPS_Y,tmp1,100,100,50,1);
		else
		   Font_String(FPS_X,FPS_Y,tmp1,50+FPS_Pulse,50,50,1);
	   Font_Display();
	}
}

//#endif

#if	DEBUG
   NonRandom = 1;
#endif


#if DEBUG

#if !MICK
if (Cheat_GameInfo)
#endif
   mick_bug();

#endif

}


PlayAway_Init()
{

#	if DEBUG
   printf("\nEntering PlayAway_Init() ...\n");
#	endif

	// Added by RYAN
	// Set in-game board texture
	ASSERT(GNumberOfPlayers == 1 || GNumberOfPlayers == 2, "Wrong number of players"); 


	GClear1 = 0;
	GClear2 = 0;

	// SelectedSkater lives in rfront.cpp
	// SelectedSkater2 lives in this file
	
	// replace board textures
	char tex[2][16];
	// get proper names for in-game textures
	strcpy(tex[0], Stats[SelectedSkater].Boards[GCareer.LastDeck[0]].BoardTexture);
	strcpy(tex[1], Stats[SelectedSkater2].Boards[GCareer.LastDeck[1]].BoardTexture);
	for (int i = 0; i < 2; i++)
		tex[i][1] = '_';
	
	ReplaceTexture(Stats[SelectedSkater].BoardChecksum, tex[0]);	
	
	if (GNumberOfPlayers == 2) 
		ReplaceTexture(Stats[SelectedSkater2].BoardChecksum, tex[1]);	



	// replace wheel textures
	// get proper names for in-game textures
	char *wheels[] = 
		{"W1blue01.bmp", "W1blue02.bmp", "W1blue03.bmp", "W1blue04.bmp", 
		"W1brow01.bmp", "W1dark01.bmp", "W1gree01.bmp", "W1gree02.bmp", 
		"W1gree03.bmp", "W1oran01.bmp", "W1purp01.bmp", "W1red_01.bmp", 
		"W1red_02.bmp", "W1whit01.bmp", "W1yell01.bmp"};
	for (int i = 0; i < 2; i++)
	{
		strcpy(tex[i], wheels[GCareer.LastWheel[i]]);
		tex[i][1] = '_';
	} 
	
	ReplaceTexture(Stats[SelectedSkater].WheelChecksum, tex[0]);	
	#if RYAN
	printf("\nReplacing wheel texture for skater %d with %s", SelectedSkater, tex[0]);
	#endif

	if (GNumberOfPlayers == 2) 
	{
		ReplaceTexture(Stats[SelectedSkater2].WheelChecksum, tex[1]);	
		#if RYAN
		printf("\nReplacing wheel texture for skater %d with %s", SelectedSkater2, tex[1]);
		#endif
	}


	// replace truck texture
	for (int i = 0; i < 2; i++)
		tex[i][1] = 'T';
	
	ReplaceTexture(Stats[SelectedSkater].TruckChecksum, tex[0]);	
	#if RYAN
	printf("\nReplacing truck texture for skater %d with %s", SelectedSkater, tex[0]);
	#endif
	
	if (GNumberOfPlayers == 2) 
	{
		ReplaceTexture(Stats[SelectedSkater2].TruckChecksum, tex[1]);	
		#if RYAN
		printf("\nReplacing wheel texture for skater %d with %s", SelectedSkater2, tex[1]);
		#endif
	}


   CBruce *pMan = (CBruce *)MechList;

	GState = GSTATE_NORMAL;






// reset the viewports to correct values
// as they may have been trashed by the video replay code
	ApocalypseViewport.TanHalf  = 3413;
	LeftViewport.TanHalf        = 3413*2/3;
	RightViewport.TanHalf       = 3413*2/3;

	TopViewport.TanHalf         = 3413;	
	BottomViewport.TanHalf      = 3413;	

	TopLeftViewport.TanHalf     = 3413*2/3;
	BottomRightViewport.TanHalf = 3413*2/3;
	TopLeftBigViewport.TanHalf =  3413*2/3;	
	BottomRightBigViewport.TanHalf = 3413*2/3;	


#if DEBUGLINES 	      // draw tracer lines
	extern void Mech_InitLines(void);
	Mech_InitLines();
#endif

#if LDBUG
//   printf("Bruce_Sync\n");
#endif
//   Bruce_Sync();

	XFramesShifted = 0;
	XFrames = 0;
   Vblanks = 0;
   Xblanks = 0;
   LastXblanks = Xblanks;
   TTime = 0;
   EveryOther = 0;

   InShell = FALSE;
#if LDBUG
   printf("Pad_ClearAll\n");
#endif
   Pad_ClearAll();

   WaterEffect = FALSE;
   Warp = FALSE;

   LogicsCalled = 0;
   TargetLogics = 0;
   EndCode=ENDCODE_NONE;


#	if DEBUG
   printf("\n\nEntering game loop ...\n\n");
#	endif

#if LDBUG
   printf("Utils_InitialRand\n");
#endif
   Utils_InitialRand( RANDSEED );

extern void M3dColij_FlushCache(void);
	M3dColij_FlushCache();		  // Always need to do this 

	GTimeFont = Mess_LoadFont("time.fnt",-1,-1,0);
	GScoreFont = Mess_LoadFont("score.fnt",-1,-1,0);
	GGameFont = Mess_LoadFont("ingame1.fnt",2,2);

}


void CreateSkatersAndCameras()
{

   // JK - now passing the bruce pointer to camera constructor...
   //@@@ CCamera *pCam=new CCamera(new CBruce);
   //@@@ pCam->SetMode(CAMERAMODE_NORMAL);

 //	printf("\n***********************************Loading the skater\n");



	
   CBruce *pBruce = new CBruce;
	GSkater1 = pBruce;
	GSkater2 = NULL;
	pBruce->mIndex = 0;			
   CCamera *pCam = new CCamera(pBruce);
   pCam->SetMode(CAMERAMODE_NORMAL);

	// nows a good time to reset the TrickTip monitor
	TrickTips_Init();

 //	printf ("GVideoRestart.NumSkaters = %d\n",GVideoRestart.NumSkaters);

	if (Levels[GLevel].isCompetition && (GGame == GAME_CAREER))
	   if (GVideoRestart.NumSkaters == 0 && !GVideoReplay)
			pCam->StartCompetitionIntro();


	if (GGame != GAME_HORSE || GHorsePlayer == 0)
		pBruce->mSkaterType = SelectedSkater;	  
	else
		pBruce->mSkaterType = SelectedSkater2;
		

	pBruce->mpCamera = pCam;
	if (GNumberOfPlayers == 2 && GGame != GAME_HORSE)
	   pBruce->InitItem(Stats[pBruce->mSkaterType].PSXName2);
	else
	   pBruce->InitItem(Stats[pBruce->mSkaterType].PSXName);

	if (*Stats[pBruce->mSkaterType].Stance == 'R' ||
		*Stats[pBruce->mSkaterType].Stance == 'r')
	   pBruce->mExtraFlags |= EXTRAFLAGS_FLIPANIM;					 // flipped is actually regular, as our skaters are goofy by default.

	pBruce->mpBoardStats = &GBoardStats[0];
	pBruce->GetStats(0);

	#include	"muska.psh"
	// Frig to turn off Chad Muska's Boom box at the start of the game
	if (Stats[pBruce->mSkaterType].ComboID == COMBO_MUSKA)
	{
			pBruce->mSubObjectDisplayMask |= (1 << MUSKAPART_BOOMBOX);			// mask off
	}


	CBruce *pBruce2;

   if (GNumberOfPlayers == 2 && GGame != GAME_HORSE)
   {
      // Create a second player w/ camera
      pBruce2 = new CBruce;
		pBruce2->mIndex = 1;
      CCamera *pCam = new CCamera(pBruce2);
      pCam->SetMode(CAMERAMODE_NORMAL);


		pBruce2->mSkaterType = SelectedSkater2;
   	pBruce2->InitItem(Stats[pBruce2->mSkaterType].PSXName2);

		if (*Stats[pBruce2->mSkaterType].Stance == 'R' ||
			*Stats[pBruce2->mSkaterType].Stance == 'r')
	   	pBruce2->mExtraFlags |= EXTRAFLAGS_FLIPANIM;	 			// P2 is Bob, Regular (Left foot forward)


		// in two players, set up pointers in each player to the other player
		pBruce->mpOtherPlayer = pBruce2;
		pBruce2->mpOtherPlayer = pBruce;
		pBruce2->mpCamera = pCam;
		GSkater2 = pBruce2;

		pBruce2->mpBoardStats = &GBoardStats[1];
		pBruce2->GetStats(1);

   }


}



//#if !CD

#if !SUBMIT
DumpSquare (int x, int y, int Solid)
{
   RECT rect;
   rect.x = x-1;
   rect.y = y-1;
   rect.w = 5+2;
   rect.h = 5+2;
   ClearImage(&rect,50,0,0);
   rect.y+=256;
   ClearImage(&rect,50,0,0);

   rect.x = x;
   rect.y = y;
   rect.w = 5;
   rect.h = 5;
   ClearImage(&rect,50,50+200*Solid,50+200*Solid);
   rect.y+=256;
   ClearImage(&rect,50,50+200*Solid,50+200*Solid);
}


#define	DSX 400
#define  DSY 40
#define	DSX2 (DSX+50)
#define  DSGAP 6

DumpController()
{
	// if you don't want this, return here
	// as it's called in db.cpp


	DumpSquare(DSX,DSY-DSGAP,Pad[0].Up.Pressed || Pad[0].AnalogueMoveForwardsBackwards<-ANALOGTRICKZONE);
	DumpSquare(DSX,DSY+DSGAP,Pad[0].Down.Pressed || Pad[0].AnalogueMoveForwardsBackwards>ANALOGTRICKZONE);
	DumpSquare(DSX-DSGAP,DSY,Pad[0].Left.Pressed || Pad[0].AnalogueMoveLeftRight<-ANALOGTRICKZONE);
	DumpSquare(DSX+DSGAP,DSY,Pad[0].Right.Pressed || Pad[0].AnalogueMoveLeftRight>ANALOGTRICKZONE);

	DumpSquare(DSX2,DSY-DSGAP,Pad[0].Triangle.Pressed);
	DumpSquare(DSX2,DSY+DSGAP,Pad[0].X.Pressed);
	DumpSquare(DSX2-DSGAP,DSY,Pad[0].Square.Pressed);
	DumpSquare(DSX2+DSGAP,DSY,Pad[0].Circle.Pressed);
}
#endif

//#endif


int Profile_Bop;

#if DEBUG&&MICK
	STracer *pTracer1;
	STracer *pTracer2;
	STracer *pTracer3;
#endif

	Sprite*  pScoreSprite;
	Sprite*  pSpecialSprite; 
	Sprite*  pBarSprite;
	Sprite*  pPausedSprite; 

void PlayAway()
{
   RECORDRA;
   PlayAway_Init();

	int  Loops = 0;
	int XStart = Xblanks; 

	#if 0//MICK&DEBUG
	extern void M3dZone_InitLines(void);   // debugging dispaly lines for collision
	M3dZone_InitLines();
	#endif

	#if DEBUG&&MICK
		pTracer1 = Tracer_New(0xff0000);
		pTracer2 = Tracer_New(0x00ff00);
//		pTracer3 = Tracer_New(0x0000ff);
	#endif

   Pause(1);								// Sync us up to a vblank so first frame start at same time

	FPS_Init();

	Crowd_Init();
	Crowd_Start();

	EndCode=ENDCODE_NONE;
	ResetDemoTimer();


	// Set the global video flags for SKATE and hidden tape
	// if this is normal gameplay, then this value will be recorded and used
	// if it's a replay, then it will be overwritten and used



   #if TEST_VIDEO

	// If we need to load video data off the memory card
	// and if this is NOT a demo
	if (GVideoRestart.NumSkaters > 0 && DemoTimer)
	{

		#if DEBUG && (RYAN||MICK)
		printf("Now loading %ld-player video!\n", GVideoRestart.NumSkaters);
		printf("GV1.pBS=$%lx\n", GVInfo1.pBlockStart);
		printf("GV2.pBS=$%lx\n", GVInfo2.pBlockStart);
		#endif

		// Yes, must load video data
		Front_SetLoadAction(LOAD_VIDEO); // Signal code to load full video (not just header)
		int LoadError;

		extern int VblankUpdateBar;
		VblankUpdateBar = 1;

		if (GVideoRestart.NumSkaters == 1)
		{
			LoadError = Card_Load(THPS_VIDEO_FILE, GVInfo1.pBlockStart); // HACKY THING, SHOULD REALLY DO FULL MENU STUFF -- JUST FOR NOW
		}
		else
		{
			LoadError = Card_Load(THPS_VIDEO_FILE, GVInfo1.pBlockStart, GVInfo2.pBlockStart); // HACKY THING, SHOULD REALLY DO FULL MENU STUFF -- JUST FOR NOW
		}

		VblankUpdateBar = 0;

		if (LoadError)
		{
			Mess_SetCurrentFont("ingame1.fnt");
			HiRes_ClearOTag();
			ResetOT();

			SetClippingBox(0, 0, 512, 240+16*PAL);
			DrawColoredBox(0, 0, 512, 240+16*PAL, 0, 0, 0);
			Mess_SetTextJustify(CENTREJUSTIFY);
			Mess_SetScale(255);
			#include "frontrgb.h"
			Mess_SetRGB(MENUTEXT_PROMPT_R,MENUTEXT_PROMPT_G,MENUTEXT_PROMPT_B);
			Mess_DrawText(256, 110, GameText.pLoadFailed, 1);
			Mess_DrawText(256, 130, GameText.pPressXToContinue, 1);
			
			HiRes_DrawOTag();
			//Mess_UnloadFont();

			Pad_ClearTriggers(&Pad[0]);
			Pad_ClearTriggers(&Pad[1]);
			while(!Pad[0].X.Triggered && !Pad[1].X.Triggered &&
				!Pad[0].Start.Triggered && !Pad[1].Start.Triggered)
				Pad_Update();
			
			EndCode = ENDCODE_LOADVIDEOFAILED;
			goto SKIP_MAIN_LOOP;
		}
		else
		{
			// Loaded OK, update stuff
			SVideoHead *VH = (SVideoHead *)(GVInfo1.pBlockStart + sizeof(SCardHead)/4);

			//GVideoRestart.NumSkaters = VH->NumSkaters;
			//GVideoRestart.Skater = VH->Skater;
			//GVideoRestart.Skater2 = VH->Skater2;
			//GVideoRestart.Level = VH->Level;
			//GVideoRestart.GGame = VH->GGame;

			GVInfo1.NumFrames = VH->NumFrames;
			for (int i = 0; i < MAX_HIGHLIGHTS; i++)
				GVInfo1.Highlights[i] = VH->Highlights[i];

			if (GVideoRestart.NumSkaters == 2)
			{
				SVideoHead *VH = (SVideoHead *)(GVInfo2.pBlockStart + sizeof(SCardHead)/4);
				GVInfo2.NumFrames = VH->NumFrames;
				for (int i = 0; i < MAX_HIGHLIGHTS; i++)
					GVInfo2.Highlights[i] = VH->Highlights[i];
			}
		}

		// Hack it negative so we won't reload it again if backend replay/highlights
		GVideoRestart.NumSkaters = -GVideoRestart.NumSkaters;

		GVideoReplay = -1; // It is a full replay
	} // end if (GVideoRestart.NumSkaters > 0 && DemoTimer)

	// Added by RYAN
	// Test if we need to load video data off the CD (for demo mode)
	if (!DemoTimer)
	{

		#if DEBUG && RYAN
		printf("Now loading %ld-player video!\n", GVideoRestart.NumSkaters);
		printf("GV1.pBS=$%lx\n", GVInfo1.pBlockStart);
		printf("GV2.pBS=$%lx\n", GVInfo2.pBlockStart);
		#endif

		// Yes, must load video data
		// Front_SetLoadAction(LOAD_VIDEO); // Signal code to load full video (not just header)
		int LoadError;

		extern int VblankUpdateBar;
		VblankUpdateBar = 1;
									 
		LoadError = Card_LoadReplayFromCD(GVInfo1.pBlockStart, GVInfo2.pBlockStart, DemoName);		
		
		// cycle to name of next demo
		if (++DemoName[4] > 'J') DemoName[4] = 'A';

		VblankUpdateBar = 0;

		if (LoadError)
		{
			EndCode = ENDCODE_LOADVIDEOFAILED;
			goto SKIP_MAIN_LOOP;
		}
		else
		{
			// Loaded OK, update stuff
			SVideoHead *VH = (SVideoHead *)(GVInfo1.pBlockStart + sizeof(SCardHead)/4);

			GVideoRestart.NumSkaters = VH->NumSkaters;
			GVideoRestart.Skater = VH->Skater;
			GVideoRestart.Skater2 = VH->Skater2;
			GVideoRestart.Level = VH->Level;
			GVideoRestart.GGame = VH->GGame;

			GVInfo1.NumFrames = VH->NumFrames;
			for (int i = 0; i < MAX_HIGHLIGHTS; i++)
				GVInfo1.Highlights[i] = VH->Highlights[i];

			if (GVideoRestart.NumSkaters == 2)
			{
				SVideoHead *VH = (SVideoHead *)(GVInfo2.pBlockStart + sizeof(SCardHead)/4);
				GVInfo2.NumFrames = VH->NumFrames;
				for (int i = 0; i < MAX_HIGHLIGHTS; i++)
					GVInfo2.Highlights[i] = VH->Highlights[i];
			}
		}

		// Hack it negative so we won't reload it again if backend replay/highlights
		GVideoRestart.NumSkaters = -GVideoRestart.NumSkaters;

		GVideoReplay = -1; // It is a full replay
	}


	// If we are in career mode, then record if we have got the hidden tapes and SKATE letters
	if (!GVideoReplay)
	{
		if (GGame == GAME_CAREER)
		{
			GVideoFlags = 0;
			if (Career_Got(TAPE_HIDDEN))
			{
				GVideoFlags |= 1;
				#if MICK&&DEBUG
				printf("Saving that we have no hidden tape in the level\n");
				#endif
			}
			else
			{
				#if MICK&&DEBUG
				printf("Saving that we HAVE the hiddent tape in the level\n");
				#endif
			}

			if (Career_Got(TAPE_SKATE))
			{
				GVideoFlags |= 2;
				#if MICK&&DEBUG
				printf("Saving that we have no SKATE letters in the level\n");
				#endif
			}	
			else
			{
				#if MICK&&DEBUG
				printf("Saving that we HAVE the SKATE letters in the level\n");
				#endif
			}
		}
		else
		{
			GVideoFlags = 3;	// default to no things, for the other game types 
		}
	}
	else
	{
		GVideoFlags = ((SVideoHead *)(GVInfo1.pBlockStart + sizeof(SCardHead)/4))->VideoFlags;
		#if MICK&&DEBUG
		printf("***********************Got video Flags %d\n",GVideoFlags);
		#endif
	}

	// At this point GVideoFlags is correct, so we may want to kill any SKATE letters or hidden tapes

	if (GGame == GAME_CAREER && !Levels[GLevel].isCompetition)
	{
		if (GVideoFlags&2)
		{
			GPowS->mLifetime = 1;
			GPowK->mLifetime = 1;
			GPowA->mLifetime = 1;
			GPowT->mLifetime = 1;
			GPowE->mLifetime = 1;
			#if MICK&&DEBUG
			printf("*********************** Kiling SKATE letters %d\n");
			#endif
		}

		if (GVideoFlags&1)
		{
			GPowTape->mLifetime = 1;
			#if MICK&&DEBUG
			printf("*********************** Killing hidden tape\n");
			#endif
		}
	}
	

   // There's been a restart due to replay of video/highlights
   if (GVideoReplay)
   {
      // Replay highlight

      // This is a little bit tricky. In 2P, which player's highlight
      // shall we replay? We can't replay different highlights due to
      // how things are set up. At best we could merge the highlights
      // in some way. For now, just replay the highlights of one of
      // the players.
      CBruce *pSkater = (CBruce *)MechList;
      CBruce *pSkater2 = (CBruce *)(MechList->mNextItem);
      if (GVideoReplay > 0)
      {
         GVInfo1.ReplayHighlight = GVideoReplay;
         GVInfo2.ReplayHighlight = GVideoReplay;
         Video_Start(pSkater, VIDEO_PLAYBACK, GVInfo1.Highlights[GVideoReplay - 1].FromFrame, GVInfo1.Highlights[GVideoReplay - 1].ToFrame);
         if (pSkater2 != NULL)
            Video_Start(pSkater2, VIDEO_PLAYBACK, GVInfo1.Highlights[GVideoReplay - 1].FromFrame, GVInfo1.Highlights[GVideoReplay - 1].ToFrame);

         Video_SyncObsIfNeeded();
      }
      else
      {
         // Full replay

         GVideoReplay = 0;
         GVInfo1.ReplayHighlight = 0;
         GVInfo2.ReplayHighlight = 0;
         Video_Start(pSkater, VIDEO_PLAYBACK);
         if (pSkater2 != NULL)
            Video_Start(pSkater2, VIDEO_PLAYBACK);
      }
      //EndCode = ENDCODE_NONE;
      GState = 0;
      //Status = STATUS_NORMAL;
      Flash_Reset();
//		#if PAL
//      ((CBruce *)MechList)->mPlayTime = Xblanks + 60*60*50 + 25;
//      if (MechList->mNextItem != NULL)
//	      ((CBruce *)(MechList->mNextItem))->mPlayTime = Xblanks + 60*60*50 + 25;
//		#else
      ((CBruce *)MechList)->mPlayTime = Xblanks + 60*60*60 + 30;
      if (MechList->mNextItem != NULL)
	      ((CBruce *)(MechList->mNextItem))->mPlayTime = Xblanks + 60*60*60 + 30;
//		#endif
   }
   else
   {
      // Just a normal start. Start recording if time to do so

      Video_Cleanup();

      CBruce *pSkater = (CBruce *)MechList;
      CBruce *pSkater2 = (CBruce *)(MechList->mNextItem);

      if (GVInfo1.VideoMode == VIDEO_OFF)
      {
			// dont start recording until we're out of an competition
			// intro stuff.
			if(!((CCamera*)CameraList)->InCompetitionIntro())
			{
		      Video_Start(pSkater, VIDEO_RECORD);
	         if (pSkater2 != NULL)
	            Video_Start(pSkater2, VIDEO_RECORD);
				// make sure the GVideo flags are saved
				((SVideoHead *)(GVInfo1.pBlockStart + sizeof(SCardHead)/4))->VideoFlags = GVideoFlags;
			}
      }
   }
   #endif


      #if 0 && DEBUG && CHRISTER // Start SN profiler when game starts
      StartSNProfiler();
      #endif

	Loops = 0;
	XStart = Xblanks; 

	// If there is just one player, then disable the second pad
	#if CD
	if (GNumberOfPlayers == 1)
			PadEnableCom(1);
	#endif


	// pretend we have some velocity
	GSkater1->mVel.vx = GSkater1->mFront.vx*20;
	GSkater1->mVel.vy = GSkater1->mFront.vy*20;
	GSkater1->mVel.vz = GSkater1->mFront.vz*20;
	// Let camera find it's way.
	for (int i=0;i<10;i++)
	{
   	Ob_AI(&CameraList);
	}
	GSkater1->mVel.vx=0;
	GSkater1->mVel.vy=0;
	GSkater1->mVel.vz=0;


	GameFade = 0;			// stop fading, just in case we still are. (unlikely)

   ////////////////////////////////////////////////////////////////////
   // ********************************************   START OF MAIN LOOP
   while( !EndCode )
   {
		#if DEBUG&&MICK
		if (!GamePaused)
			Tracers_Advance();
		#endif



		#if DEBUG
		if (Loops>=0)
		{
			Loops++;
			if (Xblanks-XStart > 60*10)
			{
				//printf("BENCHMARK! \n%d Frames in 10 Seconds\n",Loops);
				Loops = -1;
			}
		}
		#endif

		// trigger the profiler, so it always starts at the start of the main loop
		#if !CD
		Profile_Bop = (0x80010000);
		#endif
      int StartTime = Vblanks;

      //#		if DEBUG
      //		ProfileStartCount();
      //#		endif
      PollHost();


		// If both skaters are on the ground, then
		// we can check for the end of game, 
		// thusly decrementing the counter
		if (GSkater1->mPhysicsState == PHYSICS_ON_GROUND && (!GSkater2 || GSkater2->mPhysicsState == PHYSICS_ON_GROUND))
		{
			if (GState == GSTATE_STOP && --GSpin <= 0 	 )	
			{
				// Stop spinning, and end game, unless still counting down points, and it's not the Horse game.
				if (GGame!=GAME_HORSE&&(GSkater1->mPanelData.mLandedTotal || GNumberOfPlayers==2 && GSkater1->mPanelData.mLandedTotal))
				{
					// if counting down points, then don't spin (set spin speed to 0), but keep in this state
					GSpinSpeed = 0;
					GSpin = 1;
				}
				else
				{ 

					// should switch off ALL the SFX here
			      // Stop continuous sounds

			      if (GSkater1->mSFXGrind != 0)
			      {
			         SFX_Stop(GSkater1->mSFXWallride);
			         GSkater1->mSFXGrind = 0;
			      }

			      if (GSkater1->mSFXGrind != 0)
			      {
			         SFX_Stop(GSkater1->mSFXGrind);
			         GSkater1->mSFXGrind = 0;
			      }

			      if (GSkater1->mSFXGround != 0)
			      {
			         SFX_Stop(GSkater1->mSFXGround);
			         GSkater1->mSFXGround = 0;
			      }

			      if (GSkater2 && GSkater2->mSFXGrind != 0)
			      {
			         SFX_Stop(GSkater2->mSFXGrind);
			         GSkater2->mSFXGrind = 0;
			      }

			      if (GSkater2 && GSkater2->mSFXGround != 0)
			      {
			         SFX_Stop(GSkater2->mSFXGround);
			         GSkater2->mSFXGround = 0;
			      }
					
					GState = 0;

					// we're in a competition when we're in "career" mode AND a "competition" level
					if (Levels[GLevel].isCompetition && (GGame == GAME_CAREER))
						Front_SwitchOnEndHeat();
					else
				      Front_SwitchOnEndLevelMenu();

				}
		   }
		}

      // Start the profiling here, so PollHost does not mess stuff up
#		if DEBUG
      ProfileStartCount();
#		endif

		Crowd_Update();

#		if DEBUG
      Debug_InitPolyCounter();
#		endif

      CalcPolyBufferEnd();

#		if DEBUG
      ProfileReadCount(100,100,44);
#		endif

 #if !SUBMIT

 extern DumpController();
	if (Cheat_GameInfo)
		 DumpController();
#endif


		SControl TempPad;

		if (GGame == GAME_HORSE && GHorsePlayer == 1)
		{
			TempPad = Pad[0];
			Pad[0] = Pad[1];
			Pad[1] = TempPad;
		}

		Pad_Restore();
		Pad_Update();
		Pad_Remap();



		if (GGame == GAME_HORSE && GHorsePlayer == 1)
		{
			TempPad = Pad[0];
			Pad[0] = Pad[1];
			Pad[1] = TempPad;
		}

		// funky clearing of the pad for the player that did not pause
		if (GClear1) Pad_ClearAllOne(0);
		if (GClear2) Pad_ClearAllOne(1);

		Video_HandleStepping(); // Must be called after pad update



		#if DEMODISK
		if (ExitDemo())
		{
			Db_WaitRender();
			DrawSync(0);
			Db_Init();			// now reset the db stuff, which will also clear the screen 
			return;
		}
		#endif						  

		// if in stop state, and on the ground, then clear the pad, and hold "down" to brake
		if (GState == GSTATE_STOP && !GamePaused)
		{
			if (GSkater1->mPhysicsState == PHYSICS_ON_GROUND)
			{
				// don't clear the circle button, as it is used to determin if you bail then the game ends and you are grabbing
				int t = Pad[0].Circle.Pressed;
				Pad_ClearAllOne(0);
				Pad[0].Circle.Pressed = t;
				Pad[0].Down.Pressed = 1;
			}
			if (GNumberOfPlayers == 2)	  // only do second pad if two players
			{
				if (GSkater2->mPhysicsState == PHYSICS_ON_GROUND)
				{
					// don't clear the circle button, as it is used to determin if you bail then the game ends and you are grabbing
					int t = Pad[1].Circle.Pressed;
					Pad_ClearAllOne(1);
					Pad[1].Circle.Pressed = t;
					Pad[1].Down.Pressed = 1;
				}
			}
		}

		// if it is a one player game, then clear the player 2 pad, so it can't pause or stuff
		#if (!DEBUG)
		if ((GNumberOfPlayers == 1  || ((GGame == GAME_HORSE && GHorseClearInput2)))  && !Cheat_ScreenShots)
			Pad_ClearAllOne(1);		
		#endif

//			PadEnableCom(0);
      // Do two logics. Every other Logic returns without doing anything.
      Logic();
      if( EndCode ) break;
      Logic();
      if( EndCode ) break;



//		Pause(3);

#		if DEBUG
      ProfileReadCount(100,100,100);	    // White = end of Logic
#		endif
#if ASYNC
		Db_WaitRender();
#endif	
#		if DEBUG
      ProfileReadCount(0,0,0);				// BLACK = waiting for rendering to finish
#		endif

		
//		if (Pad[0].Square.Pressed)
//			PadEnableCom(0);

      FPS_Display();
      Display();

//		if (Pad[0].Square.Pressed)
//			PadEnableCom(3);


		if (!GameFrozen && Cheat_FPS)
	      Panel_DrawFlatShadedPoly(FPS_X-2,FPS_Y-2,54,18,0,0,0);

#if !CD
#if DEBUG
		#if !MICK
	if (Cheat_GameInfo)
		#endif
		if (MickY > 20)
	      Panel_DrawFlatShadedPoly(18,20-2,150-16,(MickY)+3,0,0,0);
#endif

#endif

		// added by RYAN
		// if this is demo mode, display the word "demo"
		if (!DemoTimer)
		{
			Front_PrintDemo();
		}
		
//		printf("%d\n",GModelVideoDisplayed);

		// in one player we downloaddata if video is on screen
		if (Levels[GLevel].FMV && (GNumberOfPlayers == 1 || GGame == GAME_HORSE))	
      	GameFMV_SyncFMV(GModelVideoDisplayed);
		else		// in two player we never display video
      	GameFMV_SyncFMV(0);
		
		GModelVideoDisplayed = 0;

#		if DEBUG
      ProfileReadCount(64,64,64);	// For CPU time bar
      ProfileAddOT(0,0,0);				// Adds CPU bar to screen
      ProfileAddMemoryOT();			// Adds Memory map to screen
      ProfileAddHeapIndicator(0);		// Draw heap 0 indicator
      ProfileAddHeapIndicator(1);		// Draw heap 1 indicator
#		endif



      if( Vblanks == StartTime )
      {
         // If < 1 frame has elapsed, then pause, with call to SSSeqCalledTByT.
         Pause(1);
      }

#if !ASYNC

      DoVblankProcessing = FALSE;
      Pause(1);

      while( DrawSync(1) )
      {
         Utils_VblankProcessing();
         Pause(1);  				  // As DrawSync did something, we need to do a Pause again.
      }

#endif

      // Try to get more accurate GPU indicator.
#		if DEBUG
      ProfileAddDrawOT();             // Adds GPU bar to screen
#		endif

      // Stuff that needs to be called AS CLOSE TO VBLANK AS POSSIBLE.
      ASSERT(((int)(pPoly)&0x7fffffff)<=((int)(PolyBufferEnd)&0x7fffffff),"Undetected Poly Buffer Overflow");

#if !ASYNC
      Db_DisplayDraw();
#else
		Db_Render();					// Note, this does not wait for a vblank
#endif

      if( Vblanks == StartTime + 1 )			// if running better than 30 fps, then slow down
      {
         // If < 2 frame has elapsed, then pause
         Pause(1);
      }



		// randomly restart, to test for memory leaks and stuff
//		if (!Rnd(500))
//			EndCode=ENDCODE_TWEAKJUMP;


	// for horse, we want to swithc on the menu that is displayed at the start
	  if (GGame == GAME_HORSE)
	  {
		  if (!GHorseWordChosen) {
			  GHorseDoneStart = 1;	// make sure we don't fall through right away
			  GHorseWordChosen = 1;
			  Front_PrintHorseLetters();
		  } else if (!GHorseDoneStart) {
			  GHorseDoneStart = 1;
			  Front_SwitchOnStartLevelMenu();
		  }
	  } 


      // If Bruce has died, break out of the loop.
      if (MechList->IsDead()) EndCode=ENDCODE_BRUCEDIED;

   } // while( !EndCode )
   // ********************************************   END OF MAIN LOOP
   //////////////////////////////////////////////////////////////////


SKIP_MAIN_LOOP:


	// enable both pads when we exit
	PadEnableCom(3);



   // Wait for any CD loading to finish.
   Spool_Sync();
   // Reset pushback flag.
   M3d_OTPushback = 1;

   // Save state for continue.
//   Front_SaveGameState();

// Reset the double buffer, so Triple buffering works next time around

	// There may be some stuff rendering, so wait for it
	Db_WaitRender();
	DrawSync(0);
	Db_Init();			// now reset the db stuff, which will also clear the screen 

#	if DEBUG
   printf("\n\nLeft main loop with end code = ");
   switch (EndCode)
   {
   case ENDCODE_BRUCEDIED:
      printf("ENDCODE_BRUCEDIED\n");
      break;
   case ENDCODE_E3TIMEOUT:
      printf("ENDCODE_E3TIMEOUT\n");
      break;
   case ENDCODE_ENDLEVELDOSAVE:
      printf("ENDCODE_ENDLEVELDOSAVE\n");
      break;
   case ENDCODE_ENDLEVELNOSAVE:
      printf("ENDCODE_ENDLEVELNOSAVE\n");
      break;
   case ENDCODE_PLAYERQUIT:
      printf("ENDCODE_PLAYERQUIT\n");
      break;
   case ENDCODE_DEMOINTERRUPTED:
      printf("ENDCODE_DEMOINTERRUPTED\n");
      break;
   case ENDCODE_DEMOENDED:
      printf("ENDCODE_DEMOENDED\n");
      break;
   case ENDCODE_TWEAKJUMP:
      printf("ENDCODE_TWEAKJUMP\n");
      break;
   case ENDCODE_LOADVIDEOFAILED:
      printf("ENDCODE_LOADVIDEOFAILED\n");
      break;
   default:
      printf("Unknown\n");
      break;
   }
   printf("\n\nLogic: %d\n", LogicsCalled );
#	endif
	Crowd_Stop();

	#if DEBUG&&MICK
		Tracers_Delete();
	#endif

	Mess_SetCurrentFont(GScoreFont);
	Mess_UnloadFont();
	Mess_SetCurrentFont(GTimeFont);
	Mess_UnloadFont();
	Mess_SetCurrentFont(GGameFont);
	Mess_UnloadFont();

	// back to LaunchGame()
	// after that, back to FrontEnd_Main()
}



int DemoDiskMode=0;           // Demo mode
int DemoSize;

// a mockup of what the task manager/single main loop might end up as


class CTask
{
	virtual void Init();
	virtual void Logic();
	virtual void Display();
	virtual void End();
};

class CTaskManager
{
	void MainLoop();	
}

CTaskManager GlobalTaskManager;

CTask *pGlobalTasks;

CTaskManager :: MainLoop()
{

	CTask * pTask;

	while(1)
	{
// Do common logic routines, reading the pad, etc

// Do all the logic Routines
		pTask = mpGlobalTasks;
		while (pTasks)
		{
			pTask->Logic();
		}
// Do all the Display routines
		pTask = mpGlobalTasks;
		while (pGlobalTasks)
		{
			pTask->Display();
		}

	}
}



#if LINKED_STARTUP            // If we have linked startup.obj


int main(int argc, int* argv) // launcher will pass argc, argv to you.
// argv is actually an array of integers.
{
   // The init code from the sample
   // Note some of these things are duplicated later
   // and possibility that PadInit() twice might fuck things up?
   ResetCallback();
   CdInit();

   PadInit(0);
   ResetGraph(0);
   SetGraphDebug(0);
   SetDispMask(1);

   // Now our code starts here


   RECORDRA;
   int FirstDATrack;   // First DA track
   int SectorOffset;   // Location of application directory

   DemoDiskMode   = argv[0];
   Timeout        = argv[1];
   FirstDATrack   = argv[2];
   SectorOffset   = argv[3];

   printf("\n--------------- Sampler parameters ---------------\n");
   printf("\nMode = %d",DemoDiskMode);
   printf("\nTimeout = %d",Timeout);
   printf("\nFirst DA Track = %d",FirstDATrack);
   printf("\nSector Offset = %d\n",SectorOffset);

	DemoDiskMode = 0;					// let it be zero, as we ahve no self running demo right now

#else



main()
{

	Options_Init();
	Career_Init();
	Init_AtStart(!DEMODISK);
   Init_Restart(PACK512x240,SMALL_HEAP_SIZE);    // Resets all of memory, and vram
	Db_Init();
	FrontEnd2_Main();

}






   int Oldmain() // Plain old main instead.
   // PSX doesn't like argc, argv on its own
   {

#if DEMODISK
