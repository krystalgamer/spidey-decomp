//#if TWEAK
//   if (!TweakMode)
//#endif
      M3d_Render(EnvironmentalObjectList);
//   SCACHE_OFF;
#if DEBUG
   ProfileReadCount(120,0,0);				   // brighter red = enviro objects (usualy very little)
#endif

//   SCACHE_ON;
	GSkater1->TempTransform();
	if (GSkater2)
		GSkater2->TempTransform();


	// store the pushback values
	int t1 = M3d_OTPushback;
	int t2 = M3d_OTPushback2;

	// set them to zero from now.  Ideally they world be set on a player basis
	// depending on the angle of the face normal of the bottom of the board
	// for now we simple clear them, so bob's wheels will magically re-appear

	// if Skater1 is not on the ground, and not in a bail, then we set the pushback flags
	// specifically to push bach the soles of their feet
	// so they don't sort so bad with the board
	// noting else should be flagged as pushback  
	if (GSkater1->mPhysicsState != PHYSICS_ON_GROUND && !GSkater1->mInBail)
	{
	   M3d_OTPushback  = 128;
	   M3d_OTPushback2 = 128;
	}
	else
	{
	   M3d_OTPushback  = 0;
	   M3d_OTPushback2 = 0;
	}


   M3d_Render( MechList );


	GSkater1->TempRestore();
	if (GSkater2)
		GSkater2->TempRestore();

	M3d_OTPushback = t1;
	M3d_OTPushback2 = t2;


   Bit_Display();

   /*
   	if (ViewportMode)
   	{
   		MechList->mPos.vx += 256<<FRACBITS;
   		M3d_Render( MechList );
   		MechList->mPos.vx -= 256<<FRACBITS;
   	}
   */
//   SCACHE_OFF;

#if DEBUG
   ProfileReadCount(255,255,0);
#endif

//   SCACHE_ON;
//#if TWEAK
//   if (!TweakMode)
//   {
//#endif
      M3d_Render(BaddyList);

#if DEBUG
      ProfileReadCount(50,50,150);
#endif


      M3d_Render(PowerUpList);
//#if TWEAK
//   }
//#endif


//   SCACHE_OFF;


   if (ViewportMode == 0)
      M3d_RenderBackground(BackgroundList);


#if DEBUG
   ProfileReadCount(0,0,0x40);
#endif

   M3d_RenderCleanup();




}



// Middle patch will (eventually) patch the join in the 
// middle of the screen so the overalpping screens get equal areas.
// props & greetz to Christer for the idea, but letting me do the hard work

#define OVERLAP 64

int 	PatchX = 16;
int	PatchY = 150;



// Hmm, this makes my head hurt.
// The idea is to insert primitives into the OT
// so that after the bottom right buffer has finished drawing
// we copy out the overlapping rectangle to some area of VRAM
// and then after the top left rectangle has finished, 
// we re-draw a triangle, so both buffers are the same size.
// complications include calculations of TPages 
Middle_Patch()
{
		#if 0
		RECT Window;

		// Add a regular DR_AREA primitive first.
      // this will be the off screen buffer
		DR_AREA *p_clip;
/*
		Window.x	= 0;
		Window.y	= 0 + pDoubleBuffer->Draw.clip.y;
		Window.w	= 512;
		Window.h	= 240;    // <<<<< temp, fix up later for PAL

		p_clip =	(DR_AREA	*)pPoly;
		SetDrawArea( p_clip, &Window );
		pPoly	= (Uint32 *)( p_clip + 1 );
		addPrim( pDoubleBuffer->OrderingTable + OTSIZE - 1, p_clip );
*/
		int MidX = SCREENWIDTH/2;  // middle of the screen
		int MidY = SCREENHEIGHT/2; 

		// Add two polys to the back of the first OT.
		for (int i=0;i<2;i++)
		{
			POLY_FT4 * p_poly = (POLY_FT4 *)pPoly;
			pPoly	= (Uint32 *)( p_poly + 1 );
			setPolyFT4( p_poly );

			int SourceX = (MidX + (OVERLAPX/2)*(i-1));		// left side of source rectangle
			int SourceY = (MidY - OVERLAPY/2);
			int TpageX = SourceX&~0x3f;					// tpage for this
			SourceX = SourceX - TpageX;					// convert to offset in tpage		

			setUV4( p_poly, SourceX, SourceY,
								 SourceX + OVERLAPX, SourceY,
								 SourceX, SourceY+OVERLAPY,
								 SourceX+OVERLAPX, SourceY+OVERLAPY );


			setXY4( p_poly, PatchX, PatchY,
								 PatchX + OVERLAPX, PatchY,
								 PatchX, PatchY+OVERLAPY,
								 PatchX+OVERLAPX, PatchY+OVERLAPY);

			setRGB0( p_poly, 0x80, 0x80, 0x80 );
			if( pDoubleBuffer == &DoubleBuffer[0] )				// need to get the same TPage as buffer we are drawing to
				setTPage( p_poly, 2, 0, TpageX, 0 );
			else
				setTPage( p_poly, 2, 0, TpageX, 256 );
			addPrim( pDoubleBuffer->OrderingTable + OTSIZE - 1, p_poly );

			// Add a DR_AREA primitive which allows us to draw offscreen.
			Window.x	= 0;
			Window.y	= 0;
			Window.w	= SCREENWIDTH;
			Window.h	= SCREENHEIGHT;

			p_clip =	(DR_AREA	*)pPoly;
			SetDrawArea( p_clip, &Window );
			pPoly	= (Uint32 *)( p_clip + 1 );
			addPrim( pDoubleBuffer->OrderingTable + OTSIZE - 1, p_clip );


		}


// Now add the appropiate triangle to copy it back after drawing the other buffer
// it's the last things done, so goes at the head of the OT
		POLY_FT3 * p_poly = (POLY_FT3 *)pPoly;
		pPoly	= (Uint32 *)( p_poly + 1 );
		setPolyFT3( p_poly );

		int DestX = (MidX - OVERLAPX/2);		// left side of source rectangle
		int DestY = (MidY - OVERLAPY/2);

		int TpageX = PatchX&~0x3f;					// tpage for patch
		int PatchU = PatchX - TpageX;				// convert to offset in tpage		

		setUV3( p_poly, PatchU + OVERLAPX, PatchY,
							 PatchU + OVERLAPX, PatchY+OVERLAPY,
							 PatchU, PatchY+OVERLAP);


		setXY3( p_poly, DestX + OVERLAPX, DestY,
							 DestX + OVERLAPX, DestY+OVERLAPY,
							 DestX, DestY+OVERLAPY);

		setRGB0( p_poly, 0x80, 0x80, 0x80 );
		setTPage( p_poly, 2, 0, TpageX, 0 );
		addPrim( pDoubleBuffer->OrderingTable, p_poly );

		// Add a DR_AREA primitive which allows us to draw onscreen
		Window.x	= 0;
		Window.y	= 0 + pOtherBuffer->Draw.clip.y;
		Window.w	= 512;
		Window.h	= 256;

		p_clip =	(DR_AREA	*)pPoly;
		SetDrawArea( p_clip, &Window );
		pPoly	= (Uint32 *)( p_clip + 1 );
		addPrim( pDoubleBuffer->OrderingTable + OTSIZE - 1, p_clip );


/*			
		// Add one more (flat black) poly to the back of the OT (this fixes problem with transparent source pixel copy).
		POLY_F4 * p_poly = (POLY_F4 *)pPoly;
		pPoly	= (Uint32 *)( p_poly + 1 );
		setPolyF4( p_poly );
		setXY4( p_poly, GameFMV_StartX, GameFMV_StartY,
							 GameFMV_StartX + GameFMV_Width - 1, GameFMV_StartY,
							 GameFMV_StartX, GameFMV_StartY + GameFMV_Height - 1,
							 GameFMV_StartX + GameFMV_Width - 1, GameFMV_StartY + GameFMV_Height - 1 );
		setRGB0( p_poly, 0x00, 0x00, 0x00 );
		addPrim( pDoubleBuffer->OrderingTable + OTSIZE - 1, p_poly );
*/

		#endif
}

void Draw_Rect(int X0,int Y0,int X1,int Y1,int X2,int Y2,int X3,int Y3, int c)
{
        register POLY_F4 *pF4 = (POLY_F4 *)pPoly;

			Uint8 *newppoly=(Uint8*)(pF4+1);

        *((long *)&pF4->r0) = c;  // code/b0/g0/r0
        pF4->x0 = X0;
        pF4->y0 = Y0;
        pF4->x1 = X1+1;
        pF4->y1 = Y1;
        pF4->x3 = X2+1;
        pF4->y3 = Y2+1;
        pF4->x2 = X3;
        pF4->y2 = Y3+1;
        SetPolyF4((void *)pPoly);
        addPrim(pDoubleBuffer->OrderingTable, pPoly);
   	  pPoly=(Uint32*)newppoly;

}

void BlackOut(int x, int y, int w, int h)
{
//	printf ("Balckout (%d,%d,%d,%d)\n",x,y,w,h);
	Draw_Rect(x,y,x+w,y,x+w,y+h,x,y+h,0x40000000);
}


void Display()
{
   RECORDRA;


   if (pAutoTestRestartName)
   {
      Mess_SetRGB(255,0,0);
      Mess_SetScale(256);
      Mess_SetTextJustify(CENTREJUSTIFY);
      Mess_DrawText(256,60,pAutoTestRestartName);
   }

// Dont think this does anything any more
   ApocalypseViewport.Zoom = ((CCamera*)CameraList)->GetZoom();

//   Proctex_MoveProceduralTexture();


#if DEBUG
   ProfileReadCount(255,0,0);
#endif

	if (!GameFrozen || Cheat_ScreenShots)
   Ob_AI(&CameraList); // Note that this is here rather than in Logic()!

#if DEBUG
   ProfileReadCount(0,0,0);
#endif


	if (!Cheat_ScreenShots)
	{
		static int Released = 1;
		if (Pad[0].Select.Pressed)
		{
			if (Released)
			{
				Released = 0;
			   if (GNumberOfPlayers == 2 && GGame != GAME_HORSE)
				{
			      ViewportMode += 1;
			      if (ViewportMode > MAX_VIEWPORT_MODE)
			         ViewportMode = 0;
				}
				else
				{
					CloseCam^=1;
				}
			}

		}
		else
			Released = 1;

	   if (Pad[1].Select.Triggered)
	   {
	      Pad[1].Select.Triggered = 0;
	      ViewportMode += 1;
	      if (ViewportMode > MAX_VIEWPORT_MODE)
	         ViewportMode = 0;
	   }
	}
   // Skip viewport 0 for two players
   if (GNumberOfPlayers == 2 && ViewportMode == 0  && GGame != GAME_HORSE)
      ViewportMode = 1;

extern int camDist;
extern int camPitch;
extern int camYOffset;

	#if DEBUG&&MICKMAP
	if (Mick_MapMode)
	{
		// x,y is you
		int x = GSkater1->mPos.vx>>FRACBITS;
		int y = GSkater1->mPos.vz>>FRACBITS;

		// x1,y1 is camera
		int x1 = GSkater1->mpCamera->mPos.vx>>FRACBITS;
		int y1 = GSkater1->mpCamera->mPos.vz>>FRACBITS;
		Mick_Line(x-250,y,x+250,y,0x00ff);	// red cross = you
		Mick_Line(x,y-250,x,y+250,0x00ff);
		Mick_Line(x1-150,y1,x1+150,y1,0x00ff00);  // smaller green cross = camera
		Mick_Line(x1,y1-150,x1,y1+150,0x00ff00);
		Mick_Line(x1,y1,x1+(x-x1)*10,y1+(y-y1)*10,0xffffff);   // Wite line = Direction of camera

	}
	#endif



   switch (ViewportMode)
   {
   case	0:

// this setting it directly may stop us from tweaking the camera
// maybe should not do it if game is fozen

		if (!GameFrozen)
		{
			if (CloseCam)
			{
				camDist = 386;
				camPitch	= 30;			// was 75
				camYOffset = -160;   // was 140
			}
			else
			{
				camDist = 290;
				camPitch	= 150;
				camYOffset = -108;
			}
		}

      Display_Viewport(&ApocalypseViewport,0);
      break;
   case 1:
		if (!GameFrozen)
		{
			camDist = 286;
			camPitch	= 118;
			camYOffset = -140;
		}
		BlackOut(SCREENWIDTH/2-2,0,4,SCREENHEIGHT);
      Display_Viewport(&LeftViewport,0);
      Display_Viewport(&RightViewport,1);
      break;
   case 2:
		if (!GameFrozen)
		{
			camDist = 450;
			camPitch	= 60;  // 4022
			camYOffset = -120;		//204;
		}
		BlackOut(0,(SCREENHEIGHT/2-2),SCREENWIDTH,4);
      Display_Viewport(&TopViewport,0);
      Display_Viewport(&BottomViewport,1);
      break;
   case 3:
		if (!GameFrozen)
		{
			camDist = 642;
			camPitch	= 32;
			camYOffset = -172;
		}
		BlackOut(SCREENWIDTH/2,0,SCREENWIDTH/2,SCREENHEIGHT/2);
		BlackOut(0,SCREENHEIGHT/2,SCREENWIDTH/2,SCREENHEIGHT/2);
      Display_Viewport(&TopLeftViewport,0);
      Display_Viewport(&BottomRightViewport,1);
      break;
   case 4:

		if (!GameFrozen)
		{
			camDist = 610;
			camPitch	= 0;
			camYOffset = -200;
		}
		BlackOut(SCREENWIDTH/2+OVERLAPX/2,0,SCREENWIDTH/2-OVERLAPX/2,SCREENHEIGHT/2-OVERLAPY/2);
		BlackOut(0,SCREENHEIGHT/2+OVERLAPY/2,SCREENWIDTH/2-OVERLAPX/2,SCREENHEIGHT/2-OVERLAPY/2);
      Display_Viewport(&TopLeftBigViewport,0);
      Display_Viewport(&BottomRightBigViewport,1);
//		Middle_Patch();
      break;

   }


	#if DEBUG
//	if (Mick_MapMode)
//		Mick_Darken();
	#endif



#if DEBUG
   if (Cheat_GameInfo)
      PrimitiveCount = CountPrimitives();
#endif


	#if 0&&DEBUG&&MICK
	if (Pad[0].Triangle.Pressed)
		ShrinkPrimitives();
	#endif


#	if DEBUG
   if( T[DUMPVRAM] )
   {
      VRAMDump();
   }
#	endif

#if DEBUG
   ProfileReadCount(0,80,0);
#endif

//      Bit_Display();

#if DEBUG
   ProfileReadCount(100,100,100);
#endif

   //   Post_PostProcessEffects();

#	if DEBUG
   if( T[PROFILERMODE] == OTPROFILE ) Debug_CheckOTDistribution();
#	endif






   Font_Display();

#if DDBUG
   printf("D16\n");
#endif

#if JK
   CCamera::TweakDisplay();	// JK - uh oh! C++!
#endif


   Panel_Display();

	#if DEBUG&&MICK
	Tracers_Display();
	#endif


//#if TWEAK
//   if (!TweakMode)
//#endif
//   {
      Front_Display();
//   }

   Mess_Display();


	// Draw a large semitrans poly over full screen to darken screen down
	// the position of this is important, as it uses the panel OT, it must
	// be the last thing draw in the panel OT, so it is then rendered first and does not obscure any panel.
	extern EPausedStatus Status;
	if (GamePaused && /*Status != STATUS_PAUSEDMENU &&*/ Status != STATUS_STARTHORSE)
	{
//		POLY_F4 *pF4 = Panel_DrawFlatShadedPoly(0,0,512,240, 64,64,64, 0);
//		SetSemiTrans(pF4, 1);
//		pF4->code |= 2;
		extern void Mick_Darken();
		Mick_Darken();

	}
	else
	{
		extern int Mick_Darkness;
		Mick_Darkness = 0;
	}


#if DEBUG
   ProfileAddPolyBuffIndicator();  // Adds Poly buffer indicator
   Debug_DisplayTestBit();
#endif

//#if TWEAK
//   Tweak_Display();
//   TextWin_Display();
//#endif

   // Done last so that the panel appears on top of it even if they're in the same OT slot.
   Flash_Display();

   PolyBufferBytesUsed=((Uint32)pPoly&0x7fffffff)-(((Uint32)pDoubleBuffer->Polys)&0x7fffffff);

#if DEBUG
//   if (Cheat_GameInfo)
//      PrimitiveCount = CountPrimitives();
#endif

   //   Post_DoFade();
   //   Utils_FadeTrails();


#if DEBUG
   ProfileReadCount(0,0,0);
#endif
}

