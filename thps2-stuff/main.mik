void DumpAutoTest()
{


   DISPENV DispEnv;
   DRAWENV DrawEnv;
	char Temp[200];

//   ResetGraph(0);
   SetDispMask(1);
   SetGraphDebug(0);
   FntLoad(0, 0);
   int n = FntOpen(200, 175, 160, 16, 1, 1024);
   DrawSync(0);

   SetDefDrawEnv(&DrawEnv, 0, 0, 512, SCREENHEIGHT);
   PutDrawEnv(&DrawEnv);

	sprintf(Temp,"L-%d, P1-%d, P2-%d, G-%d", GAutoLevela, GAutoPlayer1a, GAutoPlayer2a, GAutoGamea);
   FntPrint(Temp);
   FntFlush(n);

	GAutoLevela = GAutoLevel;
	GAutoPlayer1a = GAutoPlayer1;
	GAutoPlayer2a = GAutoPlayer2;
	GAutoGamea = GAutoGame;

}


