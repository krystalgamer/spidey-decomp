void* CClass::operator new(size_t size)
{
   RECORDRA;

   void *pnew=Mem_New(size);

   // Ensure size is a multiple of 4.
   size = ( size + 3 ) & ~0x03;

   // Zero all the newly allocated memory
   Uint32 *p=(Uint32 *)pnew;
   for (int i=0; i<size/4; ++i) *p++=0;

   return pnew;
}

void CClass::operator delete(void* p)
{
   RECORDRA;
   Mem_Delete(p);
}


void CalcPolyBufferEnd(void)
{
   // Calculate the end of the poly buffer
   // less a 256 byte buffer, just in case.
   PolyBufferEnd=((Uint8*)pDoubleBuffer->Polys)+(POLYBUFFERSIZE+MICKMAP*500000)-256;
   PolyBufferEnd=(Uint8*)((Uint32)PolyBufferEnd&0x7fffffff);
}

