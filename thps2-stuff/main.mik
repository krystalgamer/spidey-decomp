void Game_Over()
{

	#if MICK&&DEBUG
	printf("Game Over, Dude!\n");
	#endif



	if (GGame == GAME_GRAFFITI)
	{
		if (GSkater2->mTags == GSkater1->mTags)
		{
			// It's a tie!
		} 
		else
		{
			// Someone has won, so find out who
			if (GSkater2->mTags > GSkater1->mTags)
			{
				GWins2++;
				GLosses1++;
				if (GStreak2<0)
					GStreak2 = 1;
				else
					GStreak2++;
				GStreak1 = -GStreak2;	
			}
			else
			{
				GWins1++;
				GLosses2++;
				if (GStreak1<0)
					GStreak1 = 1;
				else
					GStreak1++;
				GStreak2 = -GStreak1;	
			}
			if (GSkater1->mTags > GHighTags1)
				GHighTags1 = GSkater1->mTags;
			if (GSkater2->mTags > GHighTags2)
				GHighTags2 = GSkater2->mTags;
		}												
	}

	if (GState == GSTATE_NORMAL)
	{
		GState = GSTATE_STOP;
		GSpin = 80;
		GSpinSpeed = 64;
//		Crowd_Cheer(500);


		if (GSkater2)
		{
			GSkater2->mLeanAngle = 0;   // huh?
		}
	}
}


#if MICKMAP

int MapX=256;
int MapY=120;
int MapScale=256;

void Mick_Line(int x0, int y0, int x1, int y1, int Color)
{
	RECORDRA;

	x0-=(GSkater1->mPos.vx>>FRACBITS);
	x1-=(GSkater1->mPos.vx>>FRACBITS);
	y0-=(GSkater1->mPos.vz>>FRACBITS);
	y1-=(GSkater1->mPos.vz>>FRACBITS);


	x0*=MapScale;
	x1*=MapScale;
	y0*=MapScale;
	y1*=MapScale;

	x0/=62*256;
	x1/=62*256;
	y0/=-100*256;
	y1/=-100*256;

	// ignore points
	if (x0==x1 && y0==y1)
		return;

	x0+=MapX;
	x1+=MapX;
	y0+=MapY;
	y1+=MapY;

	// Clipping
	int t;   // temp var for swapping

	if (x0>x1)
	{
		t = x0;
		x0=x1;
		x1=t;
		t = y0;
		y0=y1;
		y1=t;
	}

	if (x1<0 || x0>511)
		return;

	if (x0<0)
	{
		y0 = (0-x0)*(y1-y0)/(x1-x0)+y0;
		x0 = 0;
	}
	if (x1>511)
	{
		y1 = (511-x0)*(y1-y0)/(x1-x0)+y0;
		x1 = 511;
	}

	if (y0>y1)
	{
		t = x0;
		x0=x1;
		x1=t;
		t = y0;
		y0=y1;
		y1=t;
	}

	if (y1<0 || y0>239)
		return;
	if (y0<0)
	{
		x0 = (0-y0)*(x1-x0)/(y1-y0)+x0;
		y0 = 0;
	}
	if (y1>239)
	{
		x1 = (239-y0)*(x1-x0)/(y1-y0)+x0;
		y1 = 239;
	}


	
   LINE_F2* aline=(LINE_F2*)pPoly;
	Uint8 *newppoly=(Uint8*)(aline+1);
	if (newppoly>PolyBufferEnd) {POLYOVERFLOWINDICATOR; return;} // See ya
   pPoly=(Uint32*)newppoly;
	
   aline->tag=0x03000000;
	*(Uint32*)&aline->r0=0x40000000 + Color;
	aline->x0=x0;
	aline->y0=y0;
	aline->x1=x1;
	aline->y1=y1;
	addPrim(pDoubleBuffer->PanelOT,aline);
}



// draw the bounding box of an item
Mick_ItemOutline(SItem * pItem, int color)
{
	SModel *pModel=PSXRegion[pItem->Region].ppModels[pItem->Model];
	int x = pItem->Position.vx>>FRACBITS;
	int y = pItem->Position.vz>>FRACBITS;

	if (pModel->NumFaces > 50	)
	{
		color = Rnd(3000);
	}

	int x0 = x+ ((Sint32)(Sint16)(pModel->Box.vx));
	int x1 = x+ (pModel->Box.vx>>16);

	int y0 = y +((Sint32)(Sint16)(pModel->Box.vz));
	int y1 = y +(pModel->Box.vz>>16);

	
	Mick_Line(x0,y0,x1,y0,color);
	Mick_Line(x0,y0,x0,y1,color);
	Mick_Line(x0,y1,x1,y1,color);
	Mick_Line(x1,y0,x1,y1,color);
}

// draw the top down view of an item 
Mick_Item(SItem * pItem, int color)
{
	SModel *pModel=PSXRegion[pItem->Region].ppModels[pItem->Model];

   int ItemX = pItem->Position.vx>>FRACBITS;
   int ItemZ = pItem->Position.vz>>FRACBITS;

	if (pModel->NumFaces > 50	)
	{
		color = Rnd(3000);
	}

   int NumFaces = pModel->NumFaces;
   int NumVertices = pModel->NumVertices;
   int NumNormals = pModel->NumNormals;
   SVECTOR *Normals	  = pModel->Vertices	+ pModel->NumVertices;
   SVECTOR *pVertices = pModel->Vertices;
   Uint32 *pFaceX= (Uint32 *)(Normals+NumNormals);

   //				printf("/n/n*************************<<<<<<<<<<<<<<<<<<<<<<<< /n");
   for (int i=0; i<NumFaces; i++,pFaceX+=FACELEN(pFaceX))
   {
      SFace *pFace = (SFace*)pFaceX;		// to simplify casting, which hurts my head.


      Uint16   *pFaceFlags=(Uint16*)pFace;
		#if PSXVERSION>=0x20004
      Uint8    *pVertexIndex=(Uint8*)(pFaceFlags+CFACE_VERTEXNUMS*2); // Byte vertex indices which are not shifted
      int x0 =   pVertices[pVertexIndex[0]].vx+ItemX; 
      int z0 =   pVertices[pVertexIndex[0]].vz+ItemZ;

      int x1 =   pVertices[pVertexIndex[1]].vx+ItemX;
      int z1 =   pVertices[pVertexIndex[1]].vz+ItemZ;

      int x2 =   pVertices[pVertexIndex[2]].vx+ItemX;
      int z2 =   pVertices[pVertexIndex[2]].vz+ItemZ;
		#else
      Uint16    *pVertexIndex=pFaceFlags+CFACE_VERTEXNUMS*2;
      int x0 =   pVertices[pVertexIndex[0]>>3].vx+ItemX;
      int z0 =   pVertices[pVertexIndex[0]>>3].vz+ItemZ;

      int x1 =   pVertices[pVertexIndex[1]>>3].vx+ItemX;
      int z1 =   pVertices[pVertexIndex[1]>>3].vz+ItemZ;

      int x2 =   pVertices[pVertexIndex[2]>>3].vx+ItemX;
      int z2 =   pVertices[pVertexIndex[2]>>3].vz+ItemZ;
		#endif

		// ignore axis aligned vertical linesa
//		if (x0==x1 && x1 == x2 || z0==z1 && z1==z2)
//			continue;
		// ignore if any two points on top of each other
		if (x0==x2 && z0==z2)
			continue;
		if (x0==x1 && z0==z1)
			continue;
		if (x2==x1 && z2==z1)
			continue;

      if (! (pFace->Flags&FACEFLAGS_TRIANGLE))
      {
			#if PSXVERSION>=0x20004
         int x3 =   pVertices[pVertexIndex[3]].vx+ItemX;
         int z3 =   pVertices[pVertexIndex[3]].vz+ItemZ;
			#else
         int x3 =   pVertices[pVertexIndex[3]>>3].vx+ItemX;
         int z3 =   pVertices[pVertexIndex[3]>>3].vz+ItemZ;
			#endif
			Mick_Line(x0,z0,x1,z1,color);
			Mick_Line(x1,z1,x3,z3,color);
			Mick_Line(x2,z2,x3,z3,color);
			Mick_Line(x2,z2,x0,z0,color);
      }
		else
		{
			Mick_Line(x0,z0,x1,z1,color);
			Mick_Line(x1,z1,x2,z2,color);
			Mick_Line(x2,z2,x0,z0,color);
		}

   }
}

#endif

int	Mick_Darkness=0;

void Mick_Darken()
{

//		return;
		// Get the position in the OT.
      Uint32* OTPos=pDoubleBuffer->PanelOT+1;			// last slot of panel, and set it up before them, but after the windowing
		
		if (Mick_Darkness<40)
		{
			Mick_Darkness += 4;
		}

		// Set up the big transparent poly and add it to the display list.
		POLY_F4 *aPoly=(POLY_F4*)pPoly;
      DR_TPAGE* ptpage=(DR_TPAGE*)(aPoly+1);
		Uint8 *newppoly=(Uint8*)(ptpage+1);
		if (newppoly>PolyBufferEnd) {POLYOVERFLOWINDICATOR; return;} // See ya
	   pPoly=(Uint32*)newppoly;
		
		setPolyF4(aPoly);
		aPoly->code|=0x02; // Semitransparent
		aPoly->r0=Mick_Darkness, aPoly->g0=Mick_Darkness, aPoly->b0=Mick_Darkness;

		aPoly->x0=0;	aPoly->x1=SCREENWIDTH;
		aPoly->y0=0;	aPoly->y1=0;
		aPoly->x2=0;	aPoly->x3=SCREENWIDTH;
		aPoly->y2=SCREENHEIGHT;	aPoly->y3=SCREENHEIGHT;
      addPrim(OTPos,aPoly);

		
		// Now add the tpage primitive to set the transparency rate for the above poly.
      ptpage->tag=0x01000000;
//		if (Fading)
	      ptpage->code[0]=0xe1000640; // Subtractive transparency
//		else	
//      	ptpage->code[0]=0xe1000620; // 50:50 transparency
      addPrim(OTPos,ptpage);
}

#if DEBUG&&MICK

#define TRACERS 0


STracer *pTracerList = NULL; 
int TraceIndex = 0;

STracer *Tracer_New(int color)
{
	#if !TRACERS
	return 0;
	#else
	STracer *pTracer = (STracer*)Mem_New(sizeof(STracer));
	pTracer->Scale = 256;
	pTracer->Color = color;
	pTracer->pNext = pTracerList;
	pTracerList = pTracer;
	for (int i=0;i<TRACELEN;i++)
		pTracer->Data[i]=0;
	return pTracer;
	#endif
}

void Tracers_Delete()
{
	#if TRACERS
	STracer *pTracer = pTracerList;
	while (pTracer)
	{
		STracer *pThis = pTracer; 
		pTracer = pTracer->pNext;
		Mem_Delete(pThis);
	}
	pTracerList = NULL;
	#endif
}


// advance the index, and clear that position in all tracers
void Tracers_Advance()
{
	#if TRACERS
	TraceIndex++;
	if (TraceIndex == TRACELEN)
		TraceIndex = 0;
	STracer *pTracer = pTracerList;
	while (pTracer)
	{
		pTracer->Data[TraceIndex] = 0;
		pTracer = pTracer->pNext;
	}
	#endif
}


void Tracer_Set(STracer *pTrace, int Value)
{
	#if TRACERS
	pTrace->Data[TraceIndex] = Value;
	#endif
}

void Tracer_Increment(STracer *pTrace, int Value)
{
	#if TRACERS

	if (!GamePaused)			// Dont do it if paused, as we might end up getting overflows
		pTrace->Data[TraceIndex] += Value;
	#endif
}


void Tracer_Line(int x0, int y0, int x1, int y1, int Color)
{
	RECORDRA;


	// Clipping
	int t;   // temp var for swapping

	if (x0>x1)
	{
		t = x0;
		x0=x1;
		x1=t;
		t = y0;
		y0=y1;
		y1=t;
	}

	if (x1<0 || x0>511)
		return;

	if (x0<0)
	{
		y0 = (0-x0)*(y1-y0)/(x1-x0)+y0;
		x0 = 0;
	}
	if (x1>511)
	{
		y1 = (511-x0)*(y1-y0)/(x1-x0)+y0;
		x1 = 511;
	}

	if (y0>y1)
	{
		t = x0;
		x0=x1;
		x1=t;
		t = y0;
		y0=y1;
		y1=t;
	}

	if (y1<0 || y0>239)
		return;
	if (y0<0)
	{
		x0 = (0-y0)*(x1-x0)/(y1-y0)+x0;
		y0 = 0;
	}
	if (y1>239)
	{
		x1 = (239-y0)*(x1-x0)/(y1-y0)+x0;
		y1 = 239;
	}


	
   LINE_F2* aline=(LINE_F2*)pPoly;
	Uint8 *newppoly=(Uint8*)(aline+1);
	if (newppoly>PolyBufferEnd) {POLYOVERFLOWINDICATOR; return;} // See ya
   pPoly=(Uint32*)newppoly;
	
   aline->tag=0x03000000;
	*(Uint32*)&aline->r0=0x40000000 + Color;
	aline->x0=x0;
	aline->y0=y0;
	aline->x1=x1;
	aline->y1=y1;
	addPrim(pDoubleBuffer->PanelOT,aline);
}


void Tracers_Display()
{
	#if TRACERS

	STracer *pTrace = pTracerList;
	int TraceX = 30;
	int TraceY = 50;
	STracer *pTracer = pTracerList;
	int Color = pTracer->Color;
	while (pTracer)
	{
		int index = TraceIndex+1;
		for (int i=0;i<TRACELEN;i++)
		{
			if (index == TRACELEN)
				index = 0;
			Tracer_Line(TraceX+i,TraceY,TraceX+i,TraceY-pTracer->Data[index],Color);
			index++;
		}
		pTracer = pTracer->pNext;
		TraceY += 30;
	}
	#endif
}


#endif //DEBUG


// given a loaded bmp file, download it, and the palette to specific locations
// modified version of function written by Ryan
// pData is the .BMP file
// x,y = coordinates of texture in VRAM
// ClutX, ClutY = coordinates of 256 color palette in VRAM
// assumes that the textures are the same size
// loads and decodes the (uncompressed) bmp
void DownloadBMP(char* pData, int x, int y, int ClutX, int ClutY) 
{
	char dum1, dum2;
	
	int w, h;
	w = (int) (*(Uint16 *) (pData + 18));
	h = (int) (*(Uint16 *) (pData + 22));


	int bpp = *(Uint16 *) (pData + 28);
	ASSERT(bpp == 8,"Non-8 bit texture in DownloadBMP");

	int colors = (int) (*(Uint16 *) (pData + 46));
	if (colors == 0) colors = 256;

	int transparent_color = 0;
	Uint16 colorTab[256];
	char *pColor = pData + 54;
	for (int i = 0; i < colors; i++) 
	{
		Uint16 r, g, b;
		b = (Uint16) *pColor;	
		g = (Uint16) *(pColor+1);	
		r = (Uint16) *(pColor+2);
		if (b > 247 && g == 0 && r > 247) // replace this color with transparent black
		{
			transparent_color = i;
			colorTab[i] = 0x0000;
		}
		else
		{
			b = b>>3;
			g = g>>3;
			r = r>>3;
			if (b == 0 && g == 0 && r == 0) // replace with solid black
				colorTab[i] = 0x8000;	
			else colorTab[i] = (b<<10) + (g<<5) + r;
		}
		pColor += 4;	
	}


	// put pallete there
	RECT r;
	r.x = ClutX;
	r.y = ClutY;
	r.w = 256;
	r.h = 1;
	LoadImage(&r, (u_long *) colorTab);
	DrawSync(0);


	// should I add padding?
	// (note: the width of the image is automatically a multiple of four,
	// even though the width specifier in the BMP header isn't)
	int pad = w % 4;
	if (pad > 0) pad = 4 - pad;
	w += pad;
	
	// create a new memory buffer and copy actual image data into it
	// (this also puts the BMP data right-side up)
	char *data = (char *) Mem_New((w+3) * h, 1);
	char *in = pData + 54 + (colors * 4);
	char *out = (char*)(data + ((h - 1) * w));
	for (int j = 0; j < h; j++) 
	{
		for (int i = 0; i < w - pad; i++)
			*out++ = *in++;
		
		for (int i = 0; i < pad; i++) 
		{
			*out++ = transparent_color;
			in++;
		}
		
		out -= w << 1;
	}

	r.x = x;
	r.y = y;
	r.w = w/2;
	r.h = h;
	LoadImage(&r, (u_long*)data);
	DrawSync(0);



	Mem_Delete(data);

}


// Replace a texture in VRAM with one loaded in from a file

void ReplaceTexture(Uint32 Checksum, char *pFile)
{

	// Find the texture, make sure it is there
	STexture *pTexture = Spool_FindTextureEntry(Checksum);
	#if RYAN
	ASSERT(pTexture,"Target Texture not found in ReplaceTexture");
	#endif
	if (!pTexture) return;   // just to be on the safe side

	// find where it is in VRAM
	#if DEBUG
	int X = pTexture->pVRAMRect->p_pack->X;
	int Y = pTexture->pVRAMRect->p_pack->Y;
	#else
	int X = pTexture->x;
	int Y = pTexture->y;
	#endif

	// find where the palette is
	int ClutX = Pal256X;
	int ClutY = Pal256Y + pTexture->pPalette->slot; 

	// Load the BMP into memory
	int size = FileIO_Open(pFile);
	char *buf = (char*) Mem_New(size, 1);
	FileIO_Load(buf);
	FileIO_Sync();


	// extract and download bmp and font
	DownloadBMP(buf,X,Y,ClutX,ClutY);

	// recover memory

	Mem_Delete(buf);

	// That's it	

}



#define MAPSPEED 8


void Logic()
{
   RECORDRA;


#if DEBUG
   if (Pad[0].Up.Triggered && Pad[0].Select.Pressed && Pad[0].Up.Pressed)
   {
      Pad[0].Up.Triggered=0;
      DebugFaceFlags ^= FF_TRN;     // no bits zeroed out,
   }
//   if (Pad[0].Down.Triggered && Pad[0].Select.Pressed && Pad[0].Down.Pressed)
//   {
//      Pad[0].Down.Triggered=0;
//      DebugFaceFlags ^= ((FF_TEX|FF_ARB))<<16;     // zero the textured bit
//   }
//   if (Pad[0].Left.Triggered && Pad[0].Select.Pressed && Pad[0].Left.Pressed)
//   {
//      Pad[0].Left.Triggered=0;
//      DebugFaceFlags ^= FF_VXC<<16;     // zero the gourad bit
//   }

   if (Pad[0].Right.Triggered && Pad[0].Select.Pressed && Pad[0].Right.Pressed)
   {
      Pad[0].Right.Triggered = 0;
      DebugFaceFlags = 0xffff0000;     // zero the textured bit
   }

#endif

   extern int LogicsCalled;
   LogicsCalled++;

   int i;
   CBruce* pMech;
   CCamera* pCam;

   if( EveryOther++ & 1 ) return;

	#if DEBUG&&MICKMAP
	if (Pad[0].LeftOne.Pressed && Pad[0].LeftTwo.Pressed && Pad[0].RightOne.Pressed && Pad[0].RightTwo.Pressed)
	{
		Mick_MapMode ^=1;
		Pause(30);
	}
	if (Mick_MapMode && GamePaused)
	{
		if (Pad[0].Up.Pressed)
			MapY+=MAPSPEED;
		if (Pad[0].Down.Pressed)
			MapY-=MAPSPEED;
		if (Pad[0].Left.Pressed)
			MapX+=MAPSPEED*16/10;
		if (Pad[0].Right.Pressed)
			MapX-=MAPSPEED*16/10;
		if (Pad[0].Select.Pressed)
		{
			MapX = 256;
			MapY = 120;
		}
		if (Pad[0].Square.Pressed)
		{
			if (MapScale > 32)
			MapScale -= MapScale/16;
		}
		if (Pad[0].Circle.Pressed)
		{
			MapScale += MapScale/16;
		}
	}

	if (Mick_MapMode)
	{
		GSkater1->mPlayTime = XFrames + 20*60*60;
	}
	#endif


   ++TTime;

//   Tint_Update();
   Font_Reset();

#	if DEBUG
   // Reset these counters (Ob_AI() calls will modify them)
   NumSuspended=0;
   NumAICalls=0;
#	endif

//   Pad_Update();   << in logic

#if DEBUG
   Debug_Print();
   Debug_TestingStuff();
#endif

#if DEBUG
   ProfileReadCount(0,0,44);
#endif


   int	Frozen;
   Frozen = (GamePaused || GameFrozen);
   if (!Frozen)
   {
      Flash_Update();
      Utils_ClearExplosionStack();
      Ob_ClearInputFlags(BaddyList);
      Ob_ClearInputFlags(EnvironmentalObjectList);

//      Trig_ResetCPCollisionFlags(); // Flag logic for the command points.

      Ob_AI(&MechList);

		if (!GamePaused)				// Might become paused at end of 2P replay
		{

//	      Trig_ResetCPExecutedFlags();

	#if DEBUG
	      ProfileReadCount(0,255,255);				// CYAN
	#endif

	      Bit_Move();
	      Rail_Update(); // Rails now separated from non-rendered bit list

	#if DEBUG
	      ProfileReadCount(0,128,0);
	#endif

	      Ob_AI(&PowerUpList);

	#if DEBUG
	      ProfileReadCount(70,28,200);				  // blue
	#endif

	      TrickOb_Update(); // Brighten up objects
	#if DEBUG
	      ProfileReadCount(50,50,50);		   ///  GRAY
	#endif
			
	      Ob_QuickAI(&EnvironmentalObjectList);

	#if DEBUG
	      ProfileReadCount(0,100,0);		   ///  GREEN
	#endif
	      Ob_QuickAI(&BackgroundList);
	#if DEBUG
	      ProfileReadCount(100,100,0);		   ///  yellow
	#endif

	      Ob_MaybeUnSuspendOrCull();

	      Ob_AI(&BaddyList);    // Baddies are moved last because bullets and bits
	      // may set the baddies input flags which they
	      // need to respond to
	#if DEBUG
	      ProfileReadCount(0,100,100);		   ///  dull cyan
	#endif


	#if DEBUG
	      ProfileReadCount(132,132,132);		   ///  white
	#endif

	      Bit_RemoveDeadBits();

			if(GGame != GAME_HORSE)
				if (   GState == GSTATE_STOP && GSpin < SPIN_TIME 
				    && GSkater1->mPhysicsState == PHYSICS_ON_GROUND
				    && (!GSkater2 || GSkater2->mPhysicsState == PHYSICS_ON_GROUND))
				{
					//spin the camera around the player whilst he keeps moving
					GSkater1->mpCamera->extra_YRot+=GSpinSpeed;
					if (GSkater2)
						GSkater2->mpCamera->extra_YRot+=GSpinSpeed;

		//	  		((CCamera*)CameraList)->extra_YRot+=64;	   // was 64
		//			if (GNumberOfPlayers == 2)
		//	  			(((CCamera*)((CCamera*)CameraList)->mNextItem))->extra_YRot-=64;  // other player spins other way

				}

		}	// end if (!GamePaused)
		else
		{
			#if MICK&&DEBUG
			printf("Skipped final P1 Physics that previously caused nasty obscure crashes, phew!\n");
			#endif
		}
      //if (!InShell) Panel_Update();
   }	// if (!GamePaused)
   else
   {
		if (GState == GSTATE_STOP)
		{
			//spin the camera around the player whilst he keeps moving
	  	//	((CCamera*)CameraList)->extra_YRot+=64;
		// here we should test to see it the skater has come to a rest.

//	      int temp = GamePaused;
//	      int temp1 = GameFrozen;
//	      GamePaused = 0;
//			GameFrozen = 0;
	      Ob_AI(&CameraList);
//			GamePaused = temp;
//	      GameFrozen = temp1;
      }
		else
		{
	   //   Ob_AI(&CameraList);
		}
   }


   Shatter_MaybeMakeGlassShatterSound();

#if DEBUG
   // Maybe turn on the low memory indicator.
   if (LowMemory) LowMemoryIndicatorTimer=LOWMEMORYMESSAGEDURATION;
#endif

//#if TWEAK
//   if (!TweakMode)
//#endif
//   {
      Panel_Update();

	  SControl TempPad;

	  if (GGame == GAME_HORSE && GHorsePlayer == 1)
	  {
		  // must swap back pads so that we can restore/remap
		  // controllers appropriately
		  // (this is because Pad_Restore/Pad_Remap store actual
		  // pointers, rather than offsets into the current pad)
		  TempPad = Pad[0];
		  Pad[0] = Pad[1];
		  Pad[1] = TempPad;
	  }
	  
	  Pad_Restore();
      Front_Update();
	  Pad_Remap();

	  if (GGame == GAME_HORSE && GHorsePlayer == 1)
	  {
		  // must swap back pads so that we can restore/remap
		  // controllers appropriately
		  // (this is because Pad_Restore/Pad_Remap store actual
		  // pointers, rather than offsets into the current pad)
		  TempPad = Pad[0];
		  Pad[0] = Pad[1];
		  Pad[1] = TempPad;
	  }

	TrickTips_Update();
//   }
   Mess_Update();

   // unless we are doing a spoollock test, we load a bit every frame
//   if (!Cheat_SpoolLockTest)
   {
      Spool_Continue();
      FileIO_Continue();
   }

#if DEBUG
   Mem_CalcHoles(DisplayedHeap);
#endif


#if DEBUG
   ProfileReadCount(128,128,0);
#endif

   return;
}

