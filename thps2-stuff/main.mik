// These six functions are used for smoothing objects and bits' motions when the GPU
// is struggling. They are only called from within Display().





int	PrimitiveCount;


//
//#define setPolyF3(p)	setlen(p, 4),  setcode(p, 0x20)
//#define setPolyFT3(p)	setlen(p, 7),  setcode(p, 0x24)
//#define setPolyG3(p)	setlen(p, 6),  setcode(p, 0x30)
//#define setPolyGT3(p)	setlen(p, 9),  setcode(p, 0x34)
//#define setPolyF4(p)	setlen(p, 5),  setcode(p, 0x28)
//#define setPolyFT4(p)	setlen(p, 9),  setcode(p, 0x2c)
//#define setPolyG4(p)	setlen(p, 8),  setcode(p, 0x38)
//#define setPolyGT4(p)	setlen(p, 12), setcode(p, 0x3c)


#if DEBUG

int CountPrimitives()
{
   RECORDRA;

   int	Primitives = 0;

	NumPolyF3=0;
	NumPolyFT3=0;
	NumPolyG3=0;
	NumPolyGT3=0;
	NumPolyF4=0;
	NumPolyFT4=0;
	NumPolyG4=0;
	NumPolyGT4=0;
	NumSetTile=0;
	NumTile1=0;
	NumOther=0;



   P_TAG* pPrim = (P_TAG*)(pDoubleBuffer->PanelOT[Db_OTSize()-1]);

   while (pPrim!=(P_TAG*)0xffffff)
   {
      if (pPrim->len==0)
      {
         pPrim=(P_TAG*)(pPrim->addr);
         ASSERT((((Uint32)pPrim)&0xff000000)==0,"eh?");
      }
      else
      {
         Primitives++;

			switch (pPrim->code & 0x7c)
			{
				case 0x20 :
					NumPolyF3++;
					break;
				case 0x24 :
					NumPolyFT3++;
					break;
				case 0x30 :
					NumPolyG3++;
					break;
				case 0x34 :
					NumPolyGT3++;
					break;
				case 0x28 :
					NumPolyF4++;
					break;
				case 0x2c :
					NumPolyFT4++;
					break;
				case 0x38 :
					NumPolyG4++;
					break;
				case 0x3c :
					NumPolyGT4++;
					break;
				case 0x60 :
					NumSetTile++;
					break;
				case 0x68 :
					NumTile1++;
					break;
				default :
					//if (NumOther < 20)
					//	printf("%lx\n",(int)(pPrim->code & 0x7c));
					NumOther++;
			}
         pPrim=(P_TAG*)(pPrim->addr);
         ASSERT((((Uint32)pPrim)&0xff000000)==0,"eh?");
      }
   }
   return Primitives;
}

#endif

// Shrink everything that is being drawing into the middle of the screen
// so we can see what a vast amount of overdraw we have
void ShrinkPrimitives()
{
#if DEBUG
   RECORDRA;


   P_TAG* pPrim = (P_TAG*)(pDoubleBuffer->PanelOT[Db_OTSize()-1]);

   while (pPrim!=(P_TAG*)0xffffff)
   {
      if (pPrim->len==0)
      {
         pPrim=(P_TAG*)(pPrim->addr);
         ASSERT((((Uint32)pPrim)&0xff000000)==0,"eh?");
      }
      else
      {

   	POLY_G3  *pG3;
   	POLY_F3  *pF3;
   	POLY_FT3 *pFT3;
   	POLY_GT3 *pGT3;

   	POLY_G4  *pG4;
   	POLY_F4  *pF4;
   	POLY_FT4 *pFT4;
   	POLY_GT4 *pGT4;


			switch (pPrim->code & 0x7c)
			{

				case 0x20 :
				// F3
		      	pF3 = (POLY_F3 *)pPrim;
					pF3->x0 = pF3->x0/4+128;
					pF3->x1 = pF3->x1/4+128;
					pF3->x2 = pF3->x2/4+128;

					pF3->y0 = pF3->y0/4+60;
					pF3->y1 = pF3->y1/4+60;
					pF3->y2 = pF3->y2/4+60;
					break;
				case 0x24 :
				// ft3
		      	pFT3 = (POLY_FT3 *)pPrim;
					pFT3->x0 = pFT3->x0/4+128;
					pFT3->x1 = pFT3->x1/4+128;
					pFT3->x2 = pFT3->x2/4+128;

					pFT3->y0 = pFT3->y0/4+60;
					pFT3->y1 = pFT3->y1/4+60;
					pFT3->y2 = pFT3->y2/4+60;
					break;
				case 0x30 :
				// g3
		      	pG3 = (POLY_G3 *)pPrim;
					pG3->x0 = pG3->x0/4+128;
					pG3->x1 = pG3->x1/4+128;
					pG3->x2 = pG3->x2/4+128;

					pG3->y0 = pG3->y0/4+60;
					pG3->y1 = pG3->y1/4+60;
					pG3->y2 = pG3->y2/4+60;
					break;
				case 0x34 :
				// gt3 
		      	pGT3 = (POLY_GT3 *)pPrim;
					pGT3->x0 = pGT3->x0/4+128;
					pGT3->x1 = pGT3->x1/4+128;
					pGT3->x2 = pGT3->x2/4+128;

					pGT3->y0 = pGT3->y0/4+60;
					pGT3->y1 = pGT3->y1/4+60;
					pGT3->y2 = pGT3->y2/4+60;
					break;

				case 0x28 :
				// f4
		      	pF4 = (POLY_F4 *)pPrim;
					pF4->x0 = pF4->x0/4+128;
					pF4->x1 = pF4->x1/4+128;
					pF4->x2 = pF4->x2/4+128;
					pF4->x3 = pF4->x3/4+128;

					pF4->y0 = pF4->y0/4+60;
					pF4->y1 = pF4->y1/4+60;
					pF4->y2 = pF4->y2/4+60;
					pF4->y3 = pF4->y3/4+60;
					break;
				case 0x2c :
				// ft4
		      	pFT4 = (POLY_FT4 *)pPrim;
					pFT4->x0 = pFT4->x0/4+128;
					pFT4->x1 = pFT4->x1/4+128;
					pFT4->x2 = pFT4->x2/4+128;
					pFT4->x3 = pFT4->x3/4+128;

					pFT4->y0 = pFT4->y0/4+60;
					pFT4->y1 = pFT4->y1/4+60;
					pFT4->y2 = pFT4->y2/4+60;
					pFT4->y3 = pFT4->y3/4+60;
					break;
				case 0x38 :
				// g4
		      	pG4 = (POLY_G4 *)pPrim;
					pG4->x0 = pG4->x0/4+128;
					pG4->x1 = pG4->x1/4+128;
					pG4->x2 = pG4->x2/4+128;
					pG4->x3 = pG4->x3/4+128;

					pG4->y0 = pG4->y0/4+60;
					pG4->y1 = pG4->y1/4+60;
					pG4->y2 = pG4->y2/4+60;
					pG4->y3 = pG4->y3/4+60;
					break;
				case 0x3c :
				// gt4
		      	pGT4 = (POLY_GT4 *)pPrim;
					pGT4->x0 = pGT4->x0/4+128;
					pGT4->x1 = pGT4->x1/4+128;
					pGT4->x2 = pGT4->x2/4+128;
					pGT4->x3 = pGT4->x3/4+128;

					pGT4->y0 = pGT4->y0/4+60;
					pGT4->y1 = pGT4->y1/4+60;
					pGT4->y2 = pGT4->y2/4+60;
					pGT4->y3 = pGT4->y3/4+60;
					break;


				case 0x60 :
//					NumSetTile++;
					break;
				case 0x68 :
//					NumTile1++;
					break;
				default :
					break;
					//if (NumOther < 20)
					//	printf("%lx\n",(int)(Tri->code & 0x7c));
			}
         pPrim=(P_TAG*)(pPrim->addr);
         ASSERT((((Uint32)pPrim)&0xff000000)==0,"eh?");
      }
   }
#endif
}



