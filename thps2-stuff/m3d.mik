	aline->x0=z0;
	aline->y0=y0;
	aline->x1=z1;
	aline->y1=y1;
	addPrim( pDoubleBuffer->OrderingTable, aline );
}


// The following code is taken from Graphics Gems II.
#define DONT_INTERSECT	0
#define DO_INTERSECT		1
#define COLLINEAR			2

#define SAME_SIGNS( a, b )	( ( (long)( (unsigned long)a ^ (unsigned long)b ) ) >= 0 )

int lines_intersect( long x1, long y1, long x2, long y2, long x3, long y3, long x4, long y4, long *x, long *y )
{
	RECORDRA;

	CVector L1Start, L1End, L2Start, L2End, PointL1, PointL2;
	int t1, t2;

	L1Start.vx	= x1 << 12;
	L1Start.vy	= y1 << 12;
	L1Start.vz	= 0;
	L1End.vx		= x2 << 12;
	L1End.vy		= y2 << 12;
	L1End.vz		= 0;

	L2Start.vx	= x3 << 12;
	L2Start.vy	= y3 << 12;
	L2Start.vz	= 0;
	L2End.vx		= x4 << 12;
	L2End.vy		= y4 << 12;
	L2End.vz		= 0;

	int result = M3dUtils_LineLineClosestPoints( &L1Start, &L1End, &L2Start, &L2End, &PointL1, &t1, &PointL2, &t2 );
	if( result > 16 )
		printf( "M3dUtils_LineLineClosestPoints returned d of: %d\n", result );
	
	// Want to return PointL1, which is the closest point on the line to the frustrum plane.
	*x = PointL1.vx >> 12;	
	*y = PointL1.vy >> 12;
	return t1;

	// Calculate a1, b1, c1, where line joinging points 1 and 2 is a1x + b1y + c1 = 0.
	long a1 = y2 - y1;
	long b1 = x1 - x2;
	long c1 = x2 * y1 - x1 * y2;

	// Calculate r3 and r4.
	long r3 = a1 * x3 + b1 * y3 + c1;
	long r4 = a1 * x4 + b1 * y4 + c1;

	// Check signs of r3 and r4. If both point 3 and point 4 lie on same side of line 1, the line segments do not intersect.
	if( r3 && r4 && SAME_SIGNS( r3, r4 ) )
		return DONT_INTERSECT;

	// Calculate a2, b2, c2.
	long a2 = y4 - y3;
	long b2 = x3 - x4;
	long c2 = x4 * y3 - x3 * y4;

	// Calculate r1 and r2.
	long r1 = a2 * x1 + b2 * y1 + c2;
	long r2 = a2 * x2 + b2 * y2 + c2;

	// Check signs of r1 and r2. If both point 1 and point 2 lie on same side of line 2, the line segments do not intersect.
	if( r1 && r2 && SAME_SIGNS( r1, r2 ) )
		return DONT_INTERSECT;

	// Line segments intersect. Calculate intersection point.
	long denom = a1 * b2 - a2 * b1;
	if( denom == 0 )
		return COLLINEAR;
	long offset = ( denom < 0 ) ? -denom / 2 : denom / 2;

	// The denom / 2 is to get rounding rather than truncating. It is added or subtracted to the numerator, depending upon the sign of the numerator.
	long num = b1 * c2 - b2 * c1;
	*x = ( num < 0 ? num - offset : num + offset ) / denom;

	num = a2 * c1 - a1 * c2;
	*y = ( num < 0 ? num - offset : num + offset ) / denom;
	
	return DO_INTERSECT;
}


// These are allocated and destroyed over the course of creating a near-z clipped face.
Uint32					*pClipVertexColors;
Uint32					*pClipUVs;
SModel					*pClipModel;
Uint32					*pClipFace;
Uint8						new_vertex[8];
SProjectedClipVertex	clip_vertex[8];
Uint32					maxClipZ;



SProjectedClipVertex	clip_vertex_a[16];
SProjectedClipVertex	clip_vertex_b[16];
SProjectedClipVertex *p_current_read_array;
SProjectedClipVertex *p_current_write_array;


// A type definition of a pointer to a clipping function.
typedef void (*clipping_function_type)( Uint32, Uint32, Uint32 );

// An array of pointers to clipping functions.
clipping_function_type clipping_functions[] = { ClipHitherSide2, ClipPositiveVerticalSide2, ClipNegativeVerticalSide2, ClipPositiveHorizontalSide2, ClipNegativeHorizontalSide2 };


void AddClipVertex( int index, int vertex, int v0v4 )
{
	RECORDRA;

	new_vertex[index]				= vertex;
	clip_vertex[index].X			= ProjectedVertices[vertex].X;
	clip_vertex[index].Y			= ProjectedVertices[vertex].Y;
	clip_vertex[index].z			= ProjectedVertices[vertex].z;

	clip_vertex[index].world_x = RotatedVertices[vertex].x;
	clip_vertex[index].world_y = RotatedVertices[vertex].y;

	Uint32 flags = *pClipFace;

	// Decide whether this vertex is clipped or non-clipped.
	bool clip = vertex >= pClipModel->NumVertices;

	if( flags & FF_VXC )
	{
		if( clip )
		{
			clip_vertex[index].rgb = pClipVertexColors[vertex - pClipModel->NumVertices];
		}
		else
		{
			Uint32 vxc_index;

			if( v0v4 == 0 )
				vxc_index = pClipFace[2] & 0xFF;
			else if( v0v4 == 1 )
				vxc_index = ( pClipFace[2] >> 8 ) & 0xFF;
			else if( v0v4 == 2 )
				vxc_index = ( pClipFace[2] >> 16 ) & 0xFF;
			else
				vxc_index = ( pClipFace[2] >> 24 ) & 0xFF;

			clip_vertex[index].rgb = pColourTable[vxc_index];
		}
	}

	if( flags & ( FF_TEX | FF_ARB ) )
	{
		if( clip )
		{
			clip_vertex[index].uv = pClipUVs[vertex - pClipModel->NumVertices];
		}
		else
		{
			if( v0v4 == 0 )
				clip_vertex[index].uv = pClipFace[4] & 0xFFFF;
			else if( v0v4 == 1 )
				clip_vertex[index].uv = pClipFace[5] & 0xFFFF;
			else if( v0v4 == 2 )
				clip_vertex[index].uv = pClipFace[6] & 0xFFFF;
			else
				clip_vertex[index].uv = ( pClipFace[6] >> 16 ) & 0xFFFF;
		}
//		printf( "AddClipVertex: %d uv: %x\n", index, clip_vertex[index].uv );
	}
}




void AddClipVertex2( int new_index, int vertex )
{
	RECORDRA;

	p_current_write_array[new_index] = p_current_read_array[vertex];
}



void ProcessPolysNearZClipped( SModel *p_model, Uint32 *pFace, SVECTOR *Normals, int NumFaces )
{
	RECORDRA;

	if( T[4] == 1 )
	{
		debugLineXZ( 0, 0,  2560, 2760, 0x00202020 );
		debugLineXZ( 0, 0, -2560, 2760, 0x00202020 );
		debugLineXZ( -512, pCurrentViewport->Hither, 512, pCurrentViewport->Hither, 0x00202020 );
		debugLineXZ( -512, pCurrentViewport->Zoom, 512, pCurrentViewport->Zoom, 0x00202020 );
		debugLineXZ( -512, pCurrentViewport->Zoom /2, 512, pCurrentViewport->Zoom / 2, 0x00202020 );
	}
	else if( T[4] == 2 )
	{
		debugLineYZ( 0, 0,  1200, 2760, 0x00202020 );
		debugLineYZ( 0, 0, -1200, 2760, 0x00202020 );
		debugLineYZ( -512, pCurrentViewport->Hither, 512, pCurrentViewport->Hither, 0x00202020 );
		debugLineYZ( -512, pCurrentViewport->Zoom, 512, pCurrentViewport->Zoom, 0x00202020 );
		debugLineYZ( -512, pCurrentViewport->Zoom / 2, 512, pCurrentViewport->Zoom / 2, 0x00202020 );
	}

	Uint32 gff, gff_mod;

	for( Uint32 face = 0; face < NumFaces; ++face )
	{
		register Uint32 flags = *pFace;

		// If face is not visible, skip it.
		if( !( flags & FF_VIS ) )
		{
			pFace += ( ( flags >> 16 ) / 4 );
			continue;
		}

		// If the face is a floor poly, just render it. Have to get the normal first to decide.
		SVECTOR *p_normal = p_model->Vertices + p_model->NumVertices + face;
		if( p_normal->vy <= -4000 )
		{
			// Render normally.
			M3dAsm_ProcessPolys( pFace, Normals, 1 );
			pFace += ( ( flags >> 16 ) / 4 );
			continue;
		}

		// This variable is referenced by other functions.
		pClipFace = pFace;

		// It is important to remember that the vertex order for rendering is not be the one we need for
		// clipping, in the case of quads. They are ordered 0->1->3->2, when we want to clip 0->1->2->3.
		// So reorder in the case of quads.
		register Uint32 verts = *( pFace + 1 );
		register Uint32 v[4];
		v[0] = verts & 0xFF;
		v[1] = ( verts >> 8 ) & 0xFF;
		if( flags & FF_TRI )
			v[2] = ( verts >> 16 ) & 0xFF;
		else
		{
			v[2] = ( verts >> 24 ) & 0xFF;
			v[3] = ( verts >> 16 ) & 0xFF;
		}

		// If this face does not intersect the d/2 plane, then just render it normally.
		bool outside_half_d = true;

		Uint32 cumulative_outcode = 0x3FU;
		for( int i = 0; i < 4; ++i )
		{
			if( ( i == 3 ) && ( flags & FF_TRI ) ) break;

			// Checks for all vertices being outside view frustrum.
			cumulative_outcode &= ProjectedVertices[v[i]].Outcode;

			if( outside_half_d && ( ProjectedVertices[v[i]].z <= ( pCurrentViewport->Zoom / 2 ) ) )
				outside_half_d = false;
		}

		if( cumulative_outcode )
		{
			// Poly not visible.
			pFace += ( ( flags >> 16 ) / 4 );
			continue;
		}

		if( outside_half_d )
		{
			// Render normally.
			M3dAsm_ProcessPolys( pFace, Normals, 1 );
			pFace += ( ( flags >> 16 ) / 4 );
			continue;
		}

		// Draw the unclipped poly outline in white.
//		debugLineXZ( RotatedVertices[v[0]].x, ProjectedVertices[v[0]].z, RotatedVertices[v[1]].x, ProjectedVertices[v[1]].z, 0x00FFFFFF );
//		debugLineXZ( RotatedVertices[v[1]].x, ProjectedVertices[v[1]].z, RotatedVertices[v[2]].x, ProjectedVertices[v[2]].z, 0x00FFFFFF );
//		if( !( flags & FF_TRI ) )
//		{
//			debugLineXZ( RotatedVertices[v[2]].x, ProjectedVertices[v[2]].z, RotatedVertices[v[3]].x, ProjectedVertices[v[3]].z, 0x00FFFFFF );
//			debugLineXZ( RotatedVertices[v[3]].x, ProjectedVertices[v[3]].z, RotatedVertices[v[0]].x, ProjectedVertices[v[0]].z, 0x00FFFFFF );
//		}
//		else
//		{
//			debugLineXZ( RotatedVertices[v[2]].x, ProjectedVertices[v[2]].z, RotatedVertices[v[0]].x, ProjectedVertices[v[0]].z, 0x00FFFFFF );
//		}

		// Copy the current vertices into clip_vertex_a[] array.
		for( int vert = 0; vert < 4; ++vert )
		{
			if( ( vert == 3 ) && ( flags & FF_TRI ) ) break;

			clip_vertex_a[vert].world_x = RotatedVertices[v[vert]].x;
			clip_vertex_a[vert].world_y = RotatedVertices[v[vert]].y;
			clip_vertex_a[vert].z = ProjectedVertices[v[vert]].z;

			// Since these are still based on render order...
			Uint32 v0v4 = vert;
			if( !( flags & FF_TRI ) )
			{
				if( vert == 2 ) v0v4 = 3;
				else if( vert == 3 ) v0v4 = 2;
			}
						
			if( flags & FF_VXC )
			{
				Uint32 vxc_index;
				if( v0v4 == 0 )
					vxc_index = pClipFace[2] & 0xFF;
				else if( v0v4 == 1 )
					vxc_index = ( pClipFace[2] >> 8 ) & 0xFF;
				else if( v0v4 == 2 )
					vxc_index = ( pClipFace[2] >> 16 ) & 0xFF;
				else
					vxc_index = ( pClipFace[2] >> 24 ) & 0xFF;
				clip_vertex_a[vert].rgb = pColourTable[vxc_index];
			}

			if( flags & ( FF_TEX | FF_ARB ) )
			{
				Uint32 uv;
				if( v0v4 == 0 )
					uv = pClipFace[4] & 0xFFFF;
				else if( v0v4 == 1 )
					uv = pClipFace[5] & 0xFFFF;
				else if( v0v4 == 2 )
					uv = pClipFace[6] & 0xFFFF;
				else
					uv = ( pClipFace[6] >> 16 ) & 0xFFFF;
				clip_vertex_a[vert].uv = uv;
			}
		}

		p_current_read_array = clip_vertex_a;		// These are the vertices to be clipped.
		p_current_write_array = clip_vertex_b;		// This is where they will get clipped to.

		// Seed the starting number of vertices in this face.
		int number_verts = ( flags & FF_TRI ) ? 3 : 4;

		// Now clip against all view frustrum planes.
		for( int i = 0; i < 5; ++i )
		{
			// Calculate outcode for clipped vertices, for the frustrum plane we are considering.
			Uint32 outcode = 0;

			for( int vert = 0; vert < number_verts; ++vert )
			{
				int x = p_current_read_array[vert].world_x;
				int y = p_current_read_array[vert].world_y;
				int z = p_current_read_array[vert].z;

				switch( i )
				{
					case 0:
					{
						// Check for hither plane.
						if( z < pCurrentViewport->Hither )
							outcode |= ( 1 << vert );
						break;
					}

					case 1:
					{
						// Check for positive vertical plane.
						if( ( x * 2760 ) > ( z * 2560 ) )
							outcode |= ( 1 << vert );
						break;
					}

					case 2:
					{
						// Check for negative vertical plane.
						if( ( x * -2760 ) > ( z * 2560 ) )
							outcode |= ( 1 << vert );
						break;
					}

					case 3:
					{
						// Check for positive horizontal plane.
						if( ( y * 2760 ) > ( z * 1200 ) )
							outcode |= ( 1 << vert );
						break;
					}

					case 4:
					{
						// Check for negative horizontal plane.
						if( ( y * -2760 ) > ( z * 1200 ) )
							outcode |= ( 1 << vert );
					}
				}
			}

//			if( ( i == 0 ) && ( outcode == 0 ) )
//			{
//				// No hither clipping, so render normally.
//				M3dAsm_ProcessPolys( pFace, Normals, 1 );
//				goto SKIP_TO_NEXT_FACE;
//			}

			if( outcode == ( ( 1 << number_verts ) - 1 ) )
			{
				// All available bits are set - face is outside frustrum at this point.
				goto SKIP_TO_NEXT_FACE;
			}

			Uint32 new_vertex_index = 0;

			// Now clip each side in turn.
			for( int side = 0; side < number_verts; ++side )
			{
				// Set up some booleans for testing later.
				bool first_side = ( side == 0 );
				bool last_side = ( side == ( number_verts - 1 ) );

				// Calculate composite outcode for the 2 vertices comprising this side...
				Uint32 oc = ( outcode >> side ) & 0x03;

				// ...Remembering wraparound for last side.
				if( last_side ) oc |= ( ( outcode & 0x01 ) << 1 );

				int v0 = side;
				int v1 = ( last_side ) ? 0 : ( v0 + 1 );

				switch( oc )
				{
					case 0x00:
					{
						if( first_side )
						{
							// Both non-clipped.
							AddClipVertex2( new_vertex_index, v0 );
							++new_vertex_index;
			
							AddClipVertex2( new_vertex_index, v1 );
							++new_vertex_index;
						}
						else if( !last_side )
						{
							// Both non-clipped. So the first vertex here will already be in the list.
							AddClipVertex2( new_vertex_index, v1 );
							++new_vertex_index;
						}
						else
						{
							// Both non-clipped. So both vertices here will already be in the list.
						}
						break;
					}
	
					case 0x01:
					{
						if( !last_side )
						{
							// 0 clipped, 1 non-clipped.
			
							// Vertex 0.
							clipping_functions[i]( new_vertex_index, v1, v0 );
							++new_vertex_index;
								
							AddClipVertex2( new_vertex_index, v1 );
							++new_vertex_index;
						}
						else
						{
							// 0 clipped, 1 non-clipped. So the second vertex will already be in the list.
							clipping_functions[i]( new_vertex_index, v1, v0 );
							++new_vertex_index;
						}
						break;
					}
		
					case 0x02:
					{
						if( first_side )
						{
							// 0 non-clipped, 1 clipped.
							AddClipVertex2( new_vertex_index, v0 );
							++new_vertex_index;
			
							clipping_functions[i]( new_vertex_index, v0, v1 );
							++new_vertex_index;
						}
						else
						{
							// 0 non-clipped, 1 clipped. So the first vertex here will already be in the list.
							clipping_functions[i]( new_vertex_index, v0, v1 );
							++new_vertex_index;
						}
						break;
					}
		
					case 0x03:
					{
						// Both clipped.
						break;
					}
				}
			}

			// Clipped all sides against this plane. Reset the number of vertices in the newly clipped face.
			number_verts = new_vertex_index;
			if( ( number_verts <= 2 ) || ( number_verts >= 12 ) )
			{
				printf( "Bad number of clip vertices: %d\n", number_verts );
			}

			// Switch read and write buffers.
			SProjectedClipVertex *p_temp = p_current_read_array;
			p_current_read_array = p_current_write_array;
			p_current_write_array = p_temp;
		}

		// At this stage, the face is fully clipped against all frustrum planes.
		// However, if none of the clipped vertices fall within z <= ( d / 2 ), then it is still
		// safe to render it using the engine.
		outside_half_d = true;
		for( int i = 0; i < number_verts; ++i )
		{
			if( p_current_read_array[i].z <= ( pCurrentViewport->Zoom / 2 ) )
			{
				outside_half_d = false;
				break;
			}
		}

		if( outside_half_d )
		{
			// Render normally.
			M3dAsm_ProcessPolys( pFace, Normals, 1 );
			pFace += ( ( flags >> 16 ) / 4 );
			continue;
		}

		RenderClippedPoly2( number_verts );

		SKIP_TO_NEXT_FACE:

		// Skip to the next face (using face length).
		pFace += ( ( flags >> 16 ) / 4 );
	}
}





// Clip side (world coordinates) to hither plane.
void ClipHitherSide2( Uint32 new_index, Uint32 out, Uint32 in )
{
	RECORDRA;

	if( p_current_read_array[out].z < pCurrentViewport->Hither )
	{
		printf( "bad out %d %d\n", out, p_current_read_array[out].z );
	}
	if( p_current_read_array[in].z > pCurrentViewport->Hither )
	{
		printf( "bad in %d %d\n", in, p_current_read_array[in].z );
	}

	// On entry to this function, we know that the 'out' point is not z-clipped, and that the 'in' point is.
	// So, express the 'out' portion of the z distance as a fraction of the total z distance between these 2 points.
	int mult = ( ( p_current_read_array[out].z - pCurrentViewport->Hither ) * 4096 ) / ( p_current_read_array[out].z - p_current_read_array[in].z );

	ASSERT( mult < 4096, "Bad multiplier in ClipHitherSide()" );

	int z = pCurrentViewport->Hither;
	int x = p_current_read_array[out].world_x + ( ( ( p_current_read_array[in].world_x - p_current_read_array[out].world_x ) * mult ) >> 12 );
	int y = p_current_read_array[out].world_y + ( ( ( p_current_read_array[in].world_y - p_current_read_array[out].world_y ) * mult ) >> 12 );

	// Store the newly calculated x and y values in the write array.
	p_current_write_array[new_index].world_x = x;
	p_current_write_array[new_index].world_y = y;
	p_current_write_array[new_index].z = z;

	register Uint32 flags = *pClipFace;

	// If the face is texture mapped, we need to clip the UV coordinates too.
	if( flags & ( FF_TEX | FF_ARB ) )
	{
		int u0 = ( p_current_read_array[out].uv ) & 0xFF;
		int v0 = ( p_current_read_array[out].uv ) >> 8;
		int u1 = ( p_current_read_array[in].uv ) & 0xFF;
		int v1 = ( p_current_read_array[in].uv ) >> 8;

		int uc = u0 + ( ( ( u1 - u0 ) * mult ) >> 12 );
		int vc = v0 + ( ( ( v1 - v0 ) * mult ) >> 12 );

//		printf( "(%d %d) -> (%d %d) by %d = (%d %d)\n", u0, v0, u1, v1, mult, uc, vc );

		// Store this interpolated UV.
		p_current_write_array[new_index].uv = (Uint32)( (Uint16)uc | ( (Uint16)vc << 8 ) );
	}

	// If the face is vertex colored, we need to clip the rgb values too.
	if( flags & FF_VXC )
	{
		Uint32 rgb0 = p_current_read_array[out].rgb;
		Uint32 rgb1 = p_current_read_array[in].rgb;

		int r0 = rgb0 & 0xFF;
		int g0 = ( rgb0 >> 8 ) & 0xFF;
		int b0 = ( rgb0 >> 16 ) & 0xFF;
		int r1 = rgb1 & 0xFF;
		int g1 = ( rgb1 >> 8 ) & 0xFF;
		int b1 = ( rgb1 >> 16 ) & 0xFF;

		r0 += ( ( r1 - r0 ) * mult ) >> 12;
		g0 += ( ( g1 - g0 ) * mult ) >> 12;
		b0 += ( ( b1 - b0 ) * mult ) >> 12;

		// Store this interpolated color.
		p_current_write_array[new_index].rgb = (Uint32)( ( b0 << 16 ) | ( g0 << 8 ) | ( r0 ) );
	}
}













// Clip side (world coordinates) to positive vertical plane.
void ClipPositiveVerticalSide2( Uint32 new_index, Uint32 out, Uint32 in )
{
	RECORDRA;

	if( ( p_current_read_array[out].world_x * 2760 ) > ( p_current_read_array[out].z * 2560 ) )
	{
		printf( "bad out %d %d %d\n", out, p_current_read_array[out].world_x, p_current_read_array[out].z );
	}
	if( ( p_current_read_array[in].world_x * 2760 ) < ( p_current_read_array[in].z * 2560 ) )
	{
		printf( "bad in %d %d %d\n", in, p_current_read_array[in].world_x, p_current_read_array[in].z );
	}

	// Start at a specific multiplier, and increase until the point goes outside the view frustrum, and then use that multiplier.
	int mult = 32;
	int x_delta = p_current_read_array[in].world_x - p_current_read_array[out].world_x;
	int z_delta = p_current_read_array[in].z - p_current_read_array[out].z;
	for( ;; )
	{
		int new_x = p_current_read_array[out].world_x + ( ( x_delta * mult ) >> 12 );
		int new_z = p_current_read_array[out].z + ( ( z_delta * mult ) >> 12 );

		// Has this new point gone outside the frustrum?
		if( ( new_x * 2760 ) > ( new_z * 2560 ) )
		{
			// Yes it has.
			break;
		}
		mult += 32;
	}

	ASSERT( mult <= 4096, "Error" );

	// So now we have the multiplier that takes the point just out of the frustrum.
	int x = p_current_read_array[out].world_x + ( ( ( p_current_read_array[in].world_x - p_current_read_array[out].world_x ) * mult ) >> 12 );
	int y = p_current_read_array[out].world_y + ( ( ( p_current_read_array[in].world_y - p_current_read_array[out].world_y ) * mult ) >> 12 );
	int z = p_current_read_array[out].z + ( ( ( p_current_read_array[in].z - p_current_read_array[out].z ) * mult ) >> 12 );

	// Store the newly calculated x and y values in the write array.
	p_current_write_array[new_index].world_x = x;
	p_current_write_array[new_index].world_y = y;
	p_current_write_array[new_index].z = z;

	register Uint32 flags = *pClipFace;

	// If the face is texture mapped, we need to clip the UV coordinates too.
	if( flags & ( FF_TEX | FF_ARB ) )
	{
		int u0 = ( p_current_read_array[out].uv ) & 0xFF;
		int v0 = ( p_current_read_array[out].uv ) >> 8;
		int u1 = ( p_current_read_array[in].uv ) & 0xFF;
		int v1 = ( p_current_read_array[in].uv ) >> 8;

		int uc = u0 + ( ( ( u1 - u0 ) * mult ) >> 12 );
		int vc = v0 + ( ( ( v1 - v0 ) * mult ) >> 12 );

		// Store this interpolated UV.
		p_current_write_array[new_index].uv = (Uint32)( (Uint16)uc | ( (Uint16)vc << 8 ) );
	}

	// If the face is vertex colored, we need to clip the rgb values too.
	if( flags & FF_VXC )
	{
		Uint32 rgb0 = p_current_read_array[out].rgb;
		Uint32 rgb1 = p_current_read_array[in].rgb;

		int r0 = rgb0 & 0xFF;
		int g0 = ( rgb0 >> 8 ) & 0xFF;
		int b0 = ( rgb0 >> 16 ) & 0xFF;
		int r1 = rgb1 & 0xFF;
		int g1 = ( rgb1 >> 8 ) & 0xFF;
		int b1 = ( rgb1 >> 16 ) & 0xFF;

		r0 += ( ( r1 - r0 ) * mult ) >> 12;
		g0 += ( ( g1 - g0 ) * mult ) >> 12;
		b0 += ( ( b1 - b0 ) * mult ) >> 12;

		// Store this interpolated color.
		p_current_write_array[new_index].rgb = (Uint32)( ( b0 << 16 ) | ( g0 << 8 ) | ( r0 ) );
	}
}





// Clip side (world coordinates) to positive vertical plane.
void ClipNegativeVerticalSide2( Uint32 new_index, Uint32 out, Uint32 in )
{
	RECORDRA;

	if( ( p_current_read_array[out].world_x * -2760 ) > ( p_current_read_array[out].z * 2560 ) )
	{
		printf( "bad out %d %d %d\n", out, p_current_read_array[out].world_x, p_current_read_array[out].z );
	}
	if( ( p_current_read_array[in].world_x * -2760 ) < ( p_current_read_array[in].z * 2560 ) )
	{
		printf( "bad in %d %d %d\n", in, p_current_read_array[in].world_x, p_current_read_array[in].z );
	}

	// Start at a specific multiplier, and increase until the point goes outside the view frustrum, and then use that multiplier.
	int mult = 32;
	int x_delta = p_current_read_array[in].world_x - p_current_read_array[out].world_x;
	int z_delta = p_current_read_array[in].z - p_current_read_array[out].z;
	for( ;; )
	{
		int new_x = p_current_read_array[out].world_x + ( ( x_delta * mult ) >> 12 );
		int new_z = p_current_read_array[out].z + ( ( z_delta * mult ) >> 12 );

		// Has this new point gone outside the frustrum?
		if( ( new_x * -2760 ) > ( new_z * 2560 ) )
		{
			// Yes it has.
			break;
		}
		mult += 32;
	}

	ASSERT( mult <= 4096, "Error" );

	// So now we have the multiplier that takes the point just out of the frustrum.
	int x = p_current_read_array[out].world_x + ( ( ( p_current_read_array[in].world_x - p_current_read_array[out].world_x ) * mult ) >> 12 );
	int y = p_current_read_array[out].world_y + ( ( ( p_current_read_array[in].world_y - p_current_read_array[out].world_y ) * mult ) >> 12 );
	int z = p_current_read_array[out].z + ( ( ( p_current_read_array[in].z - p_current_read_array[out].z ) * mult ) >> 12 );

	// Store the newly calculated x and y values in the write array.
	p_current_write_array[new_index].world_x = x;
	p_current_write_array[new_index].world_y = y;
	p_current_write_array[new_index].z = z;

	register Uint32 flags = *pClipFace;

	// If the face is texture mapped, we need to clip the UV coordinates too.
	if( flags & ( FF_TEX | FF_ARB ) )
	{
		int u0 = ( p_current_read_array[out].uv ) & 0xFF;
		int v0 = ( p_current_read_array[out].uv ) >> 8;
		int u1 = ( p_current_read_array[in].uv ) & 0xFF;
		int v1 = ( p_current_read_array[in].uv ) >> 8;

		int uc = u0 + ( ( ( u1 - u0 ) * mult ) >> 12 );
		int vc = v0 + ( ( ( v1 - v0 ) * mult ) >> 12 );

		// Store this interpolated UV.
		p_current_write_array[new_index].uv = (Uint32)( (Uint16)uc | ( (Uint16)vc << 8 ) );
	}

	// If the face is vertex colored, we need to clip the rgb values too.
	if( flags & FF_VXC )
	{
		Uint32 rgb0 = p_current_read_array[out].rgb;
		Uint32 rgb1 = p_current_read_array[in].rgb;

		int r0 = rgb0 & 0xFF;
		int g0 = ( rgb0 >> 8 ) & 0xFF;
		int b0 = ( rgb0 >> 16 ) & 0xFF;
		int r1 = rgb1 & 0xFF;
		int g1 = ( rgb1 >> 8 ) & 0xFF;
		int b1 = ( rgb1 >> 16 ) & 0xFF;

		r0 += ( ( r1 - r0 ) * mult ) >> 12;
		g0 += ( ( g1 - g0 ) * mult ) >> 12;
		b0 += ( ( b1 - b0 ) * mult ) >> 12;

		// Store this interpolated color.
		p_current_write_array[new_index].rgb = (Uint32)( ( b0 << 16 ) | ( g0 << 8 ) | ( r0 ) );
	}
}












// Clip side (world coordinates) to positive horizontal plane.
void ClipPositiveHorizontalSide2( Uint32 new_index, Uint32 out, Uint32 in )
{
	RECORDRA;

	if( ( p_current_read_array[out].world_y * 2760 ) > ( p_current_read_array[out].z * 1200 ) )
	{
		printf( "bad out %d %d %d\n", out, p_current_read_array[out].world_y, p_current_read_array[out].z );
	}
	if( ( p_current_read_array[in].world_y * 2760 ) < ( p_current_read_array[in].z * 1200 ) )
	{
		printf( "bad in %d %d %d\n", in, p_current_read_array[in].world_y, p_current_read_array[in].z );
	}

	// Start at a specific multiplier, and increase until the point goes outside the view frustrum, and then use that multiplier.
	int mult = 32;
	int y_delta = p_current_read_array[in].world_y - p_current_read_array[out].world_y;
	int z_delta = p_current_read_array[in].z - p_current_read_array[out].z;
