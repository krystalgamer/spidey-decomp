	{
		y0 = (0-z0)*(y1-y0)/(z1-z0)+y0;
		z0 = 0;
	}
	if (z1>511)
	{
		y1 = (511-z0)*(y1-y0)/(z1-z0)+y0;
		z1 = 511;
	}

	if (y0>y1)
	{
		t = z0;
		z0=z1;
		z1=t;
		t = y0;
		y0=y1;
		y1=t;
	}

	if (y1<0 || y0>239)
		return;
	if (y0<0)
