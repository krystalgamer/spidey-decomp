void debugLineXZ( int x0, int y0, int x1, int y1, int Color )
{
	RECORDRA;

	x0 /= 4;
	x1 /= 4;
	y0 /= 4;
	y1 /= 4;

	x0 += 256;		
	x1 += 256;		

	y0 = -y0 + 160;
	y1 = -y1 + 160;

	// ignore points
	if (x0==x1 && y0==y1)
		return;

	// Clipping
	int t;   // temp var for swapping

	if (x0>x1)
	{
		t = x0;
		x0=x1;
		x1=t;
		t = y0;
		y0=y1;
		y1=t;
	}

	if (x1<0 || x0>511)
		return;

	if (x0<0)
	{
		y0 = (0-x0)*(y1-y0)/(x1-x0)+y0;
		x0 = 0;
	}
	if (x1>511)
	{
		y1 = (511-x0)*(y1-y0)/(x1-x0)+y0;
		x1 = 511;
	}

	if (y0>y1)
	{
		t = x0;
		x0=x1;
		x1=t;
		t = y0;
		y0=y1;
		y1=t;
	}

	if (y1<0 || y0>239)
		return;
	if (y0<0)
	{
		x0 = (0-y0)*(x1-x0)/(y1-y0)+x0;
		y0 = 0;
	}
	if (y1>239)
	{
		x1 = (239-y0)*(x1-x0)/(y1-y0)+x0;
		y1 = 239;
	}
	
   LINE_F2* aline=(LINE_F2*)pPoly;
	Uint8 *newppoly=(Uint8*)(aline+1);
	if (newppoly>PolyBufferEnd) return;
   pPoly=(Uint32*)newppoly;

   aline->tag=0x03000000;
	*(Uint32*)&aline->r0=0x42000000 + Color;
	aline->x0=x0;
	aline->y0=y0;
	aline->x1=x1;
	aline->y1=y1;
	addPrim( pDoubleBuffer->OrderingTable, aline );
}


void debugLineYZ( int y0, int z0, int y1, int z1, int Color )
{
	RECORDRA;

	y0 /= 4;
