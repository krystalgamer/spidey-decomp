	p_current_write_array[new_index].z = z;

	register Uint32 flags = *pClipFace;

	// If the face is texture mapped, we need to clip the UV coordinates too.
	if( flags & ( FF_TEX | FF_ARB ) )
	{
		int u0 = ( p_current_read_array[out].uv ) & 0xFF;
		int v0 = ( p_current_read_array[out].uv ) >> 8;
		int u1 = ( p_current_read_array[in].uv ) & 0xFF;
		int v1 = ( p_current_read_array[in].uv ) >> 8;

		int uc = u0 + ( ( ( u1 - u0 ) * mult ) >> 12 );
		int vc = v0 + ( ( ( v1 - v0 ) * mult ) >> 12 );

		// Store this interpolated UV.
		p_current_write_array[new_index].uv = (Uint32)( (Uint16)uc | ( (Uint16)vc << 8 ) );
	}

	// If the face is vertex colored, we need to clip the rgb values too.
	if( flags & FF_VXC )
	{
		Uint32 rgb0 = p_current_read_array[out].rgb;
		Uint32 rgb1 = p_current_read_array[in].rgb;

		int r0 = rgb0 & 0xFF;
		int g0 = ( rgb0 >> 8 ) & 0xFF;
		int b0 = ( rgb0 >> 16 ) & 0xFF;
		int r1 = rgb1 & 0xFF;
		int g1 = ( rgb1 >> 8 ) & 0xFF;
		int b1 = ( rgb1 >> 16 ) & 0xFF;

		r0 += ( ( r1 - r0 ) * mult ) >> 12;
		g0 += ( ( g1 - g0 ) * mult ) >> 12;
		b0 += ( ( b1 - b0 ) * mult ) >> 12;

		// Store this interpolated color.
		p_current_write_array[new_index].rgb = (Uint32)( ( b0 << 16 ) | ( g0 << 8 ) | ( r0 ) );
	}
}







// Clip side (world coordinates) to negative horizontal plane.
void ClipNegativeHorizontalSide2( Uint32 new_index, Uint32 out, Uint32 in )
{
	RECORDRA;

	if( ( p_current_read_array[out].world_y * -2760 ) > ( p_current_read_array[out].z * 1200 ) )
	{
		printf( "bad out %d %d %d\n", out, p_current_read_array[out].world_y, p_current_read_array[out].z );
	}
	if( ( p_current_read_array[in].world_y * -2760 ) < ( p_current_read_array[in].z * 1200 ) )
	{
		printf( "bad in %d %d %d\n", in, p_current_read_array[in].world_y, p_current_read_array[in].z );
	}

	// Start at a specific multiplier, and increase until the point goes outside the view frustrum, and then use that multiplier.
	int mult = 32;
	int x_delta = p_current_read_array[in].world_y - p_current_read_array[out].world_y;
	int z_delta = p_current_read_array[in].z - p_current_read_array[out].z;
	for( ;; )
	{
		int new_y = p_current_read_array[out].world_y + ( ( x_delta * mult ) >> 12 );
		int new_z = p_current_read_array[out].z + ( ( z_delta * mult ) >> 12 );

		// Has this new point gone outside the frustrum?
		if( ( new_y * -2760 ) > ( new_z * 1200 ) )
		{
			// Yes it has.
			break;
		}
		mult += 32;
	}

	ASSERT( mult <= 4096, "Error" );

	// So now we have the multiplier that takes the point just out of the frustrum.
	int x = p_current_read_array[out].world_x + ( ( ( p_current_read_array[in].world_x - p_current_read_array[out].world_x ) * mult ) >> 12 );
	int y = p_current_read_array[out].world_y + ( ( ( p_current_read_array[in].world_y - p_current_read_array[out].world_y ) * mult ) >> 12 );
	int z = p_current_read_array[out].z + ( ( ( p_current_read_array[in].z - p_current_read_array[out].z ) * mult ) >> 12 );

	// Store the newly calculated x and y values in the write array.
	p_current_write_array[new_index].world_x = x;
	p_current_write_array[new_index].world_y = y;
	p_current_write_array[new_index].z = z;

	register Uint32 flags = *pClipFace;

	// If the face is texture mapped, we need to clip the UV coordinates too.
	if( flags & ( FF_TEX | FF_ARB ) )
	{
		int u0 = ( p_current_read_array[out].uv ) & 0xFF;
		int v0 = ( p_current_read_array[out].uv ) >> 8;
		int u1 = ( p_current_read_array[in].uv ) & 0xFF;
		int v1 = ( p_current_read_array[in].uv ) >> 8;

		int uc = u0 + ( ( ( u1 - u0 ) * mult ) >> 12 );
		int vc = v0 + ( ( ( v1 - v0 ) * mult ) >> 12 );

		// Store this interpolated UV.
		p_current_write_array[new_index].uv = (Uint32)( (Uint16)uc | ( (Uint16)vc << 8 ) );
	}

	// If the face is vertex colored, we need to clip the rgb values too.
	if( flags & FF_VXC )
	{
		Uint32 rgb0 = p_current_read_array[out].rgb;
		Uint32 rgb1 = p_current_read_array[in].rgb;

		int r0 = rgb0 & 0xFF;
		int g0 = ( rgb0 >> 8 ) & 0xFF;
		int b0 = ( rgb0 >> 16 ) & 0xFF;
		int r1 = rgb1 & 0xFF;
		int g1 = ( rgb1 >> 8 ) & 0xFF;
		int b1 = ( rgb1 >> 16 ) & 0xFF;

		r0 += ( ( r1 - r0 ) * mult ) >> 12;
		g0 += ( ( g1 - g0 ) * mult ) >> 12;
		b0 += ( ( b1 - b0 ) * mult ) >> 12;

		// Store this interpolated color.
		p_current_write_array[new_index].rgb = (Uint32)( ( b0 << 16 ) | ( g0 << 8 ) | ( r0 ) );
	}
}


















void RenderClippedPoly2( int num_verts )
{
	RECORDRA;

	// Perform perspective divide.
	for( int i = 0; i < num_verts; ++i )
	{
		int x = p_current_read_array[i].world_x;
		int y = p_current_read_array[i].world_y;
		int z = p_current_read_array[i].z;

		p_current_read_array[i].X = ( ( x * pCurrentViewport->Zoom ) / z ) + 256;
		p_current_read_array[i].Y = ( ( y * pCurrentViewport->Zoom ) / z ) + 120;

		if( i == 2 )
		{
			// Can do trivial nclip reject here.
			int opz;
			gte_ldsxy0( *(Uint32 *)&p_current_read_array[0].X );
			gte_ldsxy1( *(Uint32 *)&p_current_read_array[1].X );
			gte_ldsxy2( *(Uint32 *)&p_current_read_array[2].X );
			gte_nclip();
			gte_stopz( &opz );
			if( opz < 0 ) return;
		}
	}

	if( T[4] == 1 )
	{
		for( int i = 0; i < num_verts - 1; ++i )
		{
			debugLineXZ( p_current_read_array[i].world_x, p_current_read_array[i].z, p_current_read_array[i + 1].world_x, p_current_read_array[i + 1].z, 0x00404000 );
		}
		debugLineXZ( p_current_read_array[num_verts - 1].world_x, p_current_read_array[num_verts - 1].z, p_current_read_array[0].world_x, p_current_read_array[0].z, 0x00404000 );
	}
	else if( T[4] == 2 )
	{
		for( int i = 0; i < num_verts - 1; ++i )
		{
			debugLineYZ( p_current_read_array[i].world_y, p_current_read_array[i].z, p_current_read_array[i + 1].world_y, p_current_read_array[i + 1].z, 0x00404000 );
		}
		debugLineYZ( p_current_read_array[num_verts - 1].world_y, p_current_read_array[num_verts - 1].z, p_current_read_array[0].world_y, p_current_read_array[0].z, 0x00404000 );
	}

	switch( num_verts )
	{
		case 3:
		{
			// Tri [0,1,2].
			RenderClippedTri2( 0, 1, 2 );
			break;
		}

		case 4:
		{
			// Quad [0,1,3,2].
			RenderClippedQuad2( 0, 1, 3, 2 );
			break;
		}

		case 5:
		{
			// Tri [0,1,2] and quad [0,2,4,3].
			RenderClippedTri2( 0, 1, 2 );
			RenderClippedQuad2( 0, 2, 4, 3 );
			break;
		}

		case 6:
		{
			// Two quads [0,1,3,2] and [0,3,5,4].
			RenderClippedQuad2( 0, 1, 3, 2 );
			RenderClippedQuad2( 0, 3, 5, 4 );
			break;
		}

		case 7:
		{
			// Two quads [0,1,3,2] and [0,3,5,4] and a tri [0,5,6].
			RenderClippedQuad2( 0, 1, 3, 2 );
			RenderClippedQuad2( 0, 3, 5, 4 );
			RenderClippedTri2( 0, 5, 6 );
			break;
		}

		default:
		{
			printf( "vertices: %d\n", num_verts );
			break;
		}
	}
}


const int SUBDIV_LEVEL = 4;


void RenderClippedTri2( int v0, int v1, int v2 )
{
	RECORDRA;

	if( T[2] )
	{
	   POLY_F3* aline=(POLY_F3*)pPoly;
		Uint8 *newppoly=(Uint8*)(aline+1);
		if (newppoly>PolyBufferEnd) return;
	   pPoly=(Uint32*)newppoly;
	
		setPolyF3( aline );

		aline->r0 = Rnd( 256 );
		aline->g0 = Rnd( 256 );
		aline->b0 = Rnd( 256 );

		*(Uint32 *)&( aline->x0 ) = *(Uint32 *)&( p_current_read_array[v0].X );
		*(Uint32 *)&( aline->x1 ) = *(Uint32 *)&( p_current_read_array[v1].X );
		*(Uint32 *)&( aline->x2 ) = *(Uint32 *)&( p_current_read_array[v2].X );
		addPrim( pDoubleBuffer->OrderingTable, aline );
	}
	else
	{
		// Pointer to current color table.
		Uint32 *p_stored_color_table = pColourTable;
		Uint32 flags = *pClipFace;

		bool subdiv = true;

		if( subdiv )
		{
			Uint32 dummy_face[SUBDIV_LEVEL * SUBDIV_LEVEL][8];
			Uint32 dummy_color_table[( SUBDIV_LEVEL * SUBDIV_LEVEL ) - 1];
			Uint16 uv[( SUBDIV_LEVEL * SUBDIV_LEVEL ) - 1];

			Uint32 face_mapping[] = {	0x000102, 0x010304, 0x010402, 0x020405, 0x030607, 0x030704, 0x040708, 0x040805,
												0x050809, 0x060A0B, 0x060B07, 0x070B0C, 0x070C08, 0x080C0D, 0x080D09, 0x090D0E };

			int index = 128;

			for( int i = 0; i <= SUBDIV_LEVEL; ++i )
			{
				// Calculate first axis delta.
				int		x_start, y_start, z_start;
				int		x_delta, y_delta, z_delta;
				Uint32	uv_start, uv_end;
				Uint32	rgb_start, rgb_end;

				// Need to work out start and end points along v0->v1 and v0->v2.
				int end;

				if( i == 0 )
				{
					x_start	= p_current_read_array[v0].world_x;
					y_start	= p_current_read_array[v0].world_y;
					z_start	= p_current_read_array[v0].z;
					x_delta	= y_delta = z_delta = 0;
	
					uv_start = p_current_read_array[v0].uv;
//					u_start	= p_current_read_array[v0].uv & 0xFF;
//					v_start	= p_current_read_array[v0].uv >> 8;
//					u_delta	= v_delta = 0;
	
					if( flags & FF_VXC )
					{
						rgb_start = rgb_end = p_current_read_array[v0].rgb;
//						r_start	= p_current_read_array[v0]. rgb & 0xFF;
//						g_start	= ( ( p_current_read_array[v0].rgb >> 8 ) & 0xFF );
//						b_start	= ( ( p_current_read_array[v0].rgb >> 16 ) & 0xFF );
//						r_delta	= g_delta = b_delta = 0;
					}
				}
				else
				{
					x_start	= ( p_current_read_array[v0].world_x << 12 ) + ( ( ( ( p_current_read_array[v1].world_x << 12 ) - ( p_current_read_array[v0].world_x << 12 ) ) * i ) / SUBDIV_LEVEL );
					end		= ( p_current_read_array[v0].world_x << 12 ) + ( ( ( ( p_current_read_array[v2].world_x << 12 ) - ( p_current_read_array[v0].world_x << 12 ) ) * i ) / SUBDIV_LEVEL );
					x_delta	= ( end - x_start ) / i;
					y_start	= ( p_current_read_array[v0].world_y << 12 ) + ( ( ( ( p_current_read_array[v1].world_y << 12 ) - ( p_current_read_array[v0].world_y << 12 ) ) * i ) / SUBDIV_LEVEL );
					end		= ( p_current_read_array[v0].world_y << 12 ) + ( ( ( ( p_current_read_array[v2].world_y << 12 ) - ( p_current_read_array[v0].world_y << 12 ) ) * i ) / SUBDIV_LEVEL );
					y_delta	= ( end - y_start ) / i;
					z_start	= ( p_current_read_array[v0].z << 12 ) + ( ( ( ( p_current_read_array[v1].z << 12 ) - ( p_current_read_array[v0].z << 12 ) ) * i ) / SUBDIV_LEVEL );
					end		= ( p_current_read_array[v0].z << 12 ) + ( ( ( ( p_current_read_array[v2].z << 12 ) - ( p_current_read_array[v0].z << 12 ) ) * i ) / SUBDIV_LEVEL );
					z_delta	= ( end - z_start ) / i;
					x_start >>= 12;
					y_start >>= 12;
					z_start >>= 12;
	
					// Load up the depth queuing value.
					gte_lddp( ( i * 4096 ) / SUBDIV_LEVEL );

					gte_ldrgb( &p_current_read_array[v0].uv );
					gte_SetFarColor( p_current_read_array[v1].uv & 0xFF, ( p_current_read_array[v1].uv >> 8 ) & 0xFF, 0 );
					gte_dpcs();
					gte_strgb( &uv_start );
	
					gte_ldrgb( &p_current_read_array[v0].uv );
					gte_SetFarColor( p_current_read_array[v2].uv & 0xFF, ( p_current_read_array[v2].uv >> 8 ) & 0xFF, 0 );
					gte_dpcs();
					gte_strgb( &uv_end );

					if( flags & FF_VXC )
					{
						gte_ldrgb( &p_current_read_array[v0].rgb );
						gte_SetFarColor( p_current_read_array[v1].rgb & 0xFF, ( p_current_read_array[v1].rgb >> 8 ) & 0xFF, ( p_current_read_array[v1].rgb >> 16 ) & 0xFF );
						gte_dpcs();
						gte_strgb( &rgb_start );

						gte_ldrgb( &p_current_read_array[v0].rgb );
						gte_SetFarColor( p_current_read_array[v2].rgb & 0xFF, ( p_current_read_array[v2].rgb >> 8 ) & 0xFF, ( p_current_read_array[v2].rgb >> 16 ) & 0xFF );
						gte_dpcs();
						gte_strgb( &rgb_end );
					}
				}

				for( int j = 0; j <= i; ++j )
				{
					RotatedVertices[index].Special = 0;

					// World coordinate interpolation.
					RotatedVertices[index].x = x_start + ( ( j * x_delta ) >> 12 );
					RotatedVertices[index].y = y_start + ( ( j * y_delta ) >> 12 );
	
					// Z world coordinate plus outcode.
					ProjectedVertices[index].z = z_start + ( ( j * z_delta ) >> 12 );
					ProjectedVertices[index].Outcode = 0xFF00U;

					// UV interpolation.
					gte_lddp( ( j * 4096 ) / i );
					gte_ldrgb( &uv_start );
					gte_SetFarColor( uv_end & 0xFF, ( uv_end >> 8 ) & 0xFF, 0 );
					gte_dpcs();
					Uint32 uv_temp;
					gte_strgb( &uv_temp );
					uv[index - 128] = (Uint16)uv_temp;

					// RGB interpolation.
					if( flags & FF_VXC )
					{
						gte_lddp( ( j * 4096 ) / i );
						gte_ldrgb( &rgb_start );
						gte_SetFarColor( rgb_end & 0xFF, ( rgb_end >> 8 ) & 0xFF, ( rgb_end >> 16 ) & 0xFF );
						gte_dpcs();
						gte_strgb( &dummy_color_table[index - 128] );
					}

//					printf( "clipped: %d ( %d, %d, %d )\n", index - 128, RotatedVertices[index].x, RotatedVertices[index].y, ProjectedVertices[index].z );

					// Perspective projection.
					ProjectedVertices[index].X = ( ( RotatedVertices[index].x * pCurrentViewport->Zoom ) / ProjectedVertices[index].z ) + 256;
					ProjectedVertices[index].Y = ( ( RotatedVertices[index].y * pCurrentViewport->Zoom ) / ProjectedVertices[index].z ) + 120;

//					printf( "clipped: %d ( %d, %d )\n", index - 128, ProjectedVertices[index].X, ProjectedVertices[index].Y );
					
					++index;
				}
			}

			// Ensure flags indicate that this is a tri.
			flags |= FF_TRI;
			flags &= ~FF_SDV;

			// Set up face array.
			index = 0;
			for( int i = 0; i < ( SUBDIV_LEVEL * SUBDIV_LEVEL ); ++i )
			{
				// First word consists of face flags, and length of face (which assumes textured at this stage).
				dummy_face[index][0] = 0x00200000UL | ( flags & 0xFFFFUL );

				// Second word contains vertex indices.
				Uint32 first			= 128 + ( ( face_mapping[index] >> 16 ) & 0xFF );
				Uint32 second			= 128 + ( ( face_mapping[index] >> 8 ) & 0xFF );
				Uint32 third			= 128 + ( ( face_mapping[index] >> 0 ) & 0xFF );
				dummy_face[index][1]	= first | ( second << 8 ) | ( third << 16 ) | ( third << 24 );

				// Third word is RGB0 for face color (in which case just copy from actual face),
				// or 4 color table indices. In this case, we have to construct the dummy color table.
				if( flags & FF_VXC )
				{
					dummy_face[index][2] = ( first - 128 ) | ( ( second - 128 ) << 8 ) | ( ( third - 128 ) << 16 );
					pColourTable = dummy_color_table;
				}
				else
					dummy_face[index][2] = pClipFace[2];

				// Fourth word is normal index and user face flags - just copy directly from actual face.
				dummy_face[index][3] = pClipFace[3];
					
				// Fifth word is uv0 and CLUT (just copy directly from actual face).
  				dummy_face[index][4] = uv[first - 128] | ( pClipFace[4] & 0xFFFF0000UL );
					
				// Sixth word is uv1 and TPAGE (just copy directly from actual face).
				dummy_face[index][5] = uv[second - 128] | ( pClipFace[5] & 0xFFFF0000UL );
				
				// Seventh word is uv2.
				dummy_face[index][6] = ( uv[third - 128] & 0x0000FFFFUL );
				
				// Eighth word is texture window.
				dummy_face[index][7] = pClipFace[7];

				++index;
			}

			// Render the clipped, subdivided poly.
			M3dAsm_ProcessPolys( &dummy_face[0][0], NULL, 16 );
		}
		else
		{
#			if 0
			Uint32 dummy_face[8];
			Uint32 dummy_color_table[3];
	
			// Set up Rotated/ProjectedVertices[128,130] as the 3 clipped vertices we will index.
			*(Uint32 *)&( ProjectedVertices[128].X ) = *(Uint32 *)&( p_current_read_array[v0].X );
			*(Uint32 *)&( ProjectedVertices[128].z ) = 0xFF000000UL | p_current_read_array[v0].z;
			*(Uint32 *)&( ProjectedVertices[129].X ) = *(Uint32 *)&( p_current_read_array[v1].X );
			*(Uint32 *)&( ProjectedVertices[129].z ) = 0xFF000000UL | p_current_read_array[v1].z;
			*(Uint32 *)&( ProjectedVertices[130].X ) = *(Uint32 *)&( p_current_read_array[v2].X );
			*(Uint32 *)&( ProjectedVertices[130].z ) = 0xFF000000UL | p_current_read_array[v2].z;
		
			RotatedVertices[128].x = p_current_read_array[v0].world_x;
			RotatedVertices[128].y = p_current_read_array[v0].world_y;
			RotatedVertices[128].Special = 0;
			RotatedVertices[129].x = p_current_read_array[v1].world_x;
			RotatedVertices[129].y = p_current_read_array[v1].world_y;
			RotatedVertices[129].Special = 0;
			RotatedVertices[130].x = p_current_read_array[v2].world_x;
			RotatedVertices[130].y = p_current_read_array[v2].world_y;
			RotatedVertices[130].Special = 0;
		
			// Ensure flags indicate that this is a tri.
			flags |= FF_TRI;
			flags &= ~FF_SDV;
		
			// First word consists of face flags, and length of face (which assumes textured at this stage).
			dummy_face[0] = 0x001C0000UL | ( flags & 0xFFFFUL );
		
			// Second word contains vertex indices (3rd vertex is doubled up).
			dummy_face[1] = 0x82828180;
			
			// Third word is RGB0 for face color (in which case just copy from actual face),
			// or 4 color table indices. In this case, we have to construct the dummy color table.
			if( flags & FF_VXC )
			{
				dummy_color_table[0] = p_current_read_array[v0].rgb;
				dummy_color_table[1] = p_current_read_array[v1].rgb;
				dummy_color_table[2] = p_current_read_array[v2].rgb;
				dummy_face[2] = 0x00020100;
				pColourTable = dummy_color_table;
			}
			else
				dummy_face[2] = pClipFace[2];
		
			// Fourth word is normal index and user face flags - just copy directly from actual face.
			dummy_face[3] = pClipFace[3];
			
			// Fifth word is uv0 and CLUT (just copy directly from actual face).
			dummy_face[4] = p_current_read_array[v0].uv | ( pClipFace[4] & 0xFFFF0000 );
			
			// Sixth word is uv1 and TPAGE (just copy directly from actual face).
			dummy_face[5] = p_current_read_array[v1].uv | ( pClipFace[5] & 0xFFFF0000 );
		
			// Seventh word is uv2 and uv3.
			dummy_face[6] = p_current_read_array[v2].uv & 0x0000FFFFUL;
		
			// Eighth word is texture window.
			dummy_face[7] = pClipFace[7];
		
			// Render the clipped poly.
			M3dAsm_ProcessPolys( dummy_face, NULL, 1 );
#			endif
		}

		// Restore the colour table pointer.	
		pColourTable = p_stored_color_table;
	}
}



void RenderClippedQuad2( int v0, int v1, int v2, int v3 )
{
	RECORDRA;

	if( T[2] )
	{
	   POLY_F4* aline=(POLY_F4*)pPoly;
		Uint8 *newppoly=(Uint8*)(aline+1);
		if (newppoly>PolyBufferEnd) return;
	   pPoly=(Uint32*)newppoly;
	
		setPolyF4( aline );

		aline->r0 = Rnd( 256 );
		aline->g0 = Rnd( 256 );
		aline->b0 = Rnd( 256 );

		*(Uint32 *)&( aline->x0 ) = *(Uint32 *)&( p_current_read_array[v0].X );
		*(Uint32 *)&( aline->x1 ) = *(Uint32 *)&( p_current_read_array[v1].X );
		*(Uint32 *)&( aline->x2 ) = *(Uint32 *)&( p_current_read_array[v2].X );
		*(Uint32 *)&( aline->x3 ) = *(Uint32 *)&( p_current_read_array[v3].X );
		addPrim( pDoubleBuffer->OrderingTable, aline );
	}
	else
	{
		ASSERT( pClipModel->NumVertices <= 128, "vertex overflow" );

		// Pointer to current color table.
		Uint32 *p_stored_color_table = pColourTable;
		Uint32 flags = *pClipFace;

		bool subdiv = true;

		if( subdiv )
		{
//			printf( "original: 0 ( %d, %d, %d )\n", p_current_read_array[v0].world_x, p_current_read_array[v0].world_y, p_current_read_array[v0].z );
//			printf( "original: 1 ( %d, %d, %d )\n", p_current_read_array[v1].world_x, p_current_read_array[v1].world_y, p_current_read_array[v1].z );
//			printf( "original: 2 ( %d, %d, %d )\n", p_current_read_array[v2].world_x, p_current_read_array[v2].world_y, p_current_read_array[v2].z );
//			printf( "original: 3 ( %d, %d, %d )\n", p_current_read_array[v3].world_x, p_current_read_array[v3].world_y, p_current_read_array[v3].z );

			Uint32 dummy_face[SUBDIV_LEVEL * SUBDIV_LEVEL][8];
			Uint32 dummy_color_table[( SUBDIV_LEVEL + 1 ) * ( SUBDIV_LEVEL + 1 )];
			Uint16 uv[( SUBDIV_LEVEL + 1 ) * ( SUBDIV_LEVEL + 1 )];

			for( int i = 0; i <= SUBDIV_LEVEL; ++i )
			{
				// Calculate first axis delta.
				int x_start, y_start, z_start;
				int u_start, v_start;
				int r_start, g_start, b_start;
				int x_delta, y_delta, z_delta;
				int u_delta, v_delta;
				int r_delta, g_delta, b_delta;

				// Need to work out start and end points along v0->v2 and v1->v3.
				int end;

				x_start	= ( p_current_read_array[v0].world_x << 12 ) + ( ( ( ( p_current_read_array[v2].world_x << 12 ) - ( p_current_read_array[v0].world_x << 12 ) ) * i ) / SUBDIV_LEVEL );
				end		= ( p_current_read_array[v1].world_x << 12 ) + ( ( ( ( p_current_read_array[v3].world_x << 12 ) - ( p_current_read_array[v1].world_x << 12 ) ) * i ) / SUBDIV_LEVEL );
				x_delta	= ( end - x_start ) / SUBDIV_LEVEL;
				y_start	= ( p_current_read_array[v0].world_y << 12 ) + ( ( ( ( p_current_read_array[v2].world_y << 12 ) - ( p_current_read_array[v0].world_y << 12 ) ) * i ) / SUBDIV_LEVEL );
				end		= ( p_current_read_array[v1].world_y << 12 ) + ( ( ( ( p_current_read_array[v3].world_y << 12 ) - ( p_current_read_array[v1].world_y << 12 ) ) * i ) / SUBDIV_LEVEL );
				y_delta	= ( end - y_start ) / SUBDIV_LEVEL;
				z_start	= ( p_current_read_array[v0].z << 12 ) + ( ( ( ( p_current_read_array[v2].z << 12 ) - ( p_current_read_array[v0].z << 12 ) ) * i ) / SUBDIV_LEVEL );
				end		= ( p_current_read_array[v1].z << 12 ) + ( ( ( ( p_current_read_array[v3].z << 12 ) - ( p_current_read_array[v1].z << 12 ) ) * i ) / SUBDIV_LEVEL );
				z_delta	= ( end - z_start ) / SUBDIV_LEVEL;
				x_start >>= 12;
				y_start >>= 12;
				z_start >>= 12;

				u_start	= ( ( p_current_read_array[v0].uv & 0xFF ) << 12 ) + ( ( ( ( ( p_current_read_array[v2].uv & 0xFF ) << 12 ) - ( ( p_current_read_array[v0].uv & 0xFF ) << 12 ) ) * i ) / SUBDIV_LEVEL );
				end		= ( ( p_current_read_array[v1].uv & 0xFF ) << 12 ) + ( ( ( ( ( p_current_read_array[v3].uv & 0xFF ) << 12 ) - ( ( p_current_read_array[v1].uv & 0xFF ) << 12 ) ) * i ) / SUBDIV_LEVEL );
				u_delta	= ( end - u_start ) / SUBDIV_LEVEL;
				v_start	= ( ( p_current_read_array[v0].uv >> 8 ) << 12 ) + ( ( ( ( ( p_current_read_array[v2].uv >> 8 ) << 12 ) - ( ( p_current_read_array[v0].uv >> 8 ) << 12 ) ) * i ) / SUBDIV_LEVEL );
				end		= ( ( p_current_read_array[v1].uv >> 8 ) << 12 ) + ( ( ( ( ( p_current_read_array[v3].uv >> 8 ) << 12 ) - ( ( p_current_read_array[v1].uv >> 8 ) << 12 ) ) * i ) / SUBDIV_LEVEL );
				v_delta	= ( end - v_start ) / SUBDIV_LEVEL;
				u_start >>= 12;
				v_start >>= 12;

				if( flags & FF_VXC )
				{
					r_start	= ( ( p_current_read_array[v0].rgb & 0xFF ) << 12 ) + ( ( ( ( ( p_current_read_array[v2].rgb & 0xFF ) << 12 ) - ( ( p_current_read_array[v0].rgb & 0xFF ) << 12 ) ) * i ) / SUBDIV_LEVEL );
					end		= ( ( p_current_read_array[v1].rgb & 0xFF ) << 12 ) + ( ( ( ( ( p_current_read_array[v3].rgb & 0xFF ) << 12 ) - ( ( p_current_read_array[v1].rgb & 0xFF ) << 12 ) ) * i ) / SUBDIV_LEVEL );
					r_delta	= ( end - r_start ) / SUBDIV_LEVEL;
					g_start	= ( ( ( p_current_read_array[v0].rgb >> 8 ) & 0xFF ) << 12 ) + ( ( ( ( ( ( p_current_read_array[v2].rgb >> 8 ) & 0xFF ) << 12 ) - ( ( ( p_current_read_array[v0].rgb >> 8 ) & 0xFF ) << 12 ) ) * i ) / SUBDIV_LEVEL );
					end		= ( ( ( p_current_read_array[v1].rgb >> 8 ) & 0xFF ) << 12 ) + ( ( ( ( ( ( p_current_read_array[v3].rgb >> 8 ) & 0xFF ) << 12 ) - ( ( ( p_current_read_array[v1].rgb >> 8 ) & 0xFF ) << 12 ) ) * i ) / SUBDIV_LEVEL );
					g_delta	= ( end - g_start ) / SUBDIV_LEVEL;
					b_start	= ( ( ( p_current_read_array[v0].rgb >> 16 ) & 0xFF ) << 12 ) + ( ( ( ( ( ( p_current_read_array[v2].rgb >> 16 ) & 0xFF ) << 12 ) - ( ( ( p_current_read_array[v0].rgb >> 16 ) & 0xFF ) << 12 ) ) * i ) / SUBDIV_LEVEL );
					end		= ( ( ( p_current_read_array[v1].rgb >> 16 ) & 0xFF ) << 12 ) + ( ( ( ( ( ( p_current_read_array[v3].rgb >> 16 ) & 0xFF ) << 12 ) - ( ( ( p_current_read_array[v1].rgb >> 16 ) & 0xFF ) << 12 ) ) * i ) / SUBDIV_LEVEL );
					b_delta	= ( end - b_start ) / SUBDIV_LEVEL;
					r_start >>= 12;
					g_start >>= 12;
					b_start >>= 12;
				}

				for( int j = 0; j <= SUBDIV_LEVEL; ++j )
				{
					int index = 128 + ( i * ( SUBDIV_LEVEL + 1 ) ) + j;
					RotatedVertices[index].Special = 0;

					// World coordinate interpolation.
					RotatedVertices[index].x = x_start + ( ( j * x_delta ) >> 12 );
					RotatedVertices[index].y = y_start + ( ( j * y_delta ) >> 12 );
	
					// Z world coordinate plus outcode.
					ProjectedVertices[index].z = z_start + ( ( j * z_delta ) >> 12 );
					ProjectedVertices[index].Outcode = 0xFF00U;

					// UV interpolation.
					int u = u_start + ( ( j * u_delta ) >> 12 );
					int v = v_start + ( ( j * v_delta ) >> 12 );
					uv[index - 128] = u | ( v << 8 );

					// RGB interpolation.
					if( flags & FF_VXC )
					{
						int r = r_start + ( ( j * r_delta ) >> 12 );
						int g = g_start + ( ( j * g_delta ) >> 12 );
						int b = b_start + ( ( j * b_delta ) >> 12 );
						dummy_color_table[index - 128] = r | ( g << 8 ) | ( b << 16 );
					}

//					printf( "clipped: %d ( %d, %d, %d )\n", index - 128, RotatedVertices[index].x, RotatedVertices[index].y, ProjectedVertices[index].z );

					// Perspective projection.
					ProjectedVertices[index].X = ( ( RotatedVertices[index].x * pCurrentViewport->Zoom ) / ProjectedVertices[index].z ) + 256;
					ProjectedVertices[index].Y = ( ( RotatedVertices[index].y * pCurrentViewport->Zoom ) / ProjectedVertices[index].z ) + 120;

//					printf( "clipped: %d ( %d, %d )\n", index - 128, ProjectedVertices[index].X, ProjectedVertices[index].Y );

				}
			}

			// Ensure flags indicate that this is a quad.
			flags &= ~FF_TRI;
			flags &= ~FF_SDV;

			// Set up face array.
			for( int i = 0; i < SUBDIV_LEVEL; ++i )
			{
				for( int j = 0; j < SUBDIV_LEVEL; ++j )
				{
					int index = ( i * SUBDIV_LEVEL ) + j;

					// First word consists of face flags, and length of face (which assumes textured at this stage).
					dummy_face[index][0] = 0x00200000UL | ( flags & 0xFFFFUL );

					// Second word contains vertex indices.
					Uint32 first = 128 + ( i * ( SUBDIV_LEVEL + 1 ) ) + j;
					Uint32 second = first + 1;
					Uint32 third = first + ( SUBDIV_LEVEL + 1 );
					Uint32 fourth = third + 1;
					dummy_face[index][1] = first | ( second << 8 ) | ( third << 16 ) | ( fourth << 24 );

					// Third word is RGB0 for face color (in which case just copy from actual face),
					// or 4 color table indices. In this case, we have to construct the dummy color table.
					if( flags & FF_VXC )
					{
//						dummy_color_table[0] = p_current_read_array[v0].rgb;
//						dummy_color_table[1] = p_current_read_array[v1].rgb;
//						dummy_color_table[2] = p_current_read_array[v2].rgb;
//						dummy_color_table[3] = p_current_read_array[v3].rgb;
//						dummy_face[index][2] = 0x03020100;
						dummy_face[index][2] = ( first - 128 ) | ( ( second - 128 ) << 8 ) | ( ( third - 128 ) << 16 ) | ( ( fourth - 128 ) << 24 );
						pColourTable = dummy_color_table;
					}
					else
						dummy_face[index][2] = pClipFace[2];

					// Fourth word is normal index and user face flags - just copy directly from actual face.
					dummy_face[index][3] = pClipFace[3];
					
					// Fifth word is uv0 and CLUT (just copy directly from actual face).
//					dummy_face[index][4] = p_current_read_array[v0].uv | ( pClipFace[4] & 0xFFFF0000UL );
					dummy_face[index][4] = uv[first - 128] | ( pClipFace[4] & 0xFFFF0000UL );
					
					// Sixth word is uv1 and TPAGE (just copy directly from actual face).
//					dummy_face[index][5] = p_current_read_array[v1].uv | ( pClipFace[5] & 0xFFFF0000UL );
					dummy_face[index][5] = uv[second - 128] | ( pClipFace[5] & 0xFFFF0000UL );
				
					// Seventh word is uv2 and uv3.
//					dummy_face[index][6] = ( p_current_read_array[v2].uv & 0x0000FFFFUL ) | ( p_current_read_array[v3].uv << 16 );
					dummy_face[index][6] = ( uv[third - 128] & 0x0000FFFFUL ) | ( uv[fourth - 128] << 16 );
				
					// Eighth word is texture window.
					dummy_face[index][7] = pClipFace[7];
				}
			}

			// Render the clipped, subdivided poly.
			M3dAsm_ProcessPolys( &dummy_face[0][0], NULL, 16 );
		}
		else
		{
#			if 0
			Uint32 dummy_face[8];
			Uint32 dummy_color_table[4];
			
			// Set up Rotated/ProjectedVertices[128,131] as the 4 clipped vertices we will index.
			*(Uint32 *)&( ProjectedVertices[128].X ) = *(Uint32 *)&( p_current_read_array[v0].X );
			*(Uint32 *)&( ProjectedVertices[128].z ) = 0xFF000000UL | p_current_read_array[v0].z;
			*(Uint32 *)&( ProjectedVertices[129].X ) = *(Uint32 *)&( p_current_read_array[v1].X );
			*(Uint32 *)&( ProjectedVertices[129].z ) = 0xFF000000UL | p_current_read_array[v1].z;
			*(Uint32 *)&( ProjectedVertices[130].X ) = *(Uint32 *)&( p_current_read_array[v2].X );
			*(Uint32 *)&( ProjectedVertices[130].z ) = 0xFF000000UL | p_current_read_array[v2].z;
			*(Uint32 *)&( ProjectedVertices[131].X ) = *(Uint32 *)&( p_current_read_array[v3].X );
			*(Uint32 *)&( ProjectedVertices[131].z ) = 0xFF000000UL | p_current_read_array[v3].z;;
		
			RotatedVertices[128].x = p_current_read_array[v0].world_x;
			RotatedVertices[128].y = p_current_read_array[v0].world_y;
			RotatedVertices[128].Special = 0;
			RotatedVertices[129].x = p_current_read_array[v1].world_x;
			RotatedVertices[129].y = p_current_read_array[v1].world_y;
			RotatedVertices[129].Special = 0;
			RotatedVertices[130].x = p_current_read_array[v2].world_x;
			RotatedVertices[130].y = p_current_read_array[v2].world_y;
			RotatedVertices[130].Special = 0;
			RotatedVertices[131].x = p_current_read_array[v3].world_x;
			RotatedVertices[131].y = p_current_read_array[v3].world_y;
			RotatedVertices[131].Special = 0;
		
			// Ensure flags indicate that this is a quad.
			flags &= ~FF_TRI;
			flags &= ~FF_SDV;
		
			// First word consists of face flags, and length of face (which assumes textured at this stage).
			dummy_face[0] = 0x001C0000UL | ( flags & 0xFFFFUL );
		
			// Second word contains vertex indices.
			dummy_face[1] = 0x83828180UL;
			
			// Third word is RGB0 for face color (in which case just copy from actual face),
			// or 4 color table indices. In this case, we have to construct the dummy color table.
			if( flags & FF_VXC )
			{
				dummy_color_table[0] = p_current_read_array[v0].rgb;
				dummy_color_table[1] = p_current_read_array[v1].rgb;
				dummy_color_table[2] = p_current_read_array[v2].rgb;
				dummy_color_table[3] = p_current_read_array[v3].rgb;
				dummy_face[2] = 0x03020100;
				pColourTable = dummy_color_table;
			}
			else
				dummy_face[2] = pClipFace[2];
		
			// Fourth word is normal index and user face flags - just copy directly from actual face.
			dummy_face[3] = pClipFace[3];
			
			// Fifth word is uv0 and CLUT (just copy directly from actual face).
			dummy_face[4] = p_current_read_array[v0].uv | ( pClipFace[4] & 0xFFFF0000UL );
			
			// Sixth word is uv1 and TPAGE (just copy directly from actual face).
			dummy_face[5] = p_current_read_array[v1].uv | ( pClipFace[5] & 0xFFFF0000UL );
		
			// Seventh word is uv2 and uv3.
			dummy_face[6] = ( p_current_read_array[v2].uv & 0x0000FFFFUL ) | ( p_current_read_array[v3].uv << 16 );
		
			// Eighth word is texture window.
			dummy_face[7] = pClipFace[7];
		
			// Render the clipped poly.
			M3dAsm_ProcessPolys( dummy_face, NULL, 1 );
#			endif
		}
	
		// Restore the colour table pointer.	
		pColourTable = p_stored_color_table;
	}
}

#endif






//	Build	the transform for	a CSuper.
//	This must be called once per frame for	each CSuper, before any
//	geometric stuff is done	on	it.


void M3d_BuildTransform(CSuper *pSuper)
{
	RECORDRA;

	SItem	*pItem =	(SItem *)pSuper;

	if (pSuper->mExtraFlags & EXTRAFLAGS_USEMATRIX)
	{
		#if !SPIDEY		// Spidey builds his mTransform in his AI
		// copy the matrix
		M3dMaths_CopyMat((XMat *)&((CBruce *)pSuper)->mRotationMatrix, (XMat *)&pSuper->mTransform);
		#endif

		#if SK			// skate uses a left-handed set of basis vectors
		// negate the centre column (from up-vec to down-vec)
		pSuper->mTransform.m[0][1] = -pSuper->mTransform.m[0][1];
		pSuper->mTransform.m[1][1] = -pSuper->mTransform.m[1][1];
		pSuper->mTransform.m[2][1] = -pSuper->mTransform.m[2][1];
		#endif
	}
	else
		M3dMaths_RotMatrixYXZ((SVECTOR *)&pItem->Angles, &pSuper->mTransform);

	if	(pItem->Flags & ITEMFLAGS_SCALED)
		M3dMaths_ScaleMatrix(pItem, &pSuper->mTransform);
	pSuper->mTransform.t[0]	= pItem->Position.vx	>>	FRACBITS;
	pSuper->mTransform.t[1]	= pItem->Position.vy	>>	FRACBITS;
	pSuper->mTransform.t[2]	= pItem->Position.vz	>>	FRACBITS;
}

Sint32 BasePhase;

Sint32 uWibble(STexWibVertInfo *pTexWibVertInfo)
{
	RECORDRA;

	Sint16 *pWibbleTable;
	Sint32 Amplitude, Phase;
	int	 Index;

	Amplitude = pTexWibVertInfo->uAmpPhase >> 4;			// get amplitude and phase from 4-bit fields

	if (Amplitude)
	{
		Phase = pTexWibVertInfo->uAmpPhase & 15;
		Index = (BasePhase + (Phase<<(WIBBLETABLESHIFT-4))) & (1<<WIBBLETABLESHIFT)-1;
		pWibbleTable = WibbleTables + (Amplitude<<WIBBLETABLESHIFT);
		return pWibbleTable[Index];
	}

	return 0;
}


Sint32 vWibble(STexWibVertInfo *pTexWibVertInfo)
{
	RECORDRA;

	Sint16 *pWibbleTable;
	Sint32 Amplitude, Phase;
	int	 Index;

	Amplitude = pTexWibVertInfo->vAmpPhase >> 4;			// get amplitude and phase from 4-bit fields

	if (Amplitude)
	{
		Phase = pTexWibVertInfo->vAmpPhase & 15;
		Index = (BasePhase + (Phase<<(WIBBLETABLESHIFT-4))) & (1<<WIBBLETABLESHIFT)-1;
		pWibbleTable = WibbleTables + (Amplitude<<WIBBLETABLESHIFT);

		return pWibbleTable[Index];
	}

	return 0;
}



void M3d_PreprocessWibblyTextures(int Region)
{
	RECORDRA;

	Uint32 *pData, *pPSX, *pFace;
	STexWibItemInfo *pTexWibItemInfo;
	STexWibFaceInfo *pTexWibFaceInfo;
	SItem *pItem;
	SModel *pModel;
	int NumFaces, i;
	Sint32 uScroll,vScroll, TileWidth,TileHeight;
	Sint32 u0,v0,u1,v1,u2,v2,u3,v3,And,Or;

	#if 1 // Used to be if DEBUG
	int Count;
	#endif
   
	// check the region exists
	if (Region == -1)
		return;

	// check there's a texture wibble packet
	pData = PSXRegion[Region].pTexWibData;
	if (!pData)
		return;
	ASSERT(pData[-2]==PK_TEXTUREWIBBLE, "Pointer doesn't point to a texture-wibble packet");

	pPSX = PSXRegion[Region].pPSX;

	while (*pData)
	{
		 // get pointer to wibble info
		pTexWibItemInfo = (STexWibItemInfo *)pData;

		 // get the item and model info
		pItem = (SItem *)((char *)pPSX + pTexWibItemInfo->ItemOffset);

		pTexWibFaceInfo = (STexWibFaceInfo *)(pTexWibItemInfo + 1);
		NumFaces = pTexWibItemInfo->NumFaces;

		if (pItem->Flags & ITEMFLAGS_CULL)
		{
			pData = (Uint32 *)(pTexWibFaceInfo + NumFaces);
			continue;
		}

		pModel=PSXRegion[pItem->Region].ppModels[pItem->Model];
		pFace = (Uint32 *)(pModel->Vertices + pModel->NumVertices + pModel->NumNormals);

		uScroll	  = (Sint32)XblanksNow * (Sint32)pTexWibItemInfo->uVel	>> 4;
		vScroll	  = (Sint32)XblanksNow * (Sint32)pTexWibItemInfo->vVel	>> 4;
		BasePhase  = (Sint32)XblanksNow * pTexWibItemInfo->Frequency		>> (16-WIBBLETABLESHIFT);
      int ZeroUAmplitudes=pTexWibItemInfo->ZeroUAmplitudes;
      int ZeroVAmplitudes=pTexWibItemInfo->ZeroVAmplitudes;

		for (i=0; i<NumFaces; i++,pFace+=FACELEN(pFace),pTexWibFaceInfo++)
		{
			ASSERT(pFace[CFACE_FLAGS]&FACEFLAGS_TEXTURED, "Wibbling a non-textured face");

			ASSERT(!(uScroll||vScroll) || (pFace[CFACE_FLAGS]&FACEFLAGS_TILED), "Scrolling a non-tiled texture");
//			if ((uScroll||vScroll) && !(pFace[CFACE_FLAGS]&FACEFLAGS_TILED))
//				continue;

				// get tile data

			TileWidth  = ((-(pFace[CFACE_TEXWIN] & 0x001F) << 3) & 0xFF) << 8;
			TileHeight = ((-(pFace[CFACE_TEXWIN] & 0x03E0) >> 2) & 0xFF) << 8;

			

				// get initial values

			u0 = pTexWibFaceInfo->p0.u << 8;
			v0 = pTexWibFaceInfo->p0.v << 8;
			u1 = pTexWibFaceInfo->p1.u << 8;
			v1 = pTexWibFaceInfo->p1.v << 8;
			u2 = pTexWibFaceInfo->p2.u << 8;
			v2 = pTexWibFaceInfo->p2.v << 8;
			u3 = pTexWibFaceInfo->p3.u << 8;
			v3 = pTexWibFaceInfo->p3.v << 8;

				// scroll 'em

			if (uScroll)
			{
				u0 += uScroll;
				u1 += uScroll;
				u2 += uScroll;
				u3 += uScroll;
			}

			if (vScroll)
			{
				v0 += vScroll;
				v1 += vScroll;
				v2 += vScroll;
				v3 += vScroll;
			}

				// wibble 'em
            // ... but only if need be.
			if (!ZeroUAmplitudes)
         {
				u0 += uWibble(&pTexWibFaceInfo->p0);
				u1 += uWibble(&pTexWibFaceInfo->p1);
				u2 += uWibble(&pTexWibFaceInfo->p2);
				u3 += uWibble(&pTexWibFaceInfo->p3);
         }
			if (!ZeroVAmplitudes)
         {
				v0 += vWibble(&pTexWibFaceInfo->p0);
				v1 += vWibble(&pTexWibFaceInfo->p1);
				v2 += vWibble(&pTexWibFaceInfo->p2);
				v3 += vWibble(&pTexWibFaceInfo->p3);
         }
				// check for partial wraparound

			And = u0&u1&u2&u3;
			Or  = u0|u1|u2|u3;

			// This line used to be if DEBUG. Changed to always compile, since sometimes
         // infinite loops can occur.
			#if 1
			Count = 0;
			while ((And^Or)&0x10000 && Count<16)
			#else
			while ((And^Or)&0x10000)
			#endif
			{
				u0 += TileWidth;
				u1 += TileWidth;
				u2 += TileWidth;
				u3 += TileWidth;
				And = u0&u1&u2&u3;
				Or  = u0|u1|u2|u3;
				#if 1
				Count++;
				#endif
			}

			#if DEBUG&0
			if (Count>=16)
	      	sprintf(AssertString,"\n U = (%d,%d,%d,%d) W = %d",u0/256,u1/256,u2/256,u3/256,TileWidth/256);   
			ASSERT(Count<16, "U wibble overflow, poly maybe too big?");
			#endif

			And = v0&v1&v2&v3;
			Or  = v0|v1|v2|v3;

			#if 1
			Count = 0;
			while ((And^Or)&0x10000 && Count<16)
			#else
			while ((And^Or)&0x10000)
			#endif
			{
				v0 += TileHeight;
				v1 += TileHeight;
				v2 += TileHeight;
				v3 += TileHeight;
				And = v0&v1&v2&v3;
				Or  = v0|v1|v2|v3;
				#if 1
				Count++;
				#endif
			}
			#if DEBUG&0
			if (Count>=16)
	      	sprintf(AssertString,"\n V = (%d,%d,%d,%d) H = %d",v0/256,v1/256,v2/256,v3/256,TileHeight/256);   
			ASSERT(Count<16, "V Wibble Overflow, poly maybe too big?");
			#endif

				// just take the 2nd byte of each

			u0 = (u0 & 0xFF00) >> 8;
			v0 = (v0 & 0xFF00) >> 8;
			u1 = (u1 & 0xFF00) >> 8;
			v1 = (v1 & 0xFF00) >> 8;
			u2 = (u2 & 0xFF00) >> 8;
			v2 = (v2 & 0xFF00) >> 8;
			u3 = (u3 & 0xFF00) >> 8;
			v3 = (v3 & 0xFF00) >> 8;

				// write uv's to model data

			*(Uint16*)&pFace[CFACE_TEXTURENUM] = u0|v0<<8;
			*(Uint16*)&pFace[CFACE_UV01] = u1|v1<<8;
			pFace[CFACE_UV23] = u2|v2<<8|u3<<16|v3<<24;
		}

		pData = (Uint32 *)pTexWibFaceInfo;
	}
}




struct SRGBI
{
	Uint8 r,g,b,Interval;
};


struct SColourPulseInfo
{
	Uint8 VertexColourIndex;
	Uint8 ListLen;
	Uint8 ListPos;
	Uint8 t;
	SRGBI RGBs[1];
};



void M3d_PreprocessPulsingColours(int Region)
{
	RECORDRA;

	Uint32 *pData, *pEnd, dt, ListLen, ListPos, OldListPos;
	int t, rgb0[3], drgb[3];
	SRGBI  *RGBs;
	SColourPulseInfo *pColourPulseInfo;


	// check the region exists
	if (Region == -1)
		return;

	// check there's a colour pulsing packet
	pData = PSXRegion[Region].pColourPulseData;
	if (!pData)
		return;
	ASSERT(pData[-2]==PK_COLOURPULSE, "Pointer doesn't point to a colour pulsing packet");

	// get pointer to end of data
	pEnd = (Uint32 *)((Uint8 *)pData+pData[-1]);

	// get corresponding colour table pointer
	pColourTable = PSXRegion[Region].pColourTable;
	ASSERT(pColourTable, "Pulsing a non-existent colour table");

	// find time since last calculation
	if( XblanksNow < XblanksThen )
		dt = 1;	// This shouldn't happen should it? Ensure some movement anyway.
	else
		dt = XblanksNow - XblanksThen;

	// loop over colours to be pulsed
	while (pData < pEnd)
	{
		// set up pointer to colour pulse info
		pColourPulseInfo = (SColourPulseInfo *)pData;

		// check for stupid values
		ASSERT( pColourPulseInfo->ListLen, "Zero list length" );

		// get some stuff from the info
		RGBs = pColourPulseInfo->RGBs;
		ListLen = pColourPulseInfo->ListLen;

		// get last position in script
		ListPos = pColourPulseInfo->ListPos;
		t = pColourPulseInfo->t;

		// find current position in script
		t += dt;
		while (t >= RGBs[ListPos].Interval)
		{
			t -= RGBs[ListPos].Interval;
			ListPos++;

			if (ListPos==ListLen)
				ListPos=0;
		}
		pColourPulseInfo->ListPos = ListPos;
		pColourPulseInfo->t = t;

		// interpolate to get rgb
		rgb0[0] = RGBs[ListPos].r << 4;
		rgb0[1] = RGBs[ListPos].g << 4;
		rgb0[2] = RGBs[ListPos].b << 4;

		OldListPos = ListPos;

		ListPos++;

		// adjust for daft zero RGB entry.
		if (ListPos==ListLen)
			ListPos=0;

		drgb[0] = ((int)RGBs[ListPos].r<<4) - rgb0[0];
		drgb[1] = ((int)RGBs[ListPos].g<<4) - rgb0[1];
		drgb[2] = ((int)RGBs[ListPos].b<<4) - rgb0[2];

		ASSERT( RGBs[ListPos].Interval, "Zero interval" );

		m3d_ldrgb(0);													// set code to zero
		gte_lddp((t<<12)/RGBs[OldListPos].Interval);			// load the interpolation parameter
		gte_ldlvnl(&rgb0);											// constant term
		gte_ldlvl(&drgb);												// linear coefficient
		gte_gpl12();													// interpolate
		gte_strgb(&pColourTable[pColourPulseInfo->VertexColourIndex]);

//		r = r0+((t*(r1-r0))/RGBs[OldListPos].Interval);		// this can be greatly sped up using the gte
//		g = g0+((t*(g1-g0))/RGBs[OldListPos].Interval);
//		b = b0+((t*(b1-b0))/RGBs[OldListPos].Interval);

		// just to make sure...
//		r &= 0xFF;
//		g &= 0xFF;
//		b &= 0xFF;

		// set colour table entry
//		pColourTable[pColourPulseInfo->VertexColourIndex] = r|g<<8|b<<16;

		// increment pData
		pData = (Uint32 *)(pColourPulseInfo+1) + ListLen-1;		// subtract 1 for the 1-element array in SColourPulseData
	}
}
