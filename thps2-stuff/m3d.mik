#if WIREFRAME

void M3d_Line(int x0, int y0, int x1, int y1, int Color, int z)
{
	RECORDRA;

	// ignore points
	if (x0==x1 && y0==y1)
		return;
	// Clipping
	int t;   // temp var for swapping

	if (x0>x1)
	{
		t = x0;
		x0=x1;
		x1=t;
		t = y0;
		y0=y1;
		y1=t;
	}

	if (x1<0 || x0>511)
		return;

	if (x0<0)
	{
		y0 = (0-x0)*(y1-y0)/(x1-x0)+y0;
		x0 = 0;
	}
	if (x1>511)
	{
		y1 = (511-x0)*(y1-y0)/(x1-x0)+y0;
		x1 = 511;
	}

	if (y0>y1)
	{
		t = x0;
		x0=x1;
		x1=t;
		t = y0;
		y0=y1;
		y1=t;
	}

	if (y1<0 || y0>239)
		return;
	if (y0<0)
	{
		x0 = (0-y0)*(x1-x0)/(y1-y0)+x0;
		y0 = 0;
	}
	if (y1>239)
	{
		x1 = (239-y0)*(x1-x0)/(y1-y0)+x0;
		y1 = 239;
	}


	
   LINE_F2* aline=(LINE_F2*)pPoly;
	Uint8 *newppoly=(Uint8*)(aline+1);
	if ((int)aline>(int)PolyBufferEnd) { return;} // See ya
   pPoly=(Uint32*)newppoly;
	
   aline->tag=0x03000000;
	*(Uint32*)&aline->r0=0x40000000 + Color;
	aline->x0=x0;
	aline->y0=y0;
	aline->x1=x1;
	aline->y1=y1;
	addPrim(pDoubleBuffer->OrderingTable+M3d_OTPriority0(z),aline);
//	addPrim(pDoubleBuffer->OrderingTable,aline);
}


// Quick and dirty display of a list of faces in wireframe mode
Wireframe_ProcessPolys(Uint32 * pFaceX, int Num, int color)
{
	if (ForceWireFrameColor) color = ForceWireFrameColor;

	SProjectedVertex*	pVertices;
	pVertices = ProjectedVertices;

	int FaceR = 0;
	int FaceG = 0;
	int FaceB = 0;
	


	for (int i=0; i<Num; i++,pFaceX+=FACELEN(pFaceX))
   {
      SFace *pFace = (SFace*)pFaceX;		// to simplify casting, which hurts my head.



      Uint16   *pFaceFlags=(Uint16*)pFace;
      Uint8    *pVertexIndex=(Uint8*)(pFaceFlags+CFACE_VERTEXNUMS*2); // Byte vertex indices which are not shifted

      int x0 =   pVertices[pVertexIndex[0]].X; 
      int y0 =   pVertices[pVertexIndex[0]].Y;
      int z0 =   pVertices[pVertexIndex[0]].z;

      int x1 =   pVertices[pVertexIndex[1]].X;
      int y1 =   pVertices[pVertexIndex[1]].Y;
      int z1 =   pVertices[pVertexIndex[0]].z;

      int x2 =   pVertices[pVertexIndex[2]].X;
      int y2 =   pVertices[pVertexIndex[2]].Y;
      int z2 =   pVertices[pVertexIndex[0]].z;
	
		// hidden face removal
		if ((x1-x0)*(y2-y0) < (x2-x0)*(y1-y0))
			continue;
		
		int zmax = z0;
		if (z1>zmax) zmax = z1;
		if (z2>zmax) zmax = z2;




      // if not a triangular face and not an invisible face
      if (! (pFace->Flags&FACEFLAGS_TRIANGLE) &&
      	((pFace->Flags&FACEFLAGS_TRANSPARENT) || (pFace->Flags&FACEFLAGS_TRANSRATELO)))
      {
         int x3 =   pVertices[pVertexIndex[3]].X;
         int y3 =   pVertices[pVertexIndex[3]].Y;
     	 	int z3 =   pVertices[pVertexIndex[0]].z;
			if (z3>zmax) zmax = z3;


			int color2 = color;
			if (color2 ==	0x800080)
			{
				if (pFace->Flags&FACEFLAGS_PRIORITYPUSH)	  
					color2 = 0x008000;		// green = push, smoothing group 17
				if (pFace->Flags&FACEFLAGS_PRIORITYPUSH2)
					color2 = 0x000080;		// red = push2, smoothing 16
			}

			M3d_Line(x0,y0,x1,y1,color2,zmax);
			M3d_Line(x1,y1,x3,y3,color2,zmax);
			M3d_Line(x2,y2,x3,y3,color2,zmax);
			M3d_Line(x2,y2,x0,y0,color2,zmax);

			if (M3d_WireframeMode == WIREFRAME_HIDDEN && !((((Uint32*)(pFace))[CFACE_NORMAL] >> 16) &FU_NONCOLLIDABLE))
			{

				FaceR = 0;
				FaceG = 0;
				FaceB = 0;
//				if ((((Uint32*)(pFace))[CFACE_NORMAL] >> 16) & FU_NONSKATEABLE)
//					FaceR=0x20;													  // Non-skatable red
//		      if (((((Uint32*)(pFace))[CFACE_NORMAL] >> 16) & FU_NONWALLRIDE))
//					FaceG=0x20;													  // Non-Wallride Green
//				if ((((Uint32*)(pFace))[CFACE_NORMAL] >> 16) & FU_STICKTOTAGGED)
//					FaceB=0x20;													  // Stick to Blue



				if (pFace->Flags&FACEFLAGS_PRIORITYPUSH)	 
				{
					int push = ((Sint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]/32;
					if (push<-255) push = -255;
					if (push>255) push = 255;
					if (push<0)
						FaceG-=push;									
					else
						FaceR+=push;									
				}
				if (pFace->Flags&FACEFLAGS_PRIORITYPUSH2)
				{
					int push = ((Sint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]/32;
					if (push<-255) push = -255;
					if (push>255) push = 255;
					if (push<0)
						FaceG-=push;									
					else
						FaceR+=push;									
				}



				POLY_F4 * p_poly = (POLY_F4 *)pPoly;
				if( (Uint8 *)p_poly > PolyBufferEnd )
				{
					#if DEBUG
					POLYOVERFLOWINDICATOR;
					#endif
					return;
				}
				pPoly	= (Uint32 *)( p_poly + 1 );
				setPolyF4( p_poly );
				setXY4( p_poly, x0, y0, x1,y1, x2,y2,x3,y3);
				setRGB0( p_poly, FaceR, FaceG, FaceB );
				addPrim( pDoubleBuffer->OrderingTable + M3d_OTPriority0(zmax), p_poly );
			}
      }
		// if a triangular face and not invisible
		else if ((pFace->Flags&FACEFLAGS_TRANSPARENT) || (pFace->Flags&FACEFLAGS_TRANSRATELO))
		{
			int color2 = color;
			if (color2 ==	0x800080)
			{
				if (pFace->Flags&FACEFLAGS_PRIORITYPUSH)	  
					color2 = 0x008000;		// green = push, smoothing group 17
				if (pFace->Flags&FACEFLAGS_PRIORITYPUSH2)
					color2 = 0x000080;		// red = push2, smoothing 16
			}
			
			M3d_Line(x0,y0,x1,y1,color2,zmax);
			M3d_Line(x1,y1,x2,y2,color2,zmax);
			M3d_Line(x2,y2,x0,y0,color2,zmax);

			if (M3d_WireframeMode == WIREFRAME_HIDDEN  && !((((Uint32*)(pFace))[CFACE_NORMAL] >> 16) &FU_NONCOLLIDABLE))
			{

				FaceR = 0;
				FaceG = 0;
				FaceB = 0;
//				if ((((Uint32*)(pFace))[CFACE_NORMAL] >> 16) & FU_NONSKATEABLE)
//					FaceR=0x20;													  // Non-skatable red
//		      if (((((Uint32*)(pFace))[CFACE_NORMAL] >> 16) & FU_NONWALLRIDE))
//					FaceG=0x20;													  // Non-Wallride Green
//				if ((((Uint32*)(pFace))[CFACE_NORMAL] >> 16) & FU_STICKTOTAGGED)
//					FaceB=0x20;													  // Stick to Blue
				
				if (pFace->Flags&FACEFLAGS_PRIORITYPUSH)	 
				{
					int push = ((Sint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]/32;
					if (push<-255) push = -255;
					if (push>255) push = 255;
					if (push<0)
						FaceG-=push;									
					else
						FaceR+=push;									
				}
				if (pFace->Flags&FACEFLAGS_PRIORITYPUSH2)
				{
					int push = ((Sint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]/32;
					if (push<-255) push = -255;
					if (push>255) push = 255;
					if (push<0)
						FaceG-=push;									
					else
						FaceR+=push;									
				}

				POLY_F3 * p_poly = (POLY_F3 *)pPoly;
				if( (Uint8 *)p_poly > PolyBufferEnd )
				{
					#if DEBUG
					POLYOVERFLOWINDICATOR;
					#endif
					return;
				}
				pPoly	= (Uint32 *)( p_poly + 1 );
				setPolyF3( p_poly );
				setXY3( p_poly, x0, y0, x1,y1, x2,y2);
				setRGB0( p_poly, FaceR, FaceG, FaceB );
				addPrim( pDoubleBuffer->OrderingTable + M3d_OTPriority0(zmax), p_poly );
			}
		}
   }
}


/*

DR_PRIO bollocks - does not work, and is not allowed by sony

// The first parameter (pbc) tells GPU to spit out all pixels with the STP (0x8000) bit set.
// It is good for taking a texture with no transparency and having it turned on
// without having to draw into VRAM.
// The 2nd parameter (pbw) tells the GPU to read each pixel being written to, 
// and if the STP-bit is set no drawing will be done, and if it is clear the pixel is drawn.

// DR_PRIO stuff for testing
typedef struct {
    u_long    tag;
    u_long    code[2];
} DR_PRIO;                    // Priority 

// *  DR_PRIO  |  3   |   -   |   -   |   -   | Drawing Priority

void SetPriority(DR_PRIO *p, int pbc, int pbw)
{
    setlen((u_long *)p, 2);
    ((u_long *)p)[1] = 0xe6000000|(pbc?0x02:0)|(pbw? 0x01:0);
    ((u_long *)p)[2] = 0;
}

*/


// Quick and dirty display of a list of faces as flat black polys
Black_ProcessPolys(Uint32 * pFaceX, int Num, int color)
{
	SProjectedVertex*	pVertices;
	pVertices = ProjectedVertices;

//	if (Pad[0].Circle.Pressed)
//		return;


	for (int i=0; i<Num; i++,pFaceX+=FACELEN(pFaceX))
   {
      SFace *pFace = (SFace*)pFaceX;		// to simplify casting, which hurts my head.

      Uint16   *pFaceFlags=(Uint16*)pFace;
      Uint8    *pVertexIndex=(Uint8*)(pFaceFlags+CFACE_VERTEXNUMS*2); // Byte vertex indices which are not shifted

		Uint32	Indices = *(Uint32*)pVertexIndex;
		Uint32	Index3 = Indices>>24;	
		Uint32	Index2 = (Indices>>16)&0xff;	
		Uint32	Index1 = (Indices>>8)&0xff;	
		Uint32	Index0 = (Indices)&0xff;	


		int z0 =   pVertices[Index0].z;
      int z1 =   pVertices[Index1].z;
      int z2 =   pVertices[Index2].z;
		int zmax = z0;
		if (z1>zmax) zmax = z1;
		if (z2>zmax) zmax = z2;


#define	SHADOW_TRANS  0			// set to 1 to see what it looks liek transparent


#if	SHADOW_TRANS	
#define	SHADOW_DARKNESS 24
#else
#define	SHADOW_DARKNESS 0
#endif


      // if not a triangular face and not an invisible face
      if (! (pFace->Flags&FACEFLAGS_TRIANGLE) /* &&
      	((pFace->Flags&FACEFLAGS_TRANSPARENT) || (pFace->Flags&FACEFLAGS_TRANSRATELO))*/)
      {

//			Uint32	x3y3	= *(Uint32*)(&pVertices[pVertexIndex[3]]);
     	 	int z3 =   pVertices[Index3].z;
			if (z3>zmax) zmax = z3;
			
			Uint32* OTPos = pDoubleBuffer->OrderingTable + M3d_OTPriority0(zmax);
			
			POLY_F4 * p_poly = (POLY_F4 *)pPoly;
			if( (Uint8 *)p_poly > PolyBufferEnd )
			{
				return;
			}
			#if SHADOW_TRANS
			DR_TPAGE* ptpage=(DR_TPAGE*)(p_poly+1);
			pPoly	= (Uint32 *)( ptpage + 1 );
			#else
			pPoly	= (Uint32 *)( p_poly + 1 );
			#endif
			
			/*
tag_f4          equ     $00
rgb0_f4         equ     $04
xy0_f4          equ     $08
xy1_f4          equ     $0C
xy2_f4          equ     $10
xy3_f4          equ     $14
size_f4         equ     $18
code_f4         equ     $28
len_f4          equ     $05
*/
			Uint32* pp = (Uint32*)p_poly;
			*pp++ = 0x05000000;			// set size 
			*pp++ = 0x28000000;			// code (0x28 = F4) and color 0
			*pp++ = *(Uint32*)(&pVertices[Index0]);
			*pp++ = *(Uint32*)(&pVertices[Index1]);
			*pp++ = *(Uint32*)(&pVertices[Index2]);
			*pp++ = *(Uint32*)(&pVertices[Index3]);
			addPrim( OTPos, p_poly );
			
			#if SHADOW_TRANS
	      ptpage->tag=0x01000000;
	      ptpage->code[0]=0xe1000640; // Subtractive transparency
   //   	ptpage->code[0]=0xe1000620; // 50:50 transparency
			addPrim(OTPos,ptpage);
			#endif
		
		
		}
		// if a triangular face and not invisible
		else/* if ((pFace->Flags&FACEFLAGS_TRANSPARENT) || (pFace->Flags&FACEFLAGS_TRANSRATELO))*/
		{
			
// this BFC test does not really make much difference
//			if ((x1-x0)*(y2-y0) < (x2-x0)*(y1-y0))
//				continue;
			

			Uint32* OTPos = pDoubleBuffer->OrderingTable + M3d_OTPriority0(zmax);
						

			POLY_F3 * p_poly = (POLY_F3 *)pPoly;
			if( (Uint8 *)p_poly > PolyBufferEnd )
			{
				return;
			}
			#if SHADOW_TRANS
			DR_TPAGE* ptpage=(DR_TPAGE*)(p_poly+1);
			pPoly	= (Uint32 *)( ptpage + 1 );
			#else
			pPoly	= (Uint32 *)( p_poly + 1 );
			#endif
			
			Uint32* pp = (Uint32*)p_poly;

			*pp++ = 0x04000000;			// set size 
			*pp++ = 0x20000000;			// code (0x20 = F3) and color 0
			*pp++ = *(Uint32*)(&pVertices[Index0]);
			*pp++ = *(Uint32*)(&pVertices[Index1]);
			*pp++ = *(Uint32*)(&pVertices[Index2]);


			/*
			setPolyF3( p_poly );
			#if SHADOW_TRANS
			p_poly->code|=0x02; // Semitransparent
			#endif
			setXY3( p_poly, x0, y0, x1,y1, x2,y2);
			setRGB0( p_poly, SHADOW_DARKNESS,SHADOW_DARKNESS,SHADOW_DARKNESS );
			*/

			addPrim( OTPos, p_poly );
			#if SHADOW_TRANS
	      ptpage->tag=0x01000000;
	      ptpage->code[0]=0xe1000640; // Subtractive transparency
   //   	ptpage->code[0]=0xe1000620; // 50:50 transparency
			addPrim(OTPos,ptpage);
			#endif
		



		}
   }
}



#endif



////////////////////////////////////////////////////////////////////////////////////
// Function M3d_RenderSetup
//
// Description: setup function to be called once per frame, before rendering
//
// Arguments:
// pCamera = address of SCamera structure defining the camera view
// pViewport = pointer to viewport defining the screen area to render to
// ot = address of slot in ordering table
//
// Return value:
// none
//
// Side effects:
////////////////////////////////////////////////////////////////////////////////////

#if DEBUG
//	debugging variables to make sure	calling sequence is correct
int RenderCleanupCalled=1;	//	set to 1	for first frame
int RenderSetupCalled=0;
#endif

SVECTOR FrustumNormals[10];				// normals to planes of view frustum in camera coords
MATRIX FrustumMatrix1, FrustumMatrix2;	// used to store above normals transformed into world coords

void M3d_RenderSetup(SCamera *pCamera,	SViewport *pVP, Uint32 *ot)
{
	RECORDRA;

	#if WIREFRAME
	#if !CD
	static int released = 1;
	if (Pad[0].LeftTwo.Pressed && Pad[0].LeftOne.Pressed)
	{
		if (released)
		{
			released = 0;
			Pad[0].LeftTwo.Triggered = 0;
			M3d_WireframeMode++;
			if (M3d_WireframeMode == 4)
				M3d_WireframeMode = 0;
		}
	}
	else
		released = 1;
	#endif
	#endif

	#if DEBUG
	RenderSetupCalled=1;
	ASSERT(RenderCleanupCalled, "Must call	M3d_RenderCleanup() after last call	to	M3d_Render()");
	RenderCleanupCalled=0;
	#endif

	// Xblanks is like Vblanks but doesn't increment during a pause
	XblanksThen = XblanksNow;
	XblanksNow = Xblanks;
	if (XblanksThen!=XblanksNow)
		FrameNo++;

#	if SPIDEY
	if( DpqInterpTime > 0 )
	{
		--DpqInterpTime;
		DpqMin += DpqInterpDeltaMin;
		DpqMax += DpqInterpDeltaMax;
	}
#	endif

	pCurrentCamera			= pCamera;
	pCurrentViewport		= pVP;
	pCurrentViewport->Yon= DpqMax;

#	if DAVE && DEBUG
	pCurrentViewport->Hither = T[1] + 16;
#	endif

	CurrentOrderingTable	= ot;

	#if SPIDEY
	M3dInit_SetResolution(512,240);
	#endif

	// restore the viewport after this render
	RECT Window;
	Window.x	= 0;
	Window.y	= pDoubleBuffer->Draw.clip.y;
	Window.w	= Xres;
	Window.h	= Yres;
	DR_AREA *pClipArea;
	pClipArea =	(DR_AREA	*)pPoly;
	// NOTE: ALLOW PolyBuffer overflow here (into "safe" 100 bytes), to ensure correct clipping 
	// (actually this is right at the start, so no check needed)
	SetDrawArea(pClipArea,&Window);
	pPoly	= (Uint32 *)(pClipArea+1);
	addPrim(CurrentOrderingTable,pClipArea);

	// calculate derived members of the viewport structure
	pVP->Zoom = (pVP->xR - pVP->xL >> 1 << 12) / pVP->TanHalf * 4096 / PixelAspectY;
	pVP->xC = pVP->xL + pVP->xR >> 1;
	pVP->yC = pVP->yT + pVP->yB >> 1;

	// set the (inward facing) frustum normals for the given viewport
	Uint32 opp,adj,hyp;

	// yon
	FrustumNormals[0].vx	 =	0;
	FrustumNormals[0].vy	 =	0;
	FrustumNormals[0].vz	 =	0xF000;
	FrustumNormals[0].pad =	pVP->Yon;

	// hither
	FrustumNormals[1].vx	 =	0;
	FrustumNormals[1].vy	 =	0;
	FrustumNormals[1].vz	 =	0x1000;
	FrustumNormals[1].pad =	-pVP->Hither;

	// true top and bottom
	opp = pVP->xR - pVP->xL << 11;
	adj = pVP->Zoom * PixelAspectX;
	hyp = M3dMaths_SquareRoot0(SQ2(opp>>12,adj>>12));

	FrustumNormals[2].vx	 =	0;
	FrustumNormals[2].vy	 =	adj/hyp;
	FrustumNormals[2].vz	 =	opp/hyp;
	FrustumNormals[2].pad =	0;

	FrustumNormals[3].vx	 =	0;
	FrustumNormals[3].vy	 =	-FrustumNormals[2].vy;
	FrustumNormals[3].vz	 =	FrustumNormals[2].vz;
	FrustumNormals[3].pad =	0;

	// true left and right
	opp = pVP->xR - pVP->xL << 11;
	adj = pVP->Zoom * PixelAspectY;
	hyp = M3dMaths_SquareRoot0(SQ2(opp>>12,adj>>12));

	FrustumNormals[4].vx	 =	adj/hyp;
	FrustumNormals[4].vy	 =	0;
	FrustumNormals[4].vz	 =	opp/hyp;
	FrustumNormals[4].pad =	0;

	FrustumNormals[5].vx	 =	-FrustumNormals[4].vx;
	FrustumNormals[5].vy	 =	0;
	FrustumNormals[5].vz	 =	FrustumNormals[4].vz;
	FrustumNormals[5].pad =	0;

	// adjusted top and bottom
	opp = pVP->yB - pVP->yT >> 1;
	adj = pVP->Zoom;
	hyp = M3dMaths_SquareRoot0(SQ2(opp,adj));

	FrustumNormals[6].vx	 =	0;
	FrustumNormals[6].vy	 =	(adj<<12)/hyp;
	FrustumNormals[6].vz	 =	(opp<<12)/hyp;
	FrustumNormals[6].pad =	0;

	FrustumNormals[7].vx	 =	0;
	FrustumNormals[7].vy	 =	-FrustumNormals[6].vy;
	FrustumNormals[7].vz	 =	FrustumNormals[6].vz;
	FrustumNormals[7].pad =	0;

	// adjusted left and right
	opp = pVP->xR - pVP->xL >> 1;
	adj = pVP->Zoom;
	hyp = M3dMaths_SquareRoot0(SQ2(opp,adj));

	FrustumNormals[8].vx	 =	(adj<<12)/hyp;
	FrustumNormals[8].vy	 =	0;
	FrustumNormals[8].vz	 =	(opp<<12)/hyp;
	FrustumNormals[8].pad =	0;

	FrustumNormals[9].vx	 =	-FrustumNormals[8].vx;
	FrustumNormals[9].vy	 =	0;
	FrustumNormals[9].vz	 =	FrustumNormals[8].vz;
	FrustumNormals[9].pad =	0;

	// set up view frustum matrices using the given camera
	gte_SetRotMatrix( &pCamera->Transform );
	for (int i=0; i<3; i++)
	{
		// The following is equivalent to 2 calls to gte_ApplyMatrixSV, but without having to reload
		// the rotation matrix from within the loop.
//		gte_ApplyMatrixSV(&pCamera->Transform, &FrustumNormals[i], (SVECTOR *)&FrustumMatrix1.m[i]);
//		gte_ApplyMatrixSV(&pCamera->Transform, &FrustumNormals[i+3], (SVECTOR *)&FrustumMatrix2.m[i]);
		gte_ldv0( &FrustumNormals[i] );
		gte_rtv0();
		gte_stsv( &FrustumMatrix1.m[i] );

		gte_ldv0( &FrustumNormals[i + 3] );
		gte_rtv0();
		gte_stsv( &FrustumMatrix2.m[i] );
	}

	//	set GTE control registers
	SetGeomScreen(pVP->Zoom);
	SetGeomOffset(pVP->xC, pVP->yC);

	//	invert the camera	transform
	M3dMaths_TransposeMat((XMat*)&pCamera->Transform, (XMat*)&pCamera->Inverse);

	// set up camera's view matrix (which accounts for the pixel aspect ratio)
	for (int i=0; i<3; i++)
	{
		pCamera->View.m[0][i] =	pCamera->Inverse.m[0][i] * PixelAspectY >> 12;
		pCamera->View.m[1][i] =	pCamera->Inverse.m[1][i] * PixelAspectX >> 12;
		pCamera->View.m[2][i] =	pCamera->Inverse.m[2][i];
	}


		// set up reflection map texture info

	STexture *pTex = Spool_FindTextureEntry(SMOKECHECKSUM);
	RefMapClut  = pTex->clut<<16;
	RefMapTpage = pTex->tpage<<16;
	RefMapU0V0  = pTex->u0 | pTex->v0<<8;


	// pulse them colours
	M3d_PreprocessPulsingColours(EnvRegions[0]);
	M3d_PreprocessPulsingColours(EnvRegions[1]);
	M3d_PreprocessPulsingColours(CurrentObjFileRegion);
   #if !KENVIEWER
	M3d_PreprocessPulsingColours(CurrentItemsFileRegion);
   #endif


	// wibble wibbly textures
	M3d_PreprocessWibblyTextures(CurrentObjFileRegion);
   #if !KENVIEWER
	M3d_PreprocessWibblyTextures(CurrentItemsFileRegion);
   #endif

	// set the clipping plane
	WaterNormal.vx = -pCurrentCamera->Transform.m[1][0];
	WaterNormal.vy = -pCurrentCamera->Transform.m[1][1];
	WaterNormal.vz = -pCurrentCamera->Transform.m[1][2];
	WaterNormal.pad = (CurrentWaterLevel >> FRACBITS) - pCurrentCamera->Position.vy;
}



void M3d_RenderSetupCamera(SCamera *pCamera)
{
	RECORDRA;

	pCurrentCamera			= pCamera;
	SViewport *pVP = pCurrentViewport;
	pCurrentViewport->Yon= DpqMax;
	Uint32 *ot = CurrentOrderingTable;
	// calculate derived members of the viewport structure
	pVP->Zoom = (pVP->xR - pVP->xL >> 1 << 12) / pVP->TanHalf * 4096 / PixelAspectY;
	pVP->xC = pVP->xL + pVP->xR >> 1;
	pVP->yC = pVP->yT + pVP->yB >> 1;

	// set the (inward facing) frustum normals for the given viewport
	Uint32 opp,adj,hyp;

	// yon
	FrustumNormals[0].vx	 =	0;
	FrustumNormals[0].vy	 =	0;
	FrustumNormals[0].vz	 =	0xF000;
	FrustumNormals[0].pad =	pVP->Yon;

	// hither
	FrustumNormals[1].vx	 =	0;
	FrustumNormals[1].vy	 =	0;
	FrustumNormals[1].vz	 =	0x1000;
	FrustumNormals[1].pad =	-pVP->Hither;

	// true top and bottom
	opp = pVP->xR - pVP->xL << 11;
	adj = pVP->Zoom * PixelAspectX;
	hyp = M3dMaths_SquareRoot0(SQ2(opp>>12,adj>>12));

	FrustumNormals[2].vx	 =	0;
	FrustumNormals[2].vy	 =	adj/hyp;
	FrustumNormals[2].vz	 =	opp/hyp;
	FrustumNormals[2].pad =	0;

	FrustumNormals[3].vx	 =	0;
	FrustumNormals[3].vy	 =	-FrustumNormals[2].vy;
	FrustumNormals[3].vz	 =	FrustumNormals[2].vz;
	FrustumNormals[3].pad =	0;

	// true left and right
	opp = pVP->xR - pVP->xL << 11;
	adj = pVP->Zoom * PixelAspectY;
	hyp = M3dMaths_SquareRoot0(SQ2(opp>>12,adj>>12));

	FrustumNormals[4].vx	 =	adj/hyp;
	FrustumNormals[4].vy	 =	0;
	FrustumNormals[4].vz	 =	opp/hyp;
	FrustumNormals[4].pad =	0;

	FrustumNormals[5].vx	 =	-FrustumNormals[4].vx;
	FrustumNormals[5].vy	 =	0;
	FrustumNormals[5].vz	 =	FrustumNormals[4].vz;
	FrustumNormals[5].pad =	0;

	// adjusted top and bottom
	opp = pVP->yB - pVP->yT >> 1;
	adj = pVP->Zoom;
	hyp = M3dMaths_SquareRoot0(SQ2(opp,adj));

	FrustumNormals[6].vx	 =	0;
	FrustumNormals[6].vy	 =	(adj<<12)/hyp;
	FrustumNormals[6].vz	 =	(opp<<12)/hyp;
	FrustumNormals[6].pad =	0;

	FrustumNormals[7].vx	 =	0;
	FrustumNormals[7].vy	 =	-FrustumNormals[6].vy;
	FrustumNormals[7].vz	 =	FrustumNormals[6].vz;
	FrustumNormals[7].pad =	0;

	// adjusted left and right
	opp = pVP->xR - pVP->xL >> 1;
	adj = pVP->Zoom;
	hyp = M3dMaths_SquareRoot0(SQ2(opp,adj));

	FrustumNormals[8].vx	 =	(adj<<12)/hyp;
	FrustumNormals[8].vy	 =	0;
	FrustumNormals[8].vz	 =	(opp<<12)/hyp;
	FrustumNormals[8].pad =	0;

	FrustumNormals[9].vx	 =	-FrustumNormals[8].vx;
	FrustumNormals[9].vy	 =	0;
	FrustumNormals[9].vz	 =	FrustumNormals[8].vz;
	FrustumNormals[9].pad =	0;

	// set up view frustum matrices using the given camera
	gte_SetRotMatrix( &pCamera->Transform );
	for (int i=0; i<3; i++)
	{
		// The following is equivalent to 2 calls to gte_ApplyMatrixSV, but without having to reload
		// the rotation matrix from within the loop.
//		gte_ApplyMatrixSV(&pCamera->Transform, &FrustumNormals[i], (SVECTOR *)&FrustumMatrix1.m[i]);
//		gte_ApplyMatrixSV(&pCamera->Transform, &FrustumNormals[i+3], (SVECTOR *)&FrustumMatrix2.m[i]);
		gte_ldv0( &FrustumNormals[i] );
		gte_rtv0();
		gte_stsv( &FrustumMatrix1.m[i] );

		gte_ldv0( &FrustumNormals[i + 3] );
		gte_rtv0();
		gte_stsv( &FrustumMatrix2.m[i] );
	}

	//	set GTE control registers
	SetGeomScreen(pVP->Zoom);
	SetGeomOffset(pVP->xC, pVP->yC);

	//	invert the camera	transform
	M3dMaths_TransposeMat((XMat*)&pCamera->Transform, (XMat*)&pCamera->Inverse);

	// set up camera's view matrix (which accounts for the pixel aspect ratio)
	for (int i=0; i<3; i++)
	{
		pCamera->View.m[0][i] =	pCamera->Inverse.m[0][i] * PixelAspectY >> 12;
		pCamera->View.m[1][i] =	pCamera->Inverse.m[1][i] * PixelAspectX >> 12;
		pCamera->View.m[2][i] =	pCamera->Inverse.m[2][i];
	}
}




void M3d_RenderCleanup(void)
{
	RECORDRA;

	#if DEBUG
	RenderCleanupCalled=1;
	ASSERT(RenderSetupCalled, "Musn't call	M3d_RenderCleanup() before	M3d_RenderSetup()");
	RenderSetupCalled=0;	//	ready	for next	frame
	#endif

	//	Set the viewport for this render.
	RECT Window;
	Window.x	= pCurrentViewport->xL;
	Window.y	= pCurrentViewport->yT+pDoubleBuffer->Draw.clip.y + M3d_Widescreen;
	Window.w	= pCurrentViewport->xR-pCurrentViewport->xL;
	Window.h	= pCurrentViewport->yB-pCurrentViewport->yT - ( 2 * M3d_Widescreen );
	DR_AREA *pClipArea;
	pClipArea =	(DR_AREA	*)pPoly;
	SetDrawArea(pClipArea,&Window);
	pPoly	= (Uint32 *)(pClipArea+1);
	
	// NOTE - Allow safe poly buffer overflow
	#if DEBUG&&SK
	PolyBufferEnd+=100;
	#endif
	addPrim(CurrentOrderingTable+OTSIZE-1,pClipArea);
	#if DEBUG&&SK
	PolyBufferEnd-=100;
	#endif

	// And add top and bottom black polys to mask the background when not black.
	if( M3d_Widescreen )
	{
		for( int i = 0; i < 2; ++i )
		{
			POLY_F4 *p_polyF4 = (POLY_F4 *)pPoly;
			pPoly	= (Uint32 *)( p_polyF4 + 1 );
			*(Uint32 *)&( p_polyF4->r0 ) = 0;
			setPolyF4( p_polyF4 );

			if( i )
				setXY4( p_polyF4, 0, 0, SCREENWIDTH, 0, 0, M3d_Widescreen, SCREENWIDTH, M3d_Widescreen );
			else
				setXY4( p_polyF4, 0, SCREENHEIGHT, SCREENWIDTH, SCREENHEIGHT, 0, SCREENHEIGHT - M3d_Widescreen, SCREENWIDTH, SCREENHEIGHT - M3d_Widescreen );

			addPrim( CurrentOrderingTable + OTSIZE - 1, p_polyF4 );
		}
	}
}


#if DEBUG && MICKMAP
extern Mick_ItemOutline(SItem * pItem, int color);
extern Mick_Item(SItem * pItem, int color);
extern int Mick_MapDoit;
#endif

#define DEFZOOM 	191

void M3d_Render(void	*p)
{
	RECORDRA;

	int	 i;
	SItem	 *pItem;
	VECTOR Position, PosnRelCam;
	MATRIX Transform,	WorldTransform, TempMatrix;
	SModel *pModel;
	STexture	*pTex;
	POLY_F4 *pFrame;
	Uint32 GlobalFaceFlags;

	Uint16 yon;


	#if DEBUG
	ASSERT(RenderSetupCalled,	  "Either M3d_Render	called before M3d_RenderSetup(),\n or M3d_Render()	called after M3d_RenderCleanup");
	#endif

	pItem=(SItem*)p;

	if	(!pItem)	return;

		//	do	bounding	sphere preprocessing

	gte_SetLightMatrix(&FrustumMatrix1);
	gte_SetColorMatrix(&FrustumMatrix2);
	gte_ldbkdir((long)FrustumNormals[0].pad>>1,(long)FrustumNormals[1].pad>>1,0);

   #if SPIDEY
   M3dAsm_BoundingSpherePreprocessing(pItem);
   #else

   if (p != BaddyList)
   {
// if (p == EnviroList)
//      M3dAsm_EnvBoundingSpherePreprocessing(pItem);
      M3dAsm_BoundingSpherePreprocessing(pItem, Camera_CurrentMikeCamera ? ITEMFLAGS_INACTIVE2 : ITEMFLAGS_INACTIVE);
   }
   else
      M3dAsm_BoundingSpherePreprocessing(pItem, ITEMFLAGS_INACTIVE);
   #endif

	#if SK&&DEBUG
  //  ProfileReadCount(128,80,80);			   // pink = bounding sphere
	#endif


		// wibble them textures (at this point to make use of bounding sphere culling)

	if (pItem == EnviroList)
	{
		M3d_PreprocessWibblyTextures(EnvRegions[0]);		// one call for each of the two environment regions
		M3d_PreprocessWibblyTextures(EnvRegions[1]);
	}



//	#if SPIDEY
//	MechList[0].mpLight = &DefaultLight;
//	#else
//	MechList[0].mpLight = &DefaultLight;
//	MechList[1].mpLight = &DefaultLight;
//	extern CPlayer *GSkater1,*GSkater2;
//	GSkater1->mpLight = &DefaultLight;
//	GSkater2->mpLight = &DefaultLight;
//	#endif
		// set up scratchpad vars

	((Uint16 *)0x1F800000)[SCRATCH_DPQMIN>>1]				= DpqMin;
	((Uint16 *)0x1F800000)[SCRATCH_DPQSHIFT>>1]			= DpqShift;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= M3d_OTPushback;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= M3d_OTPushback2;
	((Uint16 *)0x1F800000)[SCRATCH_REFLECTED>>1]			= 0;

	((Uint32 *)0x1F800000)[SCRATCH_REFMAPCLUT>>2]		= RefMapClut;
	((Uint32 *)0x1F800000)[SCRATCH_REFMAPTPAGE>>2]		= RefMapTpage;
	((Uint32 *)0x1F800000)[SCRATCH_FADECOLOUR>>2]		= M3d_FadeColour;

	#if NOPUSHBACK
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= 0;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= 0;
	#endif

		//	add everything	in	the world to the display list

	#if SK&WIREFRAME
	M3d_WireframeLast = M3d_WireframeMode;
	#endif
	for (	; pItem;	pItem=pItem->NextItem)
	{
	#if SK&WIREFRAME
	M3d_WireframeMode = M3d_WireframeLast;
	#endif

//		if (pItem==(SItem *)MechList)
//		{
//			pItem->Flags |= ITEMFLAGS_REFLECTIONMAPPED;
//			pItem->Flags |= ITEMFLAGS_RGB;
//			pItem->RGB = 0x102080;
//		}

#		if DEBUG
		if	(pItem->Flags & (ITEMFLAGS_CULL))
		{
#			if SK
			GRenderedCulled++;
#			endif

#			if MICKMAP
			if	(!(pItem->Flags & (ITEMFLAGS_INACTIVE)))
			{
				if (Mick_MapDoit)
					Mick_ItemOutline(pItem,0x404040);
			}
#			endif
		}
#		if SK
		if	(pItem->Flags & (ITEMFLAGS_INACTIVE))
			GRenderedInvisible++;
#		endif
#		endif

// Do not need to check inactive flag here, as cull flag will have
// been set for any inactive object by the bounding sphere
// preprocessing, and indeed, checking for the inactive flag will
// screw up the 2-player visilibity boxes (unless the correct
// inactive flag is checked for). So, just don't do it.
//      if (pItem->Flags & (ITEMFLAGS_CULL|ITEMFLAGS_INACTIVE))
      if (pItem->Flags & ITEMFLAGS_CULL)
		{
#			if SPIDEY
			if( pItem->Flags & ITEMFLAGS_ISSUPER )
				( (CSuper *)pItem )->mpPolyStart = ( (CSuper *)pItem )->mpPolyEnd = NULL;
#			endif
			continue;
		}

		//	Added	by	Ken (will slow	things down	a tad	but only	with DEBUG on)
		#if DEBUG
		if	(pItem->Model>=(Uint32)PSXRegion[pItem->Region].ppModels[-1])
		{
			sprintf(AssertString,"\n %s Model %d",PSXRegion[pItem->Region].Filename,pItem->Model);
			ASSERT(0,"Bad model in pItem");
		}
		#endif


		//	don't	draw if PSX	file is currently	being	spooled in
		if	(!PSXRegion[pItem->Region].Usable)
		{
			MESSAGE("PSX not usable");
			continue;
		}


		// set up the display modes for this item (lighting, tint and transparency)
		#if DEBUG
		GlobalFaceFlags = DebugFaceFlags;
		#else
		GlobalFaceFlags = 0xFFFF0000;
		#endif

		if (pItem->Flags & ITEMFLAGS_LIT)
		{
			GlobalFaceFlags |= FACEFLAGS_LIT;
			if (pItem->Flags & ITEMFLAGS_GOURAUD)
				GlobalFaceFlags |= FACEFLAGS_GOURAUD;
			else
				GlobalFaceFlags &= ~(FACEFLAGS_GOURAUD<<16);
		}
		else if (pItem->Flags & ITEMFLAGS_RGB)
		{
			GlobalFaceFlags &= ~(FACEFLAGS_LIT<<16);
			GlobalFaceFlags |= FACEFLAGS_GOURAUD;

			((Uint32 *)0x1F800000)[SCRATCH_TINT>>2] = (((CItem *)pItem)->mRGB&0x0000FF)<<2|
																	(((CItem *)pItem)->mRGB&0x00FF00)<<5|
																	(((CItem *)pItem)->mRGB&0xFF0000)<<8;
		}

		if (pItem->Flags & ITEMFLAGS_REFLECTIONMAPPED)
		{
//			printf("Item Reflection %lx\n",(int)pItem);
			GlobalFaceFlags |= FACEFLAGS_RELATIVEUVS;
			GlobalFaceFlags &= ~(FACEFLAGS_TEXTURED<<16);
			GlobalFaceFlags &= ~(FACEFLAGS_TILED<<16);
		}
		else
		{
			GlobalFaceFlags &= ~FACEFLAGS_RELATIVEUVS;
			GlobalFaceFlags |= FACEFLAGS_TEXTURED<<16;
			GlobalFaceFlags |= FACEFLAGS_TILED<<16;
		}


		if (pItem->Flags & ITEMFLAGS_TRN)
			GlobalFaceFlags = GlobalFaceFlags & ~(FF_TRL|FF_TRH) | FF_TRN | ((CItem *)pItem)->mTRN & (FF_TRL|FF_TRH);

		((Uint32 *)0x1F800000)[SCRATCH_GLOBALFACEFLAGS>>2]	= GlobalFaceFlags;


		// see whether this object is requesting control of the lighting matrices.
//		if	(pItem->Flags & ITEMFLAGS_LIT)
//			( (CBody	*)pItem )->DoLightingSetup();

		// are we testing against the water level?
		TestTheWater = pItem->Flags & ITEMFLAGS_INWATER ? 1 : 0;

		if	(pItem->Flags & ITEMFLAGS_ISSUPER)
		{
#			if SPIDEY
			( (CSuper *)pItem )->mpPolyStart = (P_TAG *)pPoly;
#			endif

			P_TAG * p_poly_start = (P_TAG *)pPoly;

#			if 1
//         if ((void *)pItem == (void *)&MechList[0])
            WaterNormal.pad = (CurrentWaterLevel >> FRACBITS) - pCurrentCamera->Position.vy;
//         else
//            WaterNormal.pad = (CurrentWaterLevel2 >> FRACBITS) - pCurrentCamera->Position.vy;
#			endif

#			if SPIDEY
			// Store the current global pushback flags.
			Sint16 stored_ot_pushback1 = ((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1];
			Sint16 stored_ot_pushback2 = ((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1];

			// Set the superitem-specific pushback flags.
			((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]	= ( (CSuper *)pItem )->mOTPushback1;
			((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]	= ( (CSuper *)pItem )->mOTPushback2;
#			endif

			RenderSuperItem( pItem );

#			if SPIDEY
			// Reset the superitem-specific pushback flags.
			((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]	= stored_ot_pushback1;
			((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]	= stored_ot_pushback2;
#			endif

#			if SK
			if( TestTheWater )
         {
				// Do a double rendering in water to get lower body submerged.
				int tmp = pItem->Flags;
            pItem->Flags |= ITEMFLAGS_RGB;
            pItem->Flags &= ~ITEMFLAGS_LIT;

            int r, g, b; 
            
				if (GLevel==0)
				{
	            b = 0xa;
	            g = 0xd;
	            r = 0x8;
				}
				else
				{
	            b = 0x22;
	            g = 0x20;
	            r = 0x20;
            }
            pItem->RGB = b << 16 | g << 8 | r;


            WaterClipValue = WATER_CLIP_ABOVE; // Clip stuff above water surface
         
            GlobalFaceFlags &= ~(FACEFLAGS_LIT<<16);
            GlobalFaceFlags |= FACEFLAGS_GOURAUD;
         
				((Uint32 *)0x1F800000)[SCRATCH_TINT>>2] =
               (pItem->RGB&0x0000FF) << 2 |
               (pItem->RGB&0x00FF00) << 5 |
               (pItem->RGB&0xFF0000) << 8;
         
            // GlobalFaceFlags = GlobalFaceFlags & ~(FF_TRL|FF_TRH) | FF_TRN | FF_TRH | FF_TRL;
            ((Uint32 *)0x1F800000)[SCRATCH_GLOBALFACEFLAGS>>2] = GlobalFaceFlags;

				// Second rendering, below water surface.
            RenderSuperItem(pItem);

				// Restore it to clip below water.
            WaterClipValue = WATER_CLIP_BELOW;

            pItem->Flags = tmp;
         }
#			endif

#			if SPIDEY
			( (CSuper *)pItem )->mpPolyEnd = (P_TAG *)pPoly;
//			if( pItem->Flags & ITEMFLAGS_PREDATOREFFECT )
//				Post_ApplyPredatorEffect( (CBody *)pItem, p_poly_start, (P_TAG *)pPoly );
#			endif

			continue;
		}

		// get model pointer
		pModel=PSXRegion[pItem->Region].ppModels[pItem->Model];

		if (pModel->Flags & MODELFLAGS_INVISIBLE)
			continue;

		#if SK
		if (pModel->Flags & MODELFLAGS_VIDEO)
			GModelVideoDisplayed = 1;
		#endif

		#if SK&&WIREFRAME
		if (pModel->Flags & MODELFLAGS_WIREFRAME)
			M3d_WireframeMode = WIREFRAME_JUST;			
		#endif


		//	get camera's view transform in rot matrix
		gte_SetRotMatrix(&pCurrentCamera->View);
		m3d_ZeroTransVector();

		//	transform item's local origin
		PosnRelCam.vx = (pItem->Position.vx	>>	FRACBITS) -	pCurrentCamera->Position.vx;
		PosnRelCam.vy = (pItem->Position.vy	>>	FRACBITS) -	pCurrentCamera->Position.vy;
		PosnRelCam.vz = (pItem->Position.vz	>>	FRACBITS) -	pCurrentCamera->Position.vz;
		gte_ldlv0(&PosnRelCam);
		gte_rtv0();
		gte_stlvnl(&Position);

		// level of detail
		#if DEBUG
		if (!Pad[1].Triangle.Pressed)
		#endif
		{


			#if SK
			if (((Sint16)(pModel->zMax)) < 0)	  // negative zMax indicates it's a fraction of DpqMax 
			{
				while (Position.vz>-(((Sint16)(pModel->zMax*pCurrentViewport->Zoom/DEFZOOM))*DpqMax>>10) && pModel->NextLOD!=0xFFFF)
					pModel=PSXRegion[pItem->Region].ppModels[pModel->NextLOD];

				// got to he last model, or to a correct LOD 
				// need to check again for -ve
				if (((Sint16)(pModel->zMax)) < 0)	  // negative zMax indicates it's a fraction of DpqMax 
				{
					if (Position.vz>-(((Sint16)(pModel->zMax*pCurrentViewport->Zoom/DEFZOOM))*DpqMax>>10) && pModel->NextLOD==0xFFFF)
						continue;
				}
				else
				{
					if (Position.vz>pModel->zMax*pCurrentViewport->Zoom/DEFZOOM && pModel->NextLOD==0xFFFF)
						continue;
				}
			}
			else
			#endif
			{
				while (
					(
					Position.vz>pModel->zMax*pCurrentViewport->Zoom/DEFZOOM
					#if DEBUG&&JASON
					|| Pad[1].X.Pressed
					#endif
					)
				 && pModel->NextLOD!=0xFFFF)
				{

					pModel=PSXRegion[pItem->Region].ppModels[pModel->NextLOD];
					#if DEBUG&&JASON
					if (Pad[1].Square.Pressed)
						goto DONTDRAW;
					#endif
				}
				if (Position.vz>pModel->zMax*pCurrentViewport->Zoom/DEFZOOM && pModel->NextLOD==0xFFFF)
					continue;
			}
		}

		if( ( pModel->NumVertices <= 100 ) &&
			 ( ( pModel->Flags & MODELFLAGS_ALWAYSFACING ) == 0 ) &&
			 ( ( pItem->Flags & ( ITEMFLAGS_LIT | ITEMFLAGS_GOURAUD | ITEMFLAGS_SCALED ) ) == 0 ) &&
			 ( ( ( ( pModel->Flags & ( MODELFLAGS_SUBDIVIDABLE ) == 0 ) && ( pModel->Radius < ( Position.vz << FRACBITS ) ) ) ||
			   ( Position.vz - ( pModel->Radius >> FRACBITS ) > pCurrentViewport->Yon / 10 ) ) &&
			 ( ( pItem->Angles.vx | pItem->Angles.vy | pItem->Angles.vz ) == 0 ) ) )
			Fast = 1;
		else
			Fast = 0;


		//	set rotation (if non-zero)
		if (pItem->Angles.vx || pItem->Angles.vy || pItem->Angles.vz)
		{
			#if SK
			extern int M3d_RotateZXY;
			if (M3d_RotateZXY)
				RotMatrixZXY((SVECTOR *)(&pItem->Angles),	&WorldTransform);
			else
			#endif
				M3dMaths_RotMatrixYXZ((SVECTOR *)(&pItem->Angles),	&WorldTransform);
			if (pItem->Flags&ITEMFLAGS_SCALED)
				M3dMaths_ScaleMatrix(pItem,&WorldTransform);
			M3dMaths_MulRotMatrix(&WorldTransform,&Transform);
			gte_SetRotMatrix(&Transform);
		}
		else
		{
			M3dMaths_SetIdentityRotation(&WorldTransform);
			if (pItem->Flags&ITEMFLAGS_SCALED)
			{
				M3dMaths_ScaleMatrix(pItem,&WorldTransform);
				M3dMaths_MulRotMatrix(&WorldTransform,&Transform);
				gte_SetRotMatrix(&Transform);
			}
		}

		pColourTable = PSXRegion[pItem->Region].pColourTable;

		if	(pModel->Flags & MODELFLAGS_REFLECTIONMAPPED || pItem->Flags & ITEMFLAGS_REFLECTIONMAPPED)
		{
//			printf("Model Refl %lx\n",(int)pModel);
//			pItem->Flags |= ITEMFLAGS_RGB;    // frig to see if we can get it working
//			pItem->Flags |= ITEMFLAGS_REFLECTIONMAPPED; // make the item also be reflection mapped
			M3dAsm_GetReflectionMapping(&WorldTransform, (long *)&Position, (Uint32 *)pModel);
		}
		else if (pModel->Flags & MODELFLAGS_LIT || pItem->Flags & ITEMFLAGS_LIT)
		{
			#if KENVIEWER
			// In the viewer, it may be that the lit item being rendered is in the dummy list
			// of items in the PSX, so it cannot be cast up to a CItem. Use the Spidey_DefaultLight
			// defined in viewer.cpp instead.
			extern SLight Spidey_DefaultLight;
			if (pItem->Angles.vx || pItem->Angles.vy || pItem->Angles.vz)
			{
				gte_MulMatrix0((MATRIX *)&Spidey_DefaultLight.LightMatrix, &WorldTransform, &TempMatrix);
				gte_SetLightMatrix(&TempMatrix);
			}
			else
				gte_SetLightMatrix((MATRIX *)&Spidey_DefaultLight.LightMatrix);

			gte_SetColorMatrix((MATRIX *)&Spidey_DefaultLight.ColorMatrix);
			M3dAsm_SetAmbient(Spidey_DefaultLight.BackColor);

			#else
			if (pItem->Angles.vx || pItem->Angles.vy || pItem->Angles.vz)
			{
				gte_MulMatrix0((MATRIX *)&((CItem *)pItem)->mpLight->LightMatrix, &WorldTransform, &TempMatrix);
				gte_SetLightMatrix(&TempMatrix);
			}
			else
				gte_SetLightMatrix((MATRIX *)&((CItem *)pItem)->mpLight->LightMatrix);

			gte_SetColorMatrix((MATRIX *)&((CItem *)pItem)->mpLight->ColorMatrix);
			M3dAsm_SetAmbient(((CItem *)pItem)->mpLight->BackColor);
			#endif
			M3dAsm_GetDynamicLighting(pModel->Vertices+pModel->NumVertices,pModel->NumNormals);
		}

#define PUSHSCALE  32  // scale of the item level push flags, signed byte, so -128/127  goes to -1024/992  of scale is 32

		yon = pCurrentViewport->Yon;
		if( pItem->Flags & ITEMFLAGS_IGNOREDPQ )
		{
			// Force no depthcueing, and no distance clipping.
			( (Uint16 *)0x1F800000 )[SCRATCH_DPQMIN >> 1]		= 0x7FFF;
			( (Uint16 *)0x1F800000 )[SCRATCH_REFLECTED >> 1]	= 0;
			pCurrentViewport->Yon = 0x7FFFU;			
		}

		if (Fast)
		{
			#if DEBUG&&SK
			GRenderedFast++;
			#endif
			#if DEBUG&&MICKMAP
			if (Mick_MapDoit)
				Mick_Item(pItem,0x008000);
			#endif

			if (pItem->Frame || pItem->Anim)
			{
				if (pItem->Frame)
					((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= PUSHSCALE*((Sint8)(pItem->Frame));
				if (pItem->Anim)
					((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= PUSHSCALE*((Sint8)(pItem->Anim));
					RenderModelFast(pModel,&PosnRelCam);
				((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= M3d_OTPushback;
				((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= M3d_OTPushback2;
			}
			else
				RenderModelFast(pModel,&PosnRelCam);

			if( pItem->Flags & ITEMFLAGS_IGNOREDPQ )
			{
				// Restore depthcueing.
				( (Uint16 *)0x1F800000 )[SCRATCH_DPQMIN >> 1]		= DpqMin;
				( (Uint16 *)0x1F800000 )[SCRATCH_REFLECTED >> 1]	= 0;
				pCurrentViewport->Yon = yon;
			}
			continue;
		}

		if	(pItem->Angles.vx==0	&&	pItem->Angles.vy==0 && pItem->Angles.vz==0 && !(pItem->Flags&ITEMFLAGS_SCALED))
		{
			#if DEBUG&&SK
			GRenderedNonRotated++;
			#endif

			if (pItem->Frame || pItem->Anim)
			{
				if (pItem->Frame)
					((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= PUSHSCALE*((Sint8)(pItem->Frame));
				if (pItem->Anim)
					((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= PUSHSCALE*((Sint8)(pItem->Anim));
				RenderModelNonRotated(pModel,&PosnRelCam);
				((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= M3d_OTPushback;
				((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= M3d_OTPushback2;
			}
			else
				RenderModelNonRotated(pModel,&PosnRelCam);


			#if DEBUG&&MICKMAP
			if (Mick_MapDoit)
				Mick_Item(pItem,0x800000);
			#endif
		}
		else
		{
			#if DEBUG&&SK
			GRenderedRotated++;
			#endif
			gte_SetTransVector(&Position);
			if (pItem->Frame || pItem->Anim)
			{
				if (pItem->Frame)
					((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= PUSHSCALE*((Sint8)(pItem->Frame));
				if (pItem->Anim)
					((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= PUSHSCALE*((Sint8)(pItem->Anim));
				RenderModel(pModel);
				((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= M3d_OTPushback;
				((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= M3d_OTPushback2;
			}
			else
				RenderModel(pModel);
		}

		if( pItem->Flags & ITEMFLAGS_IGNOREDPQ )
		{
			// Restore depthcueing.
			( (Uint16 *)0x1F800000 )[SCRATCH_DPQMIN >> 1]		= DpqMin;
			( (Uint16 *)0x1F800000 )[SCRATCH_REFLECTED >> 1]	= 0;
			pCurrentViewport->Yon = yon;
		}


	DONTDRAW:
		;
	}
	#if SK&WIREFRAME
	M3d_WireframeMode = M3d_WireframeLast;
	#endif

}






#if SK

void RenderSuperItemShadow(SItem *pItem);

// we assume that m3d_render has already been called once
void M3d_RenderSuperQuick(void	*p)
{
	RECORDRA;

	int	 i;
	SItem	 *pItem;
	VECTOR Position, PosnRelCam;
	MATRIX Transform,	WorldTransform, TempMatrix;
	SModel *pModel;
	STexture	*pTex;
	POLY_F4 *pFrame;
	Uint32 GlobalFaceFlags;

	Uint16 yon;


	#if DEBUG
	ASSERT(RenderSetupCalled,	  "Either M3d_Render	called before M3d_RenderSetup(),\n or M3d_Render()	called after M3d_RenderCleanup");
	#endif

	pItem=(SItem*)p;

	if	(!pItem)	return;

	//	do	bounding	sphere preprocessing

	gte_SetLightMatrix(&FrustumMatrix1);
	gte_SetColorMatrix(&FrustumMatrix2);
	gte_ldbkdir((long)FrustumNormals[0].pad>>1,(long)FrustumNormals[1].pad>>1,0);

   M3dAsm_BoundingSpherePreprocessing(pItem, Camera_CurrentMikeCamera ? ITEMFLAGS_INACTIVE2 : ITEMFLAGS_INACTIVE);
		// set up scratchpad vars

	((Uint16 *)0x1F800000)[SCRATCH_DPQMIN>>1]				= DpqMin;
	((Uint16 *)0x1F800000)[SCRATCH_DPQSHIFT>>1]			= DpqShift;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= M3d_OTPushback;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= M3d_OTPushback2;
	((Uint16 *)0x1F800000)[SCRATCH_REFLECTED>>1]			= 0;

	((Uint32 *)0x1F800000)[SCRATCH_REFMAPCLUT>>2]		= RefMapClut;
	((Uint32 *)0x1F800000)[SCRATCH_REFMAPTPAGE>>2]		= RefMapTpage;
	((Uint32 *)0x1F800000)[SCRATCH_FADECOLOUR>>2]		= M3d_FadeColour;

	for (	; pItem;	pItem=pItem->NextItem)
	{


// Do not need to check inactive flag here, as cull flag will have
// been set for any inactive object by the bounding sphere
// preprocessing, and indeed, checking for the inactive flag will
// screw up the 2-player visilibity boxes (unless the correct
// inactive flag is checked for). So, just don't do it.
//      if (pItem->Flags & (ITEMFLAGS_CULL|ITEMFLAGS_INACTIVE))
      if (pItem->Flags & ITEMFLAGS_CULL)
		{
			continue;
		}
		

		// are we testing against the water level?
		TestTheWater = pItem->Flags & ITEMFLAGS_INWATER ? 1 : 0;


		P_TAG * p_poly_start = (P_TAG *)pPoly;

#			if 1
          WaterNormal.pad = (CurrentWaterLevel >> FRACBITS) - pCurrentCamera->Position.vy;
#			endif

			RenderSuperItemShadow( pItem );
			//RenderSuperItemShadow( pItem );

	DONTDRAW:
		;
	}
	#if SK&WIREFRAME
	M3d_WireframeMode = M3d_WireframeLast;
	#endif

}

void RenderSuperItemShadow(SItem *pItem)
{
	RECORDRA;

	Uint32  NumParts, *pAnimFile, Rgb;
	VECTOR  Position;
	SMatrix *pAnimTransform;
	MATRIX  Transform, SuperTransform,
			  WorldTransform, SuperLightTransform;
	int	  i,Type;
	SModel  *pModel, **ppModels;
	SAnimFrame *pAnimTex;
	Uint16	Scale;
	Sint16	OTPushback;
	Uint32	ItemFlags = pItem->Flags;

   
	if (!PSXRegion[pItem->Region].Fastable || ItemFlags & (ITEMFLAGS_TRN|ITEMFLAGS_RGB|ITEMFLAGS_LIT))
		Fast = 0;
	else
		Fast = 1;


	//	Just to be sure
	ASSERT(PSXRegion[pItem->Region].Usable,"Tried to render superitem	without PSX");

	// flip anim if necessary
	if (((CSuper *)pItem)->mExtraFlags & EXTRAFLAGS_FLIPANIM)
	{
		((CSuper *)pItem)->mTransform.m[0][0] = -((CSuper *)pItem)->mTransform.m[0][0];
		((CSuper *)pItem)->mTransform.m[1][0] = -((CSuper *)pItem)->mTransform.m[1][0];
		((CSuper *)pItem)->mTransform.m[2][0] = -((CSuper *)pItem)->mTransform.m[2][0];
		((Uint16 *)0x1F800000)[SCRATCH_REFLECTED>>1] = 1;
	}
	else
	{
		// make sure flag is cleared, otherwise it will affect later superitems in this itemlist
		((Uint16 *)0x1F800000)[SCRATCH_REFLECTED>>1] = 0;
	}
		//	set up the superitem	transform in eye coords

	gte_SetRotMatrix(&pCurrentCamera->View);
	M3dMaths_MulRotMatrix(&((CSuper *)pItem)->mTransform, &SuperTransform);

		//	transform superitem's local origin

	Position.vx	= (pItem->Position.vx >> FRACBITS) - pCurrentCamera->Position.vx;
	Position.vy	= (pItem->Position.vy >> FRACBITS) - pCurrentCamera->Position.vy;
	Position.vz	= (pItem->Position.vz >> FRACBITS) - pCurrentCamera->Position.vz;
	gte_ldlvl(&Position);
	gte_rtir();
	gte_stlvnl(&SuperTransform.t);

	// Need this temporary variable because SuperTransform.t[] gets multiplied by
	// 16 for near objects (dewibbling).
	Sint16 super_dist = SuperTransform.t[2];

	/*
	if (super_dist < 1000)
	{
		Dewibble=1;
		Position.vx	= (pItem->Position.vx >> FRACBITS-4) - (pCurrentCamera->Position.vx<<4);
		Position.vy	= (pItem->Position.vy >> FRACBITS-4) - (pCurrentCamera->Position.vy<<4);
		Position.vz	= (pItem->Position.vz >> FRACBITS-4) - (pCurrentCamera->Position.vz<<4);
		gte_ldlvl(&Position);
		gte_rtir();
		gte_stlvnl(&SuperTransform.t);
	}
	else
	*/	
		Dewibble=0;



	ASSERT(pItem->Model==0, "I thought the model number was always 0 for a superitem");
	ppModels = PSXRegion[pItem->Region].ppModels;
	NumParts = PSXRegion[pItem->Region].NumParts;

	// get animation pointer...

	// if posed, used pose buffer
	if	(ItemFlags & ITEMFLAGS_POSED)
		pAnimTransform	= ((CSuper *)pItem)->mpPoseBuffer;
	else
		pAnimTransform=Decomp_GetAnimTransform((CSuper *)pItem);

	SMatrix* pFirstTransform = pAnimTransform;
	
	// set up lighting stuff
	gte_MulMatrix0((MATRIX *)&((CItem *)pItem)->mpLight->LightMatrix, &((CSuper *)pItem)->mTransform, &SuperLightTransform);

	// get ellipsoid stuff
	if ((Type = ((CSuper *)pItem)->mEllipsoidRGB>>24) & 0x7F)
	{
		int Lookup = (Type-1)&0x7F;
//		if (Lookup>QB_FIRECYCL)
//			Lookup=QB_FIRECYCL;
		if (Lookup<0)
			Lookup=0;
		pAnimTex = QuickAnimLookup[Lookup];
	   #if DEBUG && SPIDEY
   	if (pAnimTex==NULL)
	   {
   		sprintf(AssertString,"%s",AnimNames[Lookup]);
   		ASSERT(0,"Bits animation not loaded (RenderSuperItemShadow)");
	   }
   	#endif   
		pAnimTex += FrameNo % ((int *)pAnimTex)[-1];
		Rgb = ((CSuper *)pItem)->mEllipsoidRGB & 0xFFFFFF;
		Scale = ((CSuper *)pItem)->mEllipsoidScale;
		OTPushback = ((CSuper *)pItem)->mEllipsoidOTPushback;
	}

	FreeStitchVertex = Fast ? (SProjectedVertex *)0x1F8003F8 : &ProjectedVertices[MAXVERTICES-1];
	pColourTable = PSXRegion[pItem->Region].pColourTable;

	for (i=0; i<NumParts; i++,pAnimTransform++)
	{
			SubObjectMasked = (((CSuper *)pItem)->mSubObjectDisplayMask & 1<<i) ? 1 : 0;

		pModel = ppModels[i];

		// the following compensates for special models
		// such as the create-a-skater, where the render
		// order is not necessarily the animation order
		if (((CSuper*)pItem)->mUseAnimOrder)
		{
			pAnimTransform = pFirstTransform + ((CSuper*)pItem)->mAnimOrder[i];
		}
		
		// if the madel is flagged as invisible, then don't draw it
		// this is used in the front end of Skate, in the create a skater
		// we ahve more that 32 models, so can't use mSubObjectDisplayMask
		// so we just set the invisible flag
		if (pModel->Flags & MODELFLAGS_INVISIBLE)
			SubObjectMasked = 1;

		gte_MulMatrix0(&((CSuper *)pItem)->mTransform,(MATRIX *)pAnimTransform,&WorldTransform);

		if (Dewibble)
			M3dAsm_SetSuperTransformsDewibbled(&SuperTransform, &SuperLightTransform, pAnimTransform);
		else
			M3dAsm_SetSuperTransforms(&SuperTransform, &SuperLightTransform, pAnimTransform);

      
		// render the bodypart
		if (!(Type&0x80))
			if (Fast)
				RenderModelInSuperFast(pModel);
			else
				RenderModelInSuper(pModel);
            
      

		// nothing else to do if bodypart is masked off (it WAS rendered in case it had stitching vertices in it)
//		if (SubObjectMasked)
//			continue;


	}

	// unflip anim if necessary
	if (((CSuper *)pItem)->mExtraFlags & EXTRAFLAGS_FLIPANIM)
	{
		((CSuper *)pItem)->mTransform.m[0][0] = -((CSuper *)pItem)->mTransform.m[0][0];
		((CSuper *)pItem)->mTransform.m[1][0] = -((CSuper *)pItem)->mTransform.m[1][0];
		((CSuper *)pItem)->mTransform.m[2][0] = -((CSuper *)pItem)->mTransform.m[2][0];
	}
   
	#if SPIDEY
   if (((CSuper *)pItem)->mExtraFlags & EXTRAFLAGS_OVERRIDEWATERLEVEL)
     	WaterNormal.pad = OldWaterNormalPad;
   #endif   
}




#endif













// The quick version of the above, makes the following assumtions:
//  No Rotation
//  No lighting of any kind (just regular vertex or face colors)
//  No reflection mappping
//  No transparent objects
//  No super items
//  No water test
//  No scaled items
//  PSX file is in memory, so don't need to check it


void M3d_RenderQuick(void	*p)
{
	RECORDRA;

	int	 i;
	SItem	 *pItem;
	VECTOR Position, PosnRelCam;
	MATRIX Transform,	WorldTransform, TempMatrix;
	SModel *pModel;
	STexture	*pTex;
	POLY_F4 *pFrame;
	Uint32 GlobalFaceFlags;

	#if DEBUG
	ASSERT(RenderSetupCalled,	  "Either M3d_Render	called before M3d_RenderSetup(),\n or M3d_Render()	called after M3d_RenderCleanup");
	#endif

	pItem=(SItem*)p;

	if	(!pItem)	return;

		//	do	bounding	sphere preprocessing

	gte_SetLightMatrix(&FrustumMatrix1);
	gte_SetColorMatrix(&FrustumMatrix2);
	gte_ldbkdir((long)FrustumNormals[0].pad>>1,(long)FrustumNormals[1].pad>>1,0);

   #if SPIDEY
   M3dAsm_BoundingSpherePreprocessing(pItem);
   #else
   if (p != BaddyList)
   {
// if (p == EnviroList)
//      M3dAsm_EnvBoundingSpherePreprocessing(pItem);
      M3dAsm_BoundingSpherePreprocessing(pItem, Camera_CurrentMikeCamera ? ITEMFLAGS_INACTIVE2 : ITEMFLAGS_INACTIVE);
   }
   else
      M3dAsm_BoundingSpherePreprocessing(pItem, ITEMFLAGS_INACTIVE);
   #endif


	// wibble them textures (at this point to make use of bounding sphere culling)

	if (pItem == EnviroList)
	{
		M3d_PreprocessWibblyTextures(EnvRegions[0]);		// one call for each of the two environment regions
		M3d_PreprocessWibblyTextures(EnvRegions[1]);
	}

		//	add everything	in	the world to the display list



		// set up scratchpad vars
		((Uint16 *)0x1F800000)[SCRATCH_DPQMIN>>1]				= DpqMin;
		((Uint16 *)0x1F800000)[SCRATCH_DPQSHIFT>>1]			= DpqShift;
		((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= M3d_OTPushback;
		((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= M3d_OTPushback2;

		((Uint32 *)0x1F800000)[SCRATCH_REFMAPCLUT>>2]		= RefMapClut;
		((Uint32 *)0x1F800000)[SCRATCH_REFMAPTPAGE>>2]		= RefMapTpage;
		((Uint32 *)0x1F800000)[SCRATCH_REFLECTED>>2]			= 0;

		// set up the display modes for this item (lighting, tint and transparency)
		GlobalFaceFlags = 0xFFFF0000;
		((Uint32 *)0x1F800000)[SCRATCH_GLOBALFACEFLAGS>>2]	= GlobalFaceFlags;


		TestTheWater = 0;

		M3dMaths_SetIdentityRotation(&WorldTransform);

	for (	; pItem;	pItem=pItem->NextItem)
	{

#		if DEBUG
		if	(pItem->Flags & (ITEMFLAGS_CULL))
		{
#			if SK
			GRenderedCulled++;
#			endif

#			if MICKMAP
			if	(!(pItem->Flags & (ITEMFLAGS_INACTIVE)))
			{
				if (Mick_MapDoit)
					Mick_ItemOutline(pItem,0x404040);
			}
#			endif
		}

#		if SK
		if	(pItem->Flags & (ITEMFLAGS_INACTIVE))
			GRenderedInvisible++;
#		endif
#		endif


// Do not need to check inactive flag here, as cull flag will have
// been set for any inactive object by the bounding sphere
// preprocessing, and indeed, checking for the inactive flag will
// screw up the 2-player visilibity boxes (unless the correct
// inactive flag is checked for). So, just don't do it.
//      if (pItem->Flags & (ITEMFLAGS_CULL|ITEMFLAGS_INACTIVE))
      if (pItem->Flags & ITEMFLAGS_CULL)
			continue;


		//	Added	by	Ken (will slow	things down	a tad	but only	with DEBUG on)
		#if DEBUG
		if	(pItem->Model>=(Uint32)PSXRegion[pItem->Region].ppModels[-1])
		{
			sprintf(AssertString,"\n %s Model %d",PSXRegion[pItem->Region].Filename,pItem->Model);
			ASSERT(0,"Bad model in pItem");
		}
		#endif

		// get model pointer
		pModel=PSXRegion[pItem->Region].ppModels[pItem->Model];

		if (pModel->Flags & MODELFLAGS_INVISIBLE)
			continue;

		//	get camera's view transform in rot matrix
		gte_SetRotMatrix(&pCurrentCamera->View);
		m3d_ZeroTransVector();

		//	transform item's local origin
		PosnRelCam.vx = (pItem->Position.vx	>>	FRACBITS) -	pCurrentCamera->Position.vx;
		PosnRelCam.vy = (pItem->Position.vy	>>	FRACBITS) -	pCurrentCamera->Position.vy;
		PosnRelCam.vz = (pItem->Position.vz	>>	FRACBITS) -	pCurrentCamera->Position.vz;
		gte_ldlv0(&PosnRelCam);
		gte_rtv0();
		gte_stlvnl(&Position);

		// level of detail
		#if DEBUG
		if (!Pad[1].Triangle.Pressed)
		#endif
		{
			#if SK
			if (pModel->zMax < 0)	  // negative zMax indicates it's a fraction of DpqMax 
			{
				while (Position.vz>-(((Sint16)(pModel->zMax*pCurrentViewport->Zoom/DEFZOOM))*DpqMax>>10) && pModel->NextLOD!=0xFFFF)
					pModel=PSXRegion[pItem->Region].ppModels[pModel->NextLOD];
				if (Position.vz>-(((Sint16)(pModel->zMax*pCurrentViewport->Zoom/DEFZOOM))*DpqMax>>10) && pModel->NextLOD==0xFFFF)
					continue;
			}
			else
			#endif
			{
				while (Position.vz>pModel->zMax*pCurrentViewport->Zoom/DEFZOOM && pModel->NextLOD!=0xFFFF)
					pModel=PSXRegion[pItem->Region].ppModels[pModel->NextLOD];
				if (Position.vz>pModel->zMax*pCurrentViewport->Zoom/DEFZOOM && pModel->NextLOD==0xFFFF)
					continue;
			}
		}

		if (pModel->NumVertices <= 100
			 && (pItem->Flags & (ITEMFLAGS_LIT|ITEMFLAGS_GOURAUD)) == 0
			 && ((pModel->Flags&MODELFLAGS_SUBDIVIDABLE)==0 && pModel->Radius < (Position.vz<<FRACBITS) ||
				 Position.vz-(pModel->Radius>>FRACBITS) > pCurrentViewport->Yon/2)
			 && !(pItem->Angles.vx|pItem->Angles.vy|pItem->Angles.vz))
			Fast = 1;
		else
			Fast = 0;

		pColourTable = PSXRegion[pItem->Region].pColourTable;

		if (Fast)
		{
			#if DEBUG&&SK
			GRenderedFast++;
			#endif
			#if DEBUG&&MICKMAP
			if (Mick_MapDoit)
				Mick_Item(pItem,0x008000);
			#endif
			RenderModelFast(pModel,&PosnRelCam);
			continue;
		}

		if	(pItem->Angles.vx==0	&&	pItem->Angles.vy==0 && pItem->Angles.vz==0 && !(pItem->Flags&ITEMFLAGS_SCALED))
		{
			#if DEBUG&&SK
			GRenderedNonRotated++;
			#endif
			RenderModelNonRotated(pModel,&PosnRelCam);
			#if DEBUG&&MICKMAP
			if (Mick_MapDoit)
				Mick_Item(pItem,0x800000);
			#endif
		}
		else
		{
			#if DEBUG&&SK
			GRenderedRotated++;
			#endif
			gte_SetTransVector(&Position);
			RenderModel(pModel);
		}
	}
}



void M3d_RenderBackground(void *p)
{
	RECORDRA;

	int	 i;
	SItem	 *pItem;
	VECTOR Position, PosnRelCam;
	MATRIX Transform,	WorldTransform;
	SModel *pModel;
	STexture	*pTex;
	POLY_F4 *pFrame;
	Uint32 GlobalFaceFlags;


	pItem=(SItem*)p;

	if	(!pItem)	return;

	// force no depthcueing and reset various other scratchpad vars
	((Uint16 *)0x1F800000)[SCRATCH_DPQMIN>>1]		= 0x7FFF;
	((Uint16 *)0x1F800000)[SCRATCH_REFLECTED>>1]	= 0;

	//	add everything	in	the background to the display list
	for (	; pItem;	pItem=pItem->NextItem)
	{
		if	(pItem->Flags & (ITEMFLAGS_CULL|ITEMFLAGS_INACTIVE))
			continue;

		//	Added	by	Ken (will slow	things down	a tad	but only	with DEBUG on)
		#if DEBUG
		if	(pItem->Model>=(Uint32)PSXRegion[pItem->Region].ppModels[-1])
		{
			sprintf(AssertString,"\n %s Model %d",PSXRegion[pItem->Region].Filename,pItem->Model);
			ASSERT(0,"Bad model in pItem");
		}
		#endif

		//	don't	draw if PSX	file is currently	being	spooled in
		if	(!PSXRegion[pItem->Region].Usable)
		{
			MESSAGE("PSX not usable");
			continue;
		}

		#if DEBUG
		GlobalFaceFlags = DebugFaceFlags;
		#else
		GlobalFaceFlags = 0xFFFF0000;
		#endif

		((Uint32 *)0x1F800000)[SCRATCH_GLOBALFACEFLAGS>>2]	= GlobalFaceFlags;

		//	get camera's view transform in rot matrix
		gte_SetRotMatrix(&pCurrentCamera->View);

		//	set rotation (if non-zero)
		if (pItem->Angles.vx || pItem->Angles.vy || pItem->Angles.vz)
		{
			M3dMaths_RotMatrixYXZ((SVECTOR *)(&pItem->Angles),	&WorldTransform);
			M3dMaths_MulRotMatrix(&WorldTransform,&Transform);
			gte_SetRotMatrix(&Transform);
		}
		else
			M3dMaths_SetIdentityRotation(&WorldTransform);

		pColourTable = PSXRegion[pItem->Region].pColourTable;
		pModel=PSXRegion[pItem->Region].ppModels[pItem->Model];

		if	(pItem->Angles.vx==0	&&	pItem->Angles.vy==0 && pItem->Angles.vz==0)
			RenderBackgroundModelNonRotated(pModel);
		else
			RenderBackgroundModel(pModel);
	}

	// restore depthcueing
	((Uint16 *)0x1F800000)[SCRATCH_DPQMIN>>1] = DpqMin;
}

#if KENVIEWER
int TestModel=-1;
#endif
void RenderSuperItem(SItem *pItem)
{
	RECORDRA;

	Uint32  NumParts, *pAnimFile, Rgb;
	VECTOR  Position;
	SMatrix *pAnimTransform;
	MATRIX  Transform, SuperTransform,
			  WorldTransform, SuperLightTransform;
	int	  i,Type;
	SModel  *pModel, **ppModels;
	SAnimFrame *pAnimTex;
	Uint16	Scale;
	Sint16	OTPushback;
	Uint32	ItemFlags = pItem->Flags;

	#if SPIDEY
   // An ugly hack. When symbiotes die they melt into the ground using the water clipping
   // to clip them. Trouble is, two might die at once at different y's, so we really need
   // different water levels for different instances.
   // This hack stores the old water level, then restores it at the end of the function.
   int OldWaterNormalPad;
   if (((CSuper *)pItem)->mExtraFlags & EXTRAFLAGS_OVERRIDEWATERLEVEL)
   {
   	OldWaterNormalPad=WaterNormal.pad;
     	WaterNormal.pad = ((CSuper *)pItem)->mWaterLevel - pCurrentCamera->Position.vy;
   }
   #endif   
      
   
	if (!PSXRegion[pItem->Region].Fastable || ItemFlags & (ITEMFLAGS_TRN|ITEMFLAGS_RGB|ITEMFLAGS_LIT))
		Fast = 0;
	else
		Fast = 1;

	#if KENVIEWER
	Fast=0;
	#endif

	//	Just to be sure
	ASSERT(PSXRegion[pItem->Region].Usable,"Tried to render superitem	without PSX");

	// flip anim if necessary
	if (((CSuper *)pItem)->mExtraFlags & EXTRAFLAGS_FLIPANIM)
	{
		((CSuper *)pItem)->mTransform.m[0][0] = -((CSuper *)pItem)->mTransform.m[0][0];
		((CSuper *)pItem)->mTransform.m[1][0] = -((CSuper *)pItem)->mTransform.m[1][0];
		((CSuper *)pItem)->mTransform.m[2][0] = -((CSuper *)pItem)->mTransform.m[2][0];
		((Uint16 *)0x1F800000)[SCRATCH_REFLECTED>>1] = 1;
	}
	else
	{
		// make sure flag is cleared, otherwise it will affect later superitems in this itemlist
		((Uint16 *)0x1F800000)[SCRATCH_REFLECTED>>1] = 0;
	}
		//	set up the superitem	transform in eye coords

	gte_SetRotMatrix(&pCurrentCamera->View);
	M3dMaths_MulRotMatrix(&((CSuper *)pItem)->mTransform, &SuperTransform);

		//	transform superitem's local origin

	Position.vx	= (pItem->Position.vx >> FRACBITS) - pCurrentCamera->Position.vx;
	Position.vy	= (pItem->Position.vy >> FRACBITS) - pCurrentCamera->Position.vy;
	Position.vz	= (pItem->Position.vz >> FRACBITS) - pCurrentCamera->Position.vz;
	gte_ldlvl(&Position);
	gte_rtir();
	gte_stlvnl(&SuperTransform.t);

	// Need this temporary variable because SuperTransform.t[] gets multiplied by
	// 16 for near objects (dewibbling).
	Sint16 super_dist = SuperTransform.t[2];

	if (super_dist < 1000)
	{
		Dewibble=1;
		Position.vx	= (pItem->Position.vx >> FRACBITS-4) - (pCurrentCamera->Position.vx<<4);
		Position.vy	= (pItem->Position.vy >> FRACBITS-4) - (pCurrentCamera->Position.vy<<4);
		Position.vz	= (pItem->Position.vz >> FRACBITS-4) - (pCurrentCamera->Position.vz<<4);
		gte_ldlvl(&Position);
		gte_rtir();
		gte_stlvnl(&SuperTransform.t);
	}
	else
		Dewibble=0;

	ASSERT(pItem->Model==0, "I thought the model number was always 0 for a superitem");
	ppModels = PSXRegion[pItem->Region].ppModels;
	NumParts = PSXRegion[pItem->Region].NumParts;

	// get animation pointer...

	// if posed, used pose buffer
	if	(ItemFlags & ITEMFLAGS_POSED)
		pAnimTransform	= ((CSuper *)pItem)->mpPoseBuffer;
	else
		pAnimTransform=Decomp_GetAnimTransform((CSuper *)pItem);

	#if SK
	SMatrix* pFirstTransform = pAnimTransform;
	#endif
	
	// set up lighting stuff
	gte_MulMatrix0((MATRIX *)&((CItem *)pItem)->mpLight->LightMatrix, &((CSuper *)pItem)->mTransform, &SuperLightTransform);

	// get ellipsoid stuff
	if ((Type = ((CSuper *)pItem)->mEllipsoidRGB>>24) & 0x7F)
	{
		int Lookup = (Type-1)&0x7F;
//		if (Lookup>QB_FIRECYCL)
//			Lookup=QB_FIRECYCL;
		if (Lookup<0)
			Lookup=0;
		pAnimTex = QuickAnimLookup[Lookup];
	   #if DEBUG && SPIDEY
   	if (pAnimTex==NULL)
	   {
   		sprintf(AssertString,"%s",AnimNames[Lookup]);
   		ASSERT(0,"Bits animation not loaded (RenderSuperItem)");
	   }
   	#endif   
		pAnimTex += FrameNo % ((int *)pAnimTex)[-1];
		Rgb = ((CSuper *)pItem)->mEllipsoidRGB & 0xFFFFFF;
		Scale = ((CSuper *)pItem)->mEllipsoidScale;
		OTPushback = ((CSuper *)pItem)->mEllipsoidOTPushback;
	}

	FreeStitchVertex = Fast ? (SProjectedVertex *)0x1F8003F8 : &ProjectedVertices[MAXVERTICES-1];
	pColourTable = PSXRegion[pItem->Region].pColourTable;

	for (i=0; i<NumParts; i++,pAnimTransform++)
	{
#		if SK
			SubObjectMasked = (((CSuper *)pItem)->mSubObjectDisplayMask & 1<<i) ? 1 : 0;
#		else
		if( i > 31 )
			SubObjectMasked = (((CSuper *)pItem)->mSubObjectDisplayMask2 & 1<<(i-32)) ? 1 : 0;
		else
			SubObjectMasked = (((CSuper *)pItem)->mSubObjectDisplayMask & 1<<i) ? 1 : 0;
#		endif

		pModel = ppModels[i];

		#if SK
		// the following compensates for special models
		// such as the create-a-skater, where the render
		// order is not necessarily the animation order
		if (((CSuper*)pItem)->mUseAnimOrder)
		{
			pAnimTransform = pFirstTransform + ((CSuper*)pItem)->mAnimOrder[i];
		}
		
		// if the madel is flagged as invisible, then don't draw it
		// this is used in the front end of Skate, in the create a skater
		// we ahve more that 32 models, so can't use mSubObjectDisplayMask
		// so we just set the invisible flag
		if (pModel->Flags & MODELFLAGS_INVISIBLE)
			SubObjectMasked = 1;
		#endif

#		if SPIDEY
		// Determine the correct LOD model pointer.
		while( ( super_dist > pModel->zMax*pCurrentViewport->Zoom/DEFZOOM ) && ( pModel->NextLOD != 0xFFFF ) )
			pModel = PSXRegion[pItem->Region].ppModels[pModel->NextLOD];

		// Clip if too far away.
		if( ( super_dist > pModel->zMax*pCurrentViewport->Zoom/DEFZOOM ) && ( pModel->NextLOD == 0xFFFF ) )
			continue;
#		endif

		gte_MulMatrix0(&((CSuper *)pItem)->mTransform,(MATRIX *)pAnimTransform,&WorldTransform);

		if (Dewibble)
			M3dAsm_SetSuperTransformsDewibbled(&SuperTransform, &SuperLightTransform, pAnimTransform);
		else
			M3dAsm_SetSuperTransforms(&SuperTransform, &SuperLightTransform, pAnimTransform);

		if	(pModel->Flags	& MODELFLAGS_REFLECTIONMAPPED || pItem->Flags & ITEMFLAGS_REFLECTIONMAPPED)
		{
//			gte_MulMatrix0(&((CSuper *)pItem)->mTransform,(MATRIX *)pAnimTransform,&WorldTransform);
#if DEBUG
			ASSERT(!PSXRegion[pItem->Region].Fastable, "Reflection-mapped models should not be fastable");
#endif
			M3dAsm_GetReflectionMapping(&WorldTransform, SuperTransform.t, (Uint32 *)pModel);
		}
		else if (pModel->Flags & MODELFLAGS_LIT || ItemFlags & ITEMFLAGS_LIT)
		{
			gte_SetColorMatrix((MATRIX *)&((CItem *)pItem)->mpLight->ColorMatrix);
			M3dAsm_SetAmbient(((CItem *)pItem)->mpLight->BackColor);
#if DEBUG
			ASSERT(!PSXRegion[pItem->Region].Fastable, "Dynamically lit models should not be fastable");
#endif
			M3dAsm_GetDynamicLighting(pModel->Vertices+pModel->NumVertices,pModel->NumNormals);
		}

		#if SPIDEY && !KENVIEWER
      // Set the RecordRenderedFaces flag according to whether the superitem requires it.
      if (((CSuper *)pItem)->mExtraFlags & EXTRAFLAGS_DRAWOUTLINE)
      {
      	RecordRenderedFaces=TRUE;
         // Initialise the bitfield.
         pRenderedFaces[0]=0;
         pRenderedFaces[1]=0;
      }   
	   #endif
      
		// render the bodypart
		if (!(Type&0x80))
			if (Fast)
				RenderModelInSuperFast(pModel);
			else
				RenderModelInSuper(pModel);
            
	  	#if SPIDEY && !KENVIEWER
		if (RecordRenderedFaces)
	   {
      	// Call the draw outline function, then reset the flag.
         // DrawModelOutline uses the pRenderedFaces bitfield that has just been calculated.
   		((CSuper *)pItem)->DrawModelOutline(i,pModel);
			RecordRenderedFaces=FALSE;
   	}
	   #endif
      
      #if KENVIEWER
      // A quick hack to display the vertex numbers of a particular model superimposed
      // on it. Used for choosing suitable vertices to do the symbiote skin effect on
      // Venom in the Spidey project.
      extern void Viewer_DisplayModelVertexIndices(SModel *pModel);
      if (i==TestModel) Viewer_DisplayModelVertexIndices(pModel);
      #endif

		// nothing else to do if bodypart is masked off (it WAS rendered in case it had stitching vertices in it)
//		if (SubObjectMasked)
//			continue;

		// Ellipsoid effects and shadow(s) for this bodypart.
		int DoEllipsoids = Type & 0x7F;
#		if SPIDEY && !KENVIEWER
		// Can mask the ellipsoid effect of individual bodyparts.
		DoEllipsoids = DoEllipsoids && !( ( (CSuper *)pItem )->mSubObjectEllipsoidDisplayMask & ( 1 << i ) );
#		endif

		int DoShadows = ( (CSuper *)pItem )->mShadowLights > 0;
#		if SPIDEY && !KENVIEWER
		// Can mask the shadows of individual bodyparts.
		DoShadows = DoShadows && !( ( (CSuper *)pItem )->mSubObjectShadowDisplayMask & ( 1 << i ) );
#		endif

		if (DoEllipsoids||DoShadows)
		{
//			gte_MulMatrix0(&((CSuper *)pItem)->mTransform,(MATRIX *)pAnimTransform,&WorldTransform);
			gte_ldsv(&pAnimTransform->t);
			M3dMaths_TransformLastVec((XMat *)&((CSuper *)pItem)->mTransform.m);
			gte_stlvnl(&WorldTransform.t);

#			if SCALED_OFFSETS
			// Scale the translation vector back down.
			WorldTransform.t[0] >>= 4;
			WorldTransform.t[1] >>= 4;
			WorldTransform.t[2] >>= 4;
#			endif

			WorldTransform.t[0] += pItem->Position.vx>>FRACBITS;
			WorldTransform.t[1] += pItem->Position.vy>>FRACBITS;
			WorldTransform.t[2] += pItem->Position.vz>>FRACBITS;
		}

#		if !KENVIEWER
		if (DoEllipsoids && (!TestTheWater || WorldTransform.t[1]<(CurrentWaterLevel>>FRACBITS)-40))
			M3dElips_RenderEllipsoid(pModel, &WorldTransform, Rgb, Scale, OTPushback, pAnimTex->pTexture);
      #if SK   
		if (DoShadows)
			for (int s=0; s<((CSuper *)pItem)->mShadowLights; s++)
			{								  
				if (!SubObjectMasked)
				M3dElips_RenderShadow(pModel, &WorldTransform, &((CSuper *)pItem)->mShadowNormal, &((CSuper *)pItem)->mShadowPos,
											 &((CSuper *)pItem)->mpShadowSource[s], ((CSuper *)pItem)->mpShadowRGB[s]);
				
			}
		#endif
		#endif
	}

	// unflip anim if necessary
	if (((CSuper *)pItem)->mExtraFlags & EXTRAFLAGS_FLIPANIM)
	{
		((CSuper *)pItem)->mTransform.m[0][0] = -((CSuper *)pItem)->mTransform.m[0][0];
		((CSuper *)pItem)->mTransform.m[1][0] = -((CSuper *)pItem)->mTransform.m[1][0];
		((CSuper *)pItem)->mTransform.m[2][0] = -((CSuper *)pItem)->mTransform.m[2][0];
	}
   
	#if SPIDEY
   if (((CSuper *)pItem)->mExtraFlags & EXTRAFLAGS_OVERRIDEWATERLEVEL)
     	WaterNormal.pad = OldWaterNormalPad;
   #endif   
}

		 


void RenderModel(SModel *pModel)
{
	RECORDRA;

	Uint32	Outcode,	*pFace, Num;
	SVECTOR	*pGeom;

	pGeom	= pModel->Vertices;
	Num =	pModel->NumVertices;
	Outcode = M3dAsm_TransformAndOutcodeItemVertices(pGeom,Num);
	if (TestTheWater)
      M3dAsm_OutcodeVerticesInWater(Num, WaterClipValue);
	pGeom+=Num;

	if	(Outcode	& 0xBF)		//	do	all outcodes have	a common	bit?
		return;

	pFace	= (Uint32 *)(pGeom+pModel->NumNormals);
	Num =	pModel->NumFaces;

	SetFarColor(FarColor.vx, FarColor.vy, FarColor.vz);

	#if NOPUSHBACK
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= 0;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= 0;
	#endif

	#if WIREFRAME
	if (M3d_WireframeMode)
		Wireframe_ProcessPolys(pFace,Num,0x000080);	
	if (M3d_WireframeMode == WIREFRAME_NONE || M3d_WireframeMode == WIREFRAME_TEXTURED)  
	#endif
   

	M3dAsm_ProcessPolys(pFace,pGeom,Num);		//	add faces to display	buffer
}



void RenderModelFast(SModel *pModel,VECTOR *pPosnRelCam)
{
	RECORDRA;

	Uint32	Outcode,	*pFace, Num, NumVerts;
	SVECTOR	*pGeom;

	#if NOPUSHBACK
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= 0;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= 0;
	#endif

	pGeom	= pModel->Vertices;
	NumVerts =	pModel->NumVertices;
	ASSERT(pModel->NumVertices<200,"Eh?");
	Outcode = M3dAsm_TransformAndOutcodeVerticesFast(pGeom,NumVerts,pPosnRelCam);
	pGeom+=NumVerts;

	if	(Outcode	& 0x6000E000)		//	do	all outcodes have	a common	bit?
		return;

	pFace	= (Uint32 *)(pGeom+pModel->NumNormals);
	Num =	pModel->NumFaces;

	SetFarColor(FarColor.vx, FarColor.vy, FarColor.vz);

	#if NOPUSHBACK
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= 0;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= 0;
	#endif


	#if WIREFRAME
	if (M3d_WireframeMode)
	{
		M3dAsm_TransformAndOutcodeBlockVertices(pModel->Vertices,NumVerts,pPosnRelCam);
		Wireframe_ProcessPolys(pFace,Num,0x008000);
	}
	if (M3d_WireframeMode == WIREFRAME_NONE || M3d_WireframeMode == WIREFRAME_TEXTURED)  
//	Outcode = M3dAsm_TransformAndOutcodeVerticesFast(pGeom,NumVerts,pPosnRelCam);
	#endif
	M3dAsm_ProcessPolysFast(pFace,pGeom,Num);		//	add faces to display	buffer
}



void RenderBackgroundModel(SModel *pModel)
{
	RECORDRA;

	Uint32	Outcode,	*pFace, Num;
	SVECTOR	*pGeom;

	pGeom	= pModel->Vertices;
	Num =	pModel->NumVertices;
	Outcode = M3dAsm_TransformAndOutcodeBackgroundVertices(pGeom,Num);
	pGeom+=Num;

	if	(Outcode	& 0xBF)		//	do	all outcodes have	a common	bit?
		return;

	pFace	= (Uint32 *)(pGeom+pModel->NumNormals);
	Num =	pModel->NumFaces;

	#if NOPUSHBACK
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= 0;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= 0;
	#endif

	#if WIREFRAME
	if (M3d_WireframeMode)
		Wireframe_ProcessPolys(pFace,Num,0x008000);
	if (M3d_WireframeMode == WIREFRAME_NONE || M3d_WireframeMode == WIREFRAME_TEXTURED)  
	#endif
	M3dAsm_ProcessPolys(pFace,pGeom,Num);		//	add faces to display	buffer
}





void RenderModelInSuper(SModel *pModel)
{
	RECORDRA;

	Uint32	Outcode,	*pFace, Num;
	SVECTOR	*pGeom;

	pGeom	= pModel->Vertices;
	Num =	pModel->NumVertices;
	if (Dewibble)
		Outcode = M3dAsm_TransformAndOutcodeSuperVerticesDewibbled(pGeom,Num);
	else
		Outcode = M3dAsm_TransformAndOutcodeSuperVertices(pGeom,Num);
	if (TestTheWater)
      M3dAsm_OutcodeVerticesInWater(Num, WaterClipValue);
	pGeom+=Num;

	if (SubObjectMasked)
		return;

	if	(Outcode	& 0xBF)		//	do	all outcodes have	a common	bit?
		return;

	pFace	= (Uint32 *)(pGeom+pModel->NumNormals);
	Num =	pModel->NumFaces;

	#if NOPUSHBACK
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= 0;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= 0;
	#endif

	#if WIREFRAME
	if (M3d_WireframeMode)
		Wireframe_ProcessPolys(pFace,Num,0x800080);
	if (M3d_WireframeMode == WIREFRAME_NONE || M3d_WireframeMode == WIREFRAME_TEXTURED)  
	#endif
	{
		#if SK
		if (Patch_Black)
			Black_ProcessPolys(pFace,Num,0x800080);
		else
		#endif
			M3dAsm_ProcessPolys(pFace,pGeom,Num);		//	add faces to display	buffer
	}
}



void RenderModelInSuperFast(SModel *pModel)
{
	RECORDRA;

	Uint32	Outcode,	*pFace, Num;
	SVECTOR	*pGeom;

	pGeom	= pModel->Vertices;
	Num =	pModel->NumVertices;
	ASSERT(pModel->NumVertices<200,"Eh?");
	if (Dewibble)
		Outcode = M3dAsm_TransformAndOutcodeSuperVerticesFastDewibbled(pGeom,Num);
	else
		Outcode = M3dAsm_TransformAndOutcodeSuperVerticesFast(pGeom,Num);
	pGeom+=Num;

	if (SubObjectMasked)
		return;

	if	(Outcode	& 0x60006000)		//	do	all outcodes have	a common	bit?
		return;

	pFace	= (Uint32 *)(pGeom+pModel->NumNormals);
	Num =	pModel->NumFaces;

	#if NOPUSHBACK
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= 0;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= 0;
	#endif

	#if WIREFRAME
//	Wireframe_ProcessPolys(pFace,Num,0);
	#endif
	{
		#if SK
		if (Patch_Black)
			Black_ProcessPolys(pFace,Num,0x800080);
		else
		#endif
		M3dAsm_ProcessPolysFast(pFace,pGeom,Num);		//	add faces to display	buffer
	}
}



void RenderModelNonRotated(SModel *pModel, VECTOR	*pPosnRelCam)
{
	RECORDRA;

	Uint32	Outcode,	*pFace, Num;
	SVECTOR	*pGeom;

	pGeom	= pModel->Vertices;
	Num =	pModel->NumVertices;
	Outcode = M3dAsm_TransformAndOutcodeBlockVertices(pGeom,Num,pPosnRelCam);
	if (TestTheWater)
      M3dAsm_OutcodeVerticesInWater(Num, WaterClipValue);
	pGeom+=Num;

	if	(Outcode	& 0xBF)		//	do	all outcodes have	a common	bit?
		return;

	pFace	= (Uint32 *)(pGeom+pModel->NumNormals);
	Num =	pModel->NumFaces;

	SetFarColor(FarColor.vx, FarColor.vy, FarColor.vz);

	#if NOPUSHBACK
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= 0;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= 0;
	#endif

	#if WIREFRAME
	if (M3d_WireframeMode)
		Wireframe_ProcessPolys(pFace,Num,0x008080);
	if (M3d_WireframeMode == WIREFRAME_NONE || M3d_WireframeMode == WIREFRAME_TEXTURED)  
	#endif

#	if SK
	M3dAsm_ProcessPolys(pFace,pGeom,Num);		//	add faces to display	buffer
#	elif DAVE && DEBUG && 0
	if( T[3] )
	{
		// If any polys of this object are nearer then d/2, render it using the near z clipping plane code.
		for( int i = 0; i < pModel->NumVertices; ++i )
		{
			if( ProjectedVertices[i].z <= ( pCurrentViewport->Zoom / 2 ) )
			{
				ProcessPolysNearZClipped( pModel, pFace, pGeom, Num );
				return;
			}
		}
	}

	// No near z clipped polys, so just use the regular routine.
	M3dAsm_ProcessPolys(pFace,pGeom,Num);		//	add faces to display	buffer
#	else
	M3dAsm_ProcessPolys(pFace,pGeom,Num);		//	add faces to display	buffer
#	endif
}


void RenderBackgroundModelNonRotated(SModel *pModel)
{
	RECORDRA;

	Uint32	Outcode,	*pFace, Num;
	SVECTOR	*pGeom;

	pGeom	= pModel->Vertices;
	Num =	pModel->NumVertices;
	Outcode = M3dAsm_TransformAndOutcodeBackgroundVertices(pGeom,Num);
	pGeom+=Num;

	if	(Outcode	& 0xBF)		//	do	all outcodes have	a common	bit?
		return;

	pFace	= (Uint32 *)(pGeom+pModel->NumNormals);
	Num =	pModel->NumFaces;

	#if NOPUSHBACK
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK>>1]		= 0;
	((Uint16 *)0x1F800000)[SCRATCH_OTPUSHBACK2>>1]		= 0;
	#endif

	#if WIREFRAME
	if (M3d_WireframeMode)
		Wireframe_ProcessPolys(pFace,Num,0x202060);
	if (M3d_WireframeMode == WIREFRAME_NONE || M3d_WireframeMode == WIREFRAME_TEXTURED)  
	#endif

	M3dAsm_ProcessPolys(pFace,pGeom,Num);		//	add faces to display	buffer
}




